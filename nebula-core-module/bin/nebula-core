#!/system/bin/sh
set -u

PROTOCOL_VERSION=1
MODULE_ID=nebula_core
DATA_DIR=${NEBULA_DATA_DIR:-/data/adb/nebula}
LOG_DIR="$DATA_DIR/logs"
STATE_DIR="$DATA_DIR/state"
LOG_FILE="$LOG_DIR/nebula-core.log"
PROFILE_FILE="$STATE_DIR/profile"
SNAPSHOT_DIR="$STATE_DIR/snapshots"
COOLING_SNAPSHOT_FILE="$SNAPSHOT_DIR/cooling.json"
ADB_WIFI_AUTO_FILE="$STATE_DIR/adb_wifi_auto_enable"
ADB_WIFI_STATE_FILE="$STATE_DIR/adb_wifi.state"
SAFE_MODE_FILE="$DATA_DIR/safe_mode"
SCRIPT_DIR=${0%/*}
MODDIR=${NEBULA_MODULE_DIR:-${SCRIPT_DIR%/*}}
MODULE_PROP=${NEBULA_MODULE_PROP:-$MODDIR/module.prop}
DEFAULTS_JSON=${NEBULA_DEFAULTS_JSON:-$MODDIR/config/defaults.json}
MODULES_ROOT=${NEBULA_MODULES_ROOT:-/data/adb/modules}
REDMAGIC_SOURCE_COMMIT=e94d36e8204c228c6e8781157dea22946cf715e3
REDMAGIC_SOURCE_FAN="Redmagic-Control-Center HardwareController.kt:25-28,48-77@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_PUMP="Redmagic-Control-Center HardwareController.kt:30-32,80-98; DashboardSnapshot.kt:16-18; DeviceCapabilityScanner.kt:43-45@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_THERMAL="Redmagic-Control-Center HardwareController.kt:275-288@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_IDENTITY="Redmagic-Control-Center DeviceCapabilityScanner.kt:33-36@$REDMAGIC_SOURCE_COMMIT"
LEGACY_DROIDSPACES_SOURCE="Droidspaces: Daemon & Init /data/adb/modules/droidspaces service.sh,post-fs-data.sh,sepolicy.rule captured 2026-06-22"
LEGACY_BRIDGE_SOURCE="RM11 Droidspaces Bridge FD Policy /data/adb/modules/rm11-droidspace-bridge-fd service.sh,sepolicy.rule captured 2026-06-22"
NUBIA_TOOLKIT_SOURCE_COMMIT=0a2ee1a234b7f03dc6c5b0077bff003c1ba7c128
NUBIA_TOOLKIT_SOURCE="NubiaToolkit HookEntry and feature hooks@$NUBIA_TOOLKIT_SOURCE_COMMIT"
NUBIA_TOOLKIT_PACKAGE=com.khanhnguyen9872.nubiatoolkit
NUBIA_GAME_ASSIST_PACKAGE=cn.nubia.gameassist
NUBIA_GAME_LAUNCHER_PACKAGE=cn.nubia.gamelauncher
WAYLANDIE_PACKAGE=io.droidspaces.nebula.waylandie
WAYLANDIE_SOURCE_COMMIT=1526655a2470
WAYLANDIE_SOURCE="WayLandIE root-assisted proot launch@$WAYLANDIE_SOURCE_COMMIT"
DISPLAY_PHONE_SOURCE="Sidecar-11 WayLandIE/Gamescope/Xwayland evidence: RGB GLX visual/fbconfig blocker"
DISPLAY_PHONE_PROMOTION_SOURCE="Sidecar-13 XWAYLAND_GLX_RENDER_PASS_FORCE_COMPOSITION: --force-composition, ARGB8888, ready-without-sync-fd"
DISPLAY_PHONE_RUNTIME_CONSTRAINT="live-confirmed NX809J stock RedMagic ROM with OnePlus Wild kernel: CONFIG_ARM64_VA_BITS=39, 4K pages, PA_BITS=48, compat enabled; avoid 45-bit runtime assumptions"
DISPLAY_PHONE_RUNTIME_BLOCKER="ARM64EC Wine GUI blocked after force-composition: winex11.drv loads then fails during process attach with SEH invalid-frame/c0000005 under 39-bit VA"
ANLAND_REPAIR_SOURCE="Droidspaces-OSS tools/fix-anland-display.sh@6db8940190ea; anland display_producer timeout fix@5d69f36dd5a0"
DRM_LEASE_SOURCE="Bob Dilian DRM lease evidence captured 2026-06-22; docs/integration/DRM_CONTROL_REFERENCE.md"
ANLAND_DROIDSPACES_BIN=/data/local/Droidspaces/bin/droidspaces
ANLAND_CONTAINER=ubuntu
ANLAND_CONFIG=/data/local/Droidspaces/Containers/ubuntu/container.config
ANLAND_ENV=/data/local/Droidspaces/Containers/ubuntu/anland.env
ANLAND_SOCKET_HOST=/data/local/tmp/display_daemon.sock
ANLAND_SOCKET_GUEST=/run/display.sock
ANLAND_RENDER_NODE=/dev/dri/renderD128

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$STATE_DIR" 2>/dev/null || return 0
  if [ ! -s "$PROFILE_FILE" ]; then
    printf '%s\n' safe > "$PROFILE_FILE" 2>/dev/null || true
  fi
}

prop_value() {
  key=$1
  if [ -f "$MODULE_PROP" ]; then
    sed -n "s/^$key=//p" "$MODULE_PROP" | head -n 1
  fi
}

module_version() {
  value=$(prop_value version)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

module_version_code() {
  value=$(prop_value versionCode)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' 0
  fi
}

git_commit() {
  value=${NEBULA_GIT_COMMIT:-}
  if [ -z "$value" ] && [ -f "$MODDIR/config/git-commit.txt" ]; then
    value=$(sed -n '1p' "$MODDIR/config/git-commit.txt")
  fi
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

json_output_string() {
  value=$(printf '%s' "$1" | tr '\r\n' '  ' | cut -c 1-2048)
  json_string "$value"
}

json_string_or_null() {
  if [ -n "$1" ]; then
    json_string "$1"
  else
    printf '%s' null
  fi
}

json_int_or_null() {
  case "$1" in
    ''|*[!0-9-]*) printf '%s' null ;;
    *) printf '%s' "$1" ;;
  esac
}

is_unsigned_integer() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

json_number_from_milli() {
  milli=$1
  case "$milli" in
    ''|*[!0-9-]*) printf '%s' null; return ;;
  esac
  sign=
  case "$milli" in
    -*) sign=-; milli=${milli#-} ;;
  esac
  whole=$((milli / 1000))
  frac=$((milli % 1000))
  printf '%s%s.%03d' "$sign" "$whole" "$frac"
}

config_bool() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*true.*/true/p" \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*false.*/false/p" \
      "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\([-0-9.][0-9.]*\\).*/\\1/p" "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number_default() {
  key=$1
  fallback=$2
  value=$(config_number "$key")
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

json_bool() {
  if [ "$1" = "1" ]; then
    printf '%s' true
  else
    printf '%s' false
  fi
}

safe_mode_value() {
  if [ -f "$SAFE_MODE_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

current_profile() {
  if [ -s "$PROFILE_FILE" ]; then
    value=$(head -n 1 "$PROFILE_FILE")
  else
    value=safe
  fi
  case "$value" in
    safe|phone|dock|compatibility) printf '%s' "$value" ;;
    *) printf '%s' safe ;;
  esac
}

daemon_running_value() {
  pid_file="$STATE_DIR/service.pid"
  if [ -s "$pid_file" ]; then
    pid=$(head -n 1 "$pid_file")
    case "$pid" in
      *[!0-9]*|'') printf '%s' 0 ;;
      *)
        if kill -0 "$pid" 2>/dev/null; then
          printf '%s' 1
        else
          printf '%s' 0
        fi
        ;;
    esac
  else
    printf '%s' 0
  fi
}

service_status() {
  if [ "$(daemon_running_value)" = "1" ]; then
    printf '%s' running
  elif [ -d "$STATE_DIR" ]; then
    printf '%s' state_ready
  else
    printf '%s' missing_state
  fi
}

log_command() {
  ensure_dirs
  if [ -d "$LOG_DIR" ]; then
    printf '%s command=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$1" >> "$LOG_FILE" 2>/dev/null || true
  fi
}

status_json() {
  ensure_dirs
  safe=$(safe_mode_value)
  daemon=$(daemon_running_value)
  profile=$(current_profile)
  printf '{"protocol_version":%s,"module_id":"%s","module_version":"%s","module_version_code":%s,"git_commit":"%s","safe_mode":%s,"profile":"%s","daemon_running":%s,"service_status":"%s"}\n' \
    "$PROTOCOL_VERSION" \
    "$MODULE_ID" \
    "$(json_escape "$(module_version)")" \
    "$(module_version_code)" \
    "$(json_escape "$(git_commit)")" \
    "$(json_bool "$safe")" \
    "$profile" \
    "$(json_bool "$daemon")" \
    "$(service_status)"
}

capabilities_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"capabilities":[' "$PROTOCOL_VERSION"
  printf '{"id":"profile.safe","title":"Recovery / Safe Mode","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.phone","title":"Phone / App Mode","status":"available_no_launch","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.dock","title":"Dock Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"profile.compatibility","title":"Compatibility Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"safe-mode","title":"Safe mode","status":"available","mutating":true,"source":"nebula-core"},'
  printf '{"id":"logs.tail","title":"Command logs","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"redmagic.probe","title":"RM11 Pro read-only RedMagic probe","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$REDMAGIC_SOURCE_FAN")"
  printf '{"id":"redmagic.pump.probe","title":"RM11 Pro read-only liquid-cooling pump probe","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$REDMAGIC_SOURCE_PUMP")"
  printf '{"id":"cooling.policy","title":"Read-only automatic cooling policy preview","status":"available_read_only","mutating":false,"source":"nebula-core defaults.json"},'
  printf '{"id":"snapshot.cooling","title":"Cooling snapshot and rollback dry-run","status":"available_state_only","mutating":false,"source":"nebula-core state"},'
  printf '{"id":"legacy.modules","title":"Protected legacy Droidspaces module status","status":"available_read_only","mutating":false,"source":"protected module audit"},'
  printf '{"id":"nubia.toolkit.status","title":"Nubia Toolkit compatibility status","status":"ported_status_only","mutating":false,"source":"%s"},' "$(json_escape "$NUBIA_TOOLKIT_SOURCE")"
  printf '{"id":"runtime.waylandie.status","title":"WayLandIE runtime readiness","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$WAYLANDIE_SOURCE")"
  printf '{"id":"runtime.waylandie.proton-smoke","title":"WayLandIE Proton root-assisted smoke","status":"available_safe_mode_guarded","mutating":true,"source":"%s"},' "$(json_escape "$WAYLANDIE_SOURCE")"
  printf '{"id":"display.lanes","title":"Display lane selector status","status":"available_read_only","mutating":false,"source":"nebula-core lane registry"},'
  printf '{"id":"display.lane.phone.preflight","title":"Phone/App WayLandIE lane preflight","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$DISPLAY_PHONE_SOURCE")"
  printf '{"id":"display.lane.anland.preflight","title":"Anland surface lane preflight","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$ANLAND_REPAIR_SOURCE")"
  printf '{"id":"display.lane.dock.preflight","title":"Dock lease lane preflight","status":"proven_reference_read_only","mutating":false,"source":"%s"},' "$(json_escape "$DRM_LEASE_SOURCE")"
  printf '{"id":"adb.wifi","title":"ADB Wi-Fi guardrail","status":"available_opt_in","mutating":true,"source":"Android Settings.Global adb_wifi_enabled,enable_wireless_switch"}'
  printf ']}\n'
}

profile_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"profile":"%s","safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(current_profile)" "$(json_bool "$(safe_mode_value)")"
}

blocked_profile_json() {
  profile=$1
  printf '{"protocol_version":%s,"ok":false,"profile":"%s","error":"BLOCKED_NOT_READY"}\n' \
    "$PROTOCOL_VERSION" "$profile"
}

profile_set() {
  ensure_dirs
  profile=$1
  case "$profile" in
    safe)
      touch "$SAFE_MODE_FILE"
      printf '%s\n' safe > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"safe","safe_mode":true}\n' "$PROTOCOL_VERSION"
      ;;
    phone)
      rm -f "$SAFE_MODE_FILE"
      printf '%s\n' phone > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"phone","safe_mode":false,"launch_started":false}\n' "$PROTOCOL_VERSION"
      ;;
    dock|compatibility)
      blocked_profile_json "$profile"
      return 75
      ;;
    *)
      printf '{"protocol_version":%s,"ok":false,"error":"UNKNOWN_PROFILE"}\n' "$PROTOCOL_VERSION"
      return 2
      ;;
  esac
}

safe_mode_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(json_bool "$(safe_mode_value)")"
}

safe_mode_enable() {
  ensure_dirs
  touch "$SAFE_MODE_FILE"
  printf '%s\n' safe > "$PROFILE_FILE"
  printf '{"protocol_version":%s,"ok":true,"safe_mode":true,"profile":"safe"}\n' "$PROTOCOL_VERSION"
}

adb_wifi_read_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_wifi_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global enable_wireless_switch 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_write_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_enabled"
    return $?
  fi
  settings put global adb_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled"
    return $?
  fi
  settings put global adb_wifi_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch"
    return $?
  fi
  settings put global enable_wireless_switch 1 >/dev/null 2>&1
}

adb_wifi_bool_json() {
  case "$1" in
    1) printf '%s' true ;;
    0) printf '%s' false ;;
    *) printf '%s' null ;;
  esac
}

adb_wifi_effective_value() {
  wifi_value=$1
  switch_value=$2
  port_value=${3:-}
  if adb_wifi_port_active "$port_value"; then
    printf '%s' 1
    return
  fi
  if [ "$wifi_value" = "1" ] || [ "$switch_value" = "1" ]; then
    printf '%s' 0
    return
  fi
  case "$wifi_value$switch_value" in
    *0*) printf '%s' 0 ;;
    *) printf '%s' unknown ;;
  esac
}

adb_wifi_port_active() {
  port_value=${1:-}
  [ -n "$port_value" ] && [ "$port_value" -gt 0 ] 2>/dev/null && [ "$port_value" -le 65535 ] 2>/dev/null
}

adb_wifi_port_valid_or_zero() {
  port_value=${1:-}
  case "$port_value" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$port_value" -ge 0 ] 2>/dev/null && [ "$port_value" -le 65535 ] 2>/dev/null
}

adb_wifi_requested_value() {
  adb_value=$1
  wifi_value=$2
  switch_value=$3
  if [ "$adb_value" = "1" ] && { [ "$wifi_value" = "1" ] || [ "$switch_value" = "1" ]; }; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

adb_wifi_activation_state() {
  effective_value=$1
  requested_value=$2
  if [ "$effective_value" = "1" ]; then
    printf '%s' live
  elif [ "$requested_value" = "1" ]; then
    printf '%s' manual_toggle_required
  elif [ "$effective_value" = "0" ]; then
    printf '%s' disabled
  else
    printf '%s' unknown
  fi
}

adb_wifi_current_bssid() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/current_bssid" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/current_bssid" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  cmd wifi status 2>/dev/null \
    | sed -n 's/.*BSSID: \([0-9A-Fa-f:][0-9A-Fa-f:]*\),.*/\1/p' \
    | head -n 1 \
    | tr -d '\r'
}

adb_wifi_valid_bssid() {
  case "$1" in
    [0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f])
      [ "$1" != "02:00:00:00:00:00" ]
      ;;
    *) return 1 ;;
  esac
}

adb_wifi_manager_allow() {
  bssid=$1
  if ! adb_wifi_valid_bssid "$bssid"; then
    return 2
  fi
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' "$bssid" > "$NEBULA_SETTINGS_DIR/manager_allow_bssid"
    return $?
  fi
  service call adb 4 i32 1 s16 "$bssid" >/dev/null 2>&1
}

adb_wifi_read_wireless_port() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/adb_wireless_port" ]; then
      value=$(head -n 1 "$NEBULA_SETTINGS_DIR/adb_wireless_port" | tr -d '\r')
      if adb_wifi_port_valid_or_zero "$value"; then
        printf '%s' "$value"
        return 0
      fi
      return 2
    fi
    return 2
  fi
  parcel=$(service call adb 10 2>/dev/null | tr -d '\r')
  value=$(printf '%s\n' "$parcel" | sed -n 's/.*00000000 \([0-9A-Fa-f][0-9A-Fa-f]*\).*/\1/p' | head -n 1)
  if [ -n "$value" ]; then
    port=$(printf '%d' "0x$value" 2>/dev/null || true)
    if adb_wifi_port_valid_or_zero "$port"; then
      printf '%s' "$port"
      return 0
    fi
  fi
  return 2
}

adb_wifi_auto_value() {
  if [ -f "$ADB_WIFI_AUTO_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

adb_wifi_state_snapshot() {
  ensure_dirs
  if [ ! -s "$ADB_WIFI_STATE_FILE" ]; then
    adb_value=$(adb_wifi_read_adb_enabled 2>/dev/null || printf unknown)
    wifi_value=$(adb_wifi_read_wireless_enabled 2>/dev/null || printf unknown)
    switch_value=$(adb_wifi_read_ui_switch 2>/dev/null || printf unknown)
    bssid_value=$(adb_wifi_current_bssid 2>/dev/null || printf unknown)
    {
      printf 'adb_enabled=%s\n' "$adb_value"
      printf 'adb_wifi_enabled=%s\n' "$wifi_value"
      printf 'enable_wireless_switch=%s\n' "$switch_value"
      printf 'current_bssid=%s\n' "$bssid_value"
    } > "$ADB_WIFI_STATE_FILE"
  fi
}

adb_wifi_status_payload() {
  errors=
  adb_value=$(adb_wifi_read_adb_enabled)
  adb_rc=$?
  if [ "$adb_rc" != "0" ]; then
    adb_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_enabled")
  fi
  wifi_value=$(adb_wifi_read_wireless_enabled)
  wifi_rc=$?
  if [ "$wifi_rc" != "0" ]; then
    wifi_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_wifi_enabled")
  fi
  switch_value=$(adb_wifi_read_ui_switch)
  switch_rc=$?
  if [ "$switch_rc" != "0" ]; then
    switch_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_enable_wireless_switch")
  fi
  port_value=$(adb_wifi_read_wireless_port)
  port_rc=$?
  if [ "$port_rc" != "0" ]; then
    port_value=
    errors=$(list_append_json_string "$errors" "unreadable:adb_manager_wireless_port")
  fi
  bssid_value=$(adb_wifi_current_bssid)
  bssid_rc=$?
  if [ "$bssid_rc" != "0" ] || ! adb_wifi_valid_bssid "$bssid_value"; then
    bssid_value=
    errors=$(list_append_json_string "$errors" "unreadable:current_wifi_bssid")
  fi
  effective_value=$(adb_wifi_effective_value "$wifi_value" "$switch_value" "$port_value")
  requested_value=$(adb_wifi_requested_value "$adb_value" "$wifi_value" "$switch_value")
  manual_required=0
  if [ "$requested_value" = "1" ] && [ "$effective_value" != "1" ]; then
    manual_required=1
    errors=$(list_append_json_string "$errors" "manual_toggle_required:wireless_port_inactive")
  fi

  printf '"adb_debugging":%s,' "$(adb_wifi_bool_json "$adb_value")"
  printf '"wireless_debugging":%s,' "$(adb_wifi_bool_json "$effective_value")"
  printf '"settings_wireless_debugging":%s,' "$(adb_wifi_bool_json "$wifi_value")"
  printf '"ui_wireless_switch":%s,' "$(adb_wifi_bool_json "$switch_value")"
  if [ -n "$port_value" ] && [ "$port_value" -ge 0 ] 2>/dev/null; then
    printf '"wireless_port":%s,' "$port_value"
  else
    printf '"wireless_port":null,'
  fi
  printf '"manager_bssid_available":%s,' "$(json_bool "$([ -n "$bssid_value" ] && printf 1 || printf 0)")"
  printf '"settings_requested":%s,' "$(json_bool "$requested_value")"
  printf '"manual_toggle_required":%s,' "$(json_bool "$manual_required")"
  printf '"activation_state":"%s",' "$(adb_wifi_activation_state "$effective_value" "$requested_value")"
  printf '"ui_switch_source":"Android Settings.Global enable_wireless_switch",'
  printf '"auto_enable":%s,' "$(json_bool "$(adb_wifi_auto_value)")"
  printf '"source":"Android Settings.Global adb_enabled,adb_wifi_enabled,enable_wireless_switch; android.debug.IAdbManager allowWirelessDebugging/getAdbWirelessPort",'
  printf '"errors":[%s]' "$errors"
}

adb_wifi_status_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"command":"adb-wifi status",' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

adb_wifi_enable_json() {
  ensure_dirs
  adb_wifi_state_snapshot
  errors=
  settings_ok=1
  manager_ok=1
  if ! adb_wifi_write_adb_enabled; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_enabled")
  fi
  if ! adb_wifi_write_wireless_enabled; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_wifi_enabled")
  fi
  if ! adb_wifi_write_ui_switch; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_enable_wireless_switch")
  fi
  bssid_value=$(adb_wifi_current_bssid 2>/dev/null || true)
  if adb_wifi_valid_bssid "$bssid_value"; then
    if ! adb_wifi_manager_allow "$bssid_value"; then
      manager_ok=0
      errors=$(list_append_json_string "$errors" "write_failed:adb_manager_allow_wireless_debugging")
    fi
  else
    manager_ok=0
    errors=$(list_append_json_string "$errors" "unavailable:current_wifi_bssid")
  fi
  requested=0
  if [ "$settings_ok" = "1" ]; then
    requested=1
    touch "$ADB_WIFI_AUTO_FILE" 2>/dev/null || {
      requested=0
      errors=$(list_append_json_string "$errors" "write_failed:adb_wifi_auto_enable")
    }
  fi
  port_value=$(adb_wifi_read_wireless_port 2>/dev/null || true)
  live=0
  if adb_wifi_port_active "$port_value"; then
    live=1
  elif [ "$settings_ok" = "1" ]; then
    errors=$(list_append_json_string "$errors" "manual_toggle_required:wireless_port_inactive")
  fi
  printf '{"protocol_version":%s,"command":"adb-wifi enable","ok":%s,"applied":%s,"requested":%s,"manager_request_ok":%s,' \
    "$PROTOCOL_VERSION" "$(json_bool "$live")" "$(json_bool "$live")" "$(json_bool "$requested")" "$(json_bool "$manager_ok")"
  adb_wifi_status_payload
  printf '}\n'
  [ "$live" = "1" ]
}

adb_wifi_auto_disable_json() {
  ensure_dirs
  rm -f "$ADB_WIFI_AUTO_FILE"
  printf '{"protocol_version":%s,"command":"adb-wifi auto-disable","ok":true,"current_session_changed":false,' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

logs_tail_json() {
  ensure_dirs
  lines=$1
  case "$lines" in
    ''|*[!0-9]*) lines=50 ;;
  esac
  if [ "$lines" -lt 1 ]; then lines=1; fi
  if [ "$lines" -gt 500 ]; then lines=500; fi
  printf '{"protocol_version":%s,"lines":[' "$PROTOCOL_VERSION"
  if [ -f "$LOG_FILE" ]; then
    out=$(tail -n "$lines" "$LOG_FILE" 2>/dev/null || true)
    if [ -n "$out" ]; then
      first=1
      printf '%s\n' "$out" | while IFS= read -r line; do
        if [ "$first" = "1" ]; then
          first=0
        else
          printf ','
        fi
        printf '"%s"' "$(json_escape "$line")"
      done
    fi
  fi
  printf ']}\n'
}

list_append_json_string() {
  current=$1
  item=$2
  if [ -n "$current" ]; then
    printf '%s,"%s"' "$current" "$(json_escape "$item")"
  else
    printf '"%s"' "$(json_escape "$item")"
  fi
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

package_visible() {
  pkg=$1
  if [ -n "${NEBULA_TEST_PACKAGE_DIR:-}" ]; then
    [ -e "$NEBULA_TEST_PACKAGE_DIR/$pkg" ]
    return
  fi
  cmd package path "$pkg" >/dev/null 2>&1
}

nubia_package_json() {
  key=$1
  pkg=$2
  role=$3
  visible=0
  if package_visible "$pkg"; then visible=1; fi
  printf '"%s":{"package":%s,"visible":%s,"role":%s}' \
    "$key" \
    "$(json_string "$pkg")" \
    "$(json_bool "$visible")" \
    "$(json_string "$role")"
}

nubia_toolkit_status_json() {
  vector_dir="$MODULES_ROOT/zygisk_vector"
  vector_installed=0
  vector_enabled=0
  vector_version=unknown
  vector_version_code=0
  if [ -d "$vector_dir" ]; then
    vector_installed=1
    [ ! -f "$vector_dir/disable" ] && vector_enabled=1
    vector_version=$(module_prop_from_dir "$vector_dir" version)
    vector_version_code=$(module_prop_from_dir "$vector_dir" versionCode)
  fi
  if [ "$vector_installed" != "1" ] && [ -x /data/adb/ksu/bin/ksud ]; then
    vector_entry=$(/data/adb/ksu/bin/ksud module list 2>/dev/null \
      | tr '\n' ' ' \
      | sed 's/[{]/\
{/g' \
      | grep '"id": "zygisk_vector"' \
      | head -n 1)
    if [ -n "$vector_entry" ]; then
      vector_installed=1
      vector_enabled_value=$(printf '%s' "$vector_entry" | sed -n 's/.*"enabled": "\([^"]*\)".*/\1/p')
      [ "$vector_enabled_value" = "true" ] && vector_enabled=1
      vector_version=$(printf '%s' "$vector_entry" | sed -n 's/.*"version": "\([^"]*\)".*/\1/p')
      vector_version_code=$(printf '%s' "$vector_entry" | sed -n 's/.*"versionCode": "\([^"]*\)".*/\1/p')
    fi
  fi
  [ -n "$vector_version" ] || vector_version=unknown
  case "$vector_version_code" in
    ''|*[!0-9]*) vector_version_code=0 ;;
  esac

  printf '{"protocol_version":%s,"command":"nubia toolkit status",' "$PROTOCOL_VERSION"
  printf '"source_project":"NubiaToolkit","source_commit":%s,"license":"Apache-2.0",' \
    "$(json_string "$NUBIA_TOOLKIT_SOURCE_COMMIT")"
  printf '"integration":"ported_status_only","old_toolkit_required":false,'
  printf '"lsposed_required_for_hooks":true,"lsposed_hooks_active":false,'
  printf '"hook_framework":{"id":"zygisk_vector","name":"Vector","installed":%s,"enabled":%s,"version":%s,"version_code":%s,"android_16_compatible":true},' \
    "$(json_bool "$vector_installed")" \
    "$(json_bool "$vector_enabled")" \
    "$(json_string "$vector_version")" \
    "$vector_version_code"
  printf '"packages":{'
  nubia_package_json game_assist "$NUBIA_GAME_ASSIST_PACKAGE" "Game Assist hook target"
  printf ','
  nubia_package_json game_launcher "$NUBIA_GAME_LAUNCHER_PACKAGE" "Game Launcher hook target"
  printf ','
  nubia_package_json toolkit_reference "$NUBIA_TOOLKIT_PACKAGE" "Old standalone LSPosed reference APK"
  printf '},'
  printf '"features":['
  printf '{"id":"no_kill","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"global_game_mode","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"hide_energy_cube","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"small_window_bypass","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"super_resolution_unlock","owner":"future_hook_or_reimplementation","state":"reference_only","mutating":true},'
  printf '{"id":"watermark_length","owner":"future_hook_lane","state":"deferred","mutating":true}'
  printf '],"errors":[]}\n'
}

waylandie_data_dir() {
  if [ -n "${NEBULA_WAYLANDIE_DATA_DIR:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_DATA_DIR"
  else
    printf '/data/user/0/%s' "$WAYLANDIE_PACKAGE"
  fi
}

waylandie_native_lib_dir() {
  if [ -n "${NEBULA_WAYLANDIE_NATIVE_LIB_DIR:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_NATIVE_LIB_DIR"
    return
  fi
  apk=$(cmd package path "$WAYLANDIE_PACKAGE" 2>/dev/null | sed -n 's/^package://p' | head -n 1)
  if [ -n "$apk" ]; then
    printf '%s/lib/arm64' "${apk%/base.apk}"
  fi
}

waylandie_uid() {
  if [ -n "${NEBULA_WAYLANDIE_UID:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_UID"
    return
  fi
  data_dir=$(waylandie_data_dir)
  if [ -d "$data_dir" ]; then
    uid=$(ls -ldn "$data_dir" 2>/dev/null | awk '{print $3}' | head -n 1)
    case "$uid" in
      ''|*[!0-9]*) ;;
      *) printf '%s' "$uid"; return ;;
    esac
  fi
  cmd package list packages -U "$WAYLANDIE_PACKAGE" 2>/dev/null \
    | sed -n 's/.*uid:\([0-9][0-9]*\).*/\1/p' \
    | head -n 1
}

waylandie_find_wine_host() {
  proton=$1
  for rel in \
    files/lib/wine/aarch64-unix/wine \
    files/bin-arm64/wine \
    files/bin-arm64/wine64 \
    files/bin/wine \
    files/bin/wine64 \
    dist/bin/wine \
    dist/bin/wine64 \
    bin/wine \
    bin/wine64
  do
    if [ -f "$proton/$rel" ]; then
      printf '%s' "$proton/$rel"
      return
    fi
  done
}

waylandie_guest_wine_path() {
  wine_host=$1
  proton=$2
  rel=${wine_host#"$proton"/}
  if [ "$rel" != "$wine_host" ]; then
    printf '/opt/proton/%s' "$rel"
  else
    printf '/opt/proton/files/lib/wine/aarch64-unix/wine'
  fi
}

waylandie_collect() {
  wl_data=$(waylandie_data_dir)
  wl_native=$(waylandie_native_lib_dir)
  wl_uid=$(waylandie_uid)
  wl_rootfs="$wl_data/files/imagefs"
  wl_proton="$wl_data/files/contents/proton/active"
  wl_proot="$wl_native/libproot.so"
  wl_loader="$wl_native/libld_glibc.so"
  wl_wine_host=$(waylandie_find_wine_host "$wl_proton")
  wl_wine_guest=$(waylandie_guest_wine_path "$wl_wine_host" "$wl_proton")
  wl_errors=
  wl_installed=0
  wl_data_present=0
  wl_imagefs_present=0
  wl_native_present=0
  wl_proot_present=0
  wl_loader_present=0
  wl_proton_present=0
  wl_wine_present=0
  wl_uid_present=0
  wl_ready=1

  if package_visible "$WAYLANDIE_PACKAGE"; then wl_installed=1; fi
  if [ -d "$wl_data" ]; then wl_data_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:app_data"); fi
  if [ -d "$wl_rootfs" ]; then wl_imagefs_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:imagefs"); fi
  if [ -n "$wl_native" ] && [ -d "$wl_native" ]; then wl_native_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:native_lib_dir"); fi
  if [ -f "$wl_proot" ]; then wl_proot_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:libproot.so"); fi
  if [ -f "$wl_loader" ]; then wl_loader_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:libld_glibc.so"); fi
  if [ -d "$wl_proton" ]; then wl_proton_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:proton_active"); fi
  if [ -n "$wl_wine_host" ]; then wl_wine_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:proton_wine"); fi
  case "$wl_uid" in
    ''|*[!0-9]*) wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:app_uid") ;;
    *) wl_uid_present=1 ;;
  esac
}

waylandie_runtime_status_payload() {
  waylandie_collect
  printf '"package":%s,' "$(json_string "$WAYLANDIE_PACKAGE")"
  printf '"source":%s,' "$(json_string "$WAYLANDIE_SOURCE")"
  printf '"method":"root_assisted_proot","safe_mode":%s,' "$(json_bool "$(safe_mode_value)")"
  printf '"installed":%s,"app_uid_known":%s,"data_dir_present":%s,"imagefs_present":%s,' \
    "$(json_bool "$wl_installed")" \
    "$(json_bool "$wl_uid_present")" \
    "$(json_bool "$wl_data_present")" \
    "$(json_bool "$wl_imagefs_present")"
  printf '"native_lib_dir_present":%s,"proot_present":%s,"glibc_loader_present":%s,' \
    "$(json_bool "$wl_native_present")" \
    "$(json_bool "$wl_proot_present")" \
    "$(json_bool "$wl_loader_present")"
  printf '"proton_present":%s,"wine_present":%s,"ready":%s,"errors":[%s]' \
    "$(json_bool "$wl_proton_present")" \
    "$(json_bool "$wl_wine_present")" \
    "$(json_bool "$wl_ready")" \
    "$wl_errors"
}

waylandie_runtime_status_json() {
  printf '{"protocol_version":%s,"command":"runtime waylandie status",' "$PROTOCOL_VERSION"
  waylandie_runtime_status_payload
  printf '}\n'
}

waylandie_test_smoke_json() {
  mode=${NEBULA_TEST_WAYLANDIE_SMOKE_RESULT:-}
  case "$mode" in
    pass)
      printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":true,"safe_mode":false,"method":"root_assisted_proot","exit_code":0,"stdout":"Nebula Proton smoke fixture","stderr":"","source":%s,"errors":[]}\n' \
        "$PROTOCOL_VERSION" "$(json_string "$WAYLANDIE_SOURCE")"
      return 0
      ;;
    fail)
      printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"method":"root_assisted_proot","exit_code":1,"stdout":"","stderr":"fixture failure","source":%s,"errors":["fixture_failure"]}\n' \
        "$PROTOCOL_VERSION" "$(json_string "$WAYLANDIE_SOURCE")"
      return 1
      ;;
  esac
  return 99
}

waylandie_runtime_smoke_json() {
  ensure_dirs
  if [ "$(safe_mode_value)" = "1" ]; then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":true,"error":"SAFE_MODE_ACTIVE","errors":["SAFE_MODE_ACTIVE"]}\n' "$PROTOCOL_VERSION"
    return 75
  fi

  if [ -n "${NEBULA_TEST_WAYLANDIE_SMOKE_RESULT:-}" ]; then
    waylandie_test_smoke_json
    return $?
  fi

  waylandie_collect
  if [ "$wl_ready" != "1" ]; then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"error":"RUNTIME_NOT_READY","status":{' "$PROTOCOL_VERSION"
    waylandie_runtime_status_payload
    printf '}}\n'
    return 2
  fi

  script_path="$wl_data/files/nebula-core-proton-smoke-$$.sh"
  out_path="$wl_data/files/nebula-core-proton-smoke-$$.out"
  err_path="$wl_data/files/nebula-core-proton-smoke-$$.err"
  q_script=$(shell_quote "$script_path")
  q_out=$(shell_quote "$out_path")
  q_err=$(shell_quote "$err_path")
  q_rootfs=$(shell_quote "$wl_rootfs")
  q_native=$(shell_quote "$wl_native")
  q_data=$(shell_quote "$wl_data")
  q_proton=$(shell_quote "$wl_proton")
  q_wine_guest=$(shell_quote "$wl_wine_guest")

  if ! su "$wl_uid" -c "cat > $q_script" <<EOF
#!/system/bin/sh
set -u
ROOTFS=$q_rootfs
NATIVE=$q_native
DATA=$q_data
PROTON=$q_proton
WINE_GUEST=$q_wine_guest
PROOT="\$NATIVE/libproot.so"
mkdir -p "\$ROOTFS/home/xuser" "\$ROOTFS/tmp" "\$ROOTFS/android-lib" "\$ROOTFS/opt/proton" "\$DATA/cache/proot-tmp" "\$DATA/cache/proot-l2s"
export HOME=/home/xuser
export USER=xuser
export LOGNAME=xuser
export LANG=en_US.UTF-8
export TERM=xterm-256color
export TMPDIR=/tmp
export XDG_RUNTIME_DIR=/tmp
export WINEPREFIX=/home/xuser/.wine
export WINEDEBUG=-all
export WINE_NO_DUPLICATE_EXPLORER=1
export WINE_GST_NO_GL=1
export WINE_DISABLE_FULLSCREEN_HACK=1
export PROOT_TMP_DIR="\$DATA/cache/proot-tmp"
export PROOT_L2S_DIR="\$DATA/cache/proot-l2s"
export WAYLANDIE_CONTENTS_DIR=/waylandie-contents
export PATH=/waylandie-scripts:/opt/proton/files/bin-arm64:/opt/proton/files/bin:/opt/proton/bin:/usr/local/bin:/usr/bin:/bin
export LD_LIBRARY_PATH=/opt/proton/files/lib/wine/aarch64-unix:/opt/proton/files/lib/wine/aarch64-windows:/opt/proton/files/lib:/opt/proton/lib:/usr/lib:/usr/local/lib:/system/lib64
exec "\$PROOT" -r "\$ROOTFS" -w /home/xuser -b /dev:/dev -b /dev/urandom:/dev/random -b /proc:/proc -b /sys:/sys -b /sdcard:/sdcard -b /storage:/storage:ro -b "\$ROOTFS/home/xuser:/home/xuser" -b "\$ROOTFS/tmp:/tmp" -b "\$DATA/files/contents:/waylandie-contents" -b "\$NATIVE:/android-lib" -b "\$PROTON:/opt/proton" /android-lib/libld_glibc.so --library-path /usr/lib/aarch64-linux-gnu:/lib/aarch64-linux-gnu:/usr/lib:/lib:/usr/local/lib "\$WINE_GUEST" cmd /c ver
EOF
  then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"error":"SCRIPT_WRITE_FAILED","errors":["SCRIPT_WRITE_FAILED"]}\n' "$PROTOCOL_VERSION"
    return 1
  fi

  su "$wl_uid" -c "chmod 700 $q_script" >/dev/null 2>&1 || true
  if command -v timeout >/dev/null 2>&1; then
    su "$wl_uid" -c "timeout 25 sh $q_script > $q_out 2> $q_err"
    rc=$?
  else
    su "$wl_uid" -c "sh $q_script > $q_out 2> $q_err"
    rc=$?
  fi
  stdout=$(head -c 4096 "$out_path" 2>/dev/null || true)
  stderr=$(head -c 4096 "$err_path" 2>/dev/null || true)
  su "$wl_uid" -c "rm -f $q_script $q_out $q_err" >/dev/null 2>&1 || rm -f "$script_path" "$out_path" "$err_path"

  errors=
  if [ "$rc" -ne 0 ]; then
    errors=$(list_append_json_string "$errors" "exit_code:$rc")
  fi
  printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":%s,"safe_mode":false,"method":"root_assisted_proot","exit_code":%s,"stdout":%s,"stderr":%s,"source":%s,"errors":[%s]}\n' \
    "$PROTOCOL_VERSION" \
    "$(json_bool "$([ "$rc" -eq 0 ] && printf 1 || printf 0)")" \
    "$rc" \
    "$(json_output_string "$stdout")" \
    "$(json_output_string "$stderr")" \
    "$(json_string "$WAYLANDIE_SOURCE")" \
    "$errors"
  [ "$rc" -eq 0 ]
}

fixed_device_path() {
  path=$1
  root=${NEBULA_TEST_DEVICE_ROOT:-}
  if [ -n "$root" ]; then
    printf '%s%s' "$root" "$path"
  else
    printf '%s' "$path"
  fi
}

fixed_path_exists() {
  path=$(fixed_device_path "$1")
  [ -e "$path" ]
}

fixed_path_executable() {
  path=$(fixed_device_path "$1")
  [ -x "$path" ]
}

fixed_path_socket() {
  path=$(fixed_device_path "$1")
  [ -S "$path" ]
}

fixed_file_contains() {
  path=$(fixed_device_path "$1")
  pattern=$2
  [ -f "$path" ] && grep -F "$pattern" "$path" >/dev/null 2>&1
}

display_bool_source() {
  bool_value=$1
  true_label=$2
  false_label=$3
  if [ "$bool_value" = "1" ]; then
    printf '%s' "$true_label"
  else
    printf '%s' "$false_label"
  fi
}

