  printf '}\n'
}

display_anland_preflight_payload() {
  anland_errors=
  anland_bin=0
  anland_config=0
  anland_env=0
  anland_socket=0
  anland_render=0
  anland_config_env=0
  anland_config_bind=0
  anland_env_socket=0
  anland_env_kgsl=0

  fixed_path_executable "$ANLAND_DROIDSPACES_BIN" && anland_bin=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:droidspaces_binary")
  fixed_path_exists "$ANLAND_CONFIG" && anland_config=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:container_config")
  fixed_path_exists "$ANLAND_ENV" && anland_env=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:anland_env")
  fixed_path_socket "$ANLAND_SOCKET_HOST" && anland_socket=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:display_daemon_socket")
  fixed_path_exists "$ANLAND_RENDER_NODE" && anland_render=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:render_node")
  fixed_file_contains "$ANLAND_CONFIG" "env_file=$ANLAND_ENV" && anland_config_env=1 || true
  fixed_file_contains "$ANLAND_CONFIG" "$ANLAND_SOCKET_HOST:$ANLAND_SOCKET_GUEST" && anland_config_bind=1 || true
  fixed_file_contains "$ANLAND_ENV" "ANLAND_SOCKET=$ANLAND_SOCKET_GUEST" && anland_env_socket=1 || true
  fixed_file_contains "$ANLAND_ENV" "MESA_LOADER_DRIVER_OVERRIDE=kgsl" && anland_env_kgsl=1 || true

  anland_ready=0
  anland_status=missing
  if [ "$anland_bin" = "1" ] && [ "$anland_config" = "1" ] && [ "$anland_socket" = "1" ] && [ "$anland_render" = "1" ]; then
    anland_status=preflight_ready
    anland_ready=1
  elif [ "$anland_bin" = "1" ] || [ "$anland_config" = "1" ] || [ "$anland_env" = "1" ]; then
    anland_status=partial
  fi

  printf '"id":"anland_surface",'
  printf '"title":"Anland Surface Mode",'
  printf '"status":%s,' "$(json_string "$anland_status")"
  printf '"available":%s,' "$(json_bool "$anland_ready")"
  printf '"mutating":false,'
  printf '"repair_command_available":false,'
  printf '"source":%s,' "$(json_string "$ANLAND_REPAIR_SOURCE")"
  printf '"checks":{"droidspaces_binary":%s,"container_config":%s,"anland_env":%s,"display_daemon_socket":%s,"render_node":%s,"config_env_file":%s,"config_socket_bind":%s,"env_socket":%s,"env_kgsl":%s},' \
    "$(json_bool "$anland_bin")" \
    "$(json_bool "$anland_config")" \
    "$(json_bool "$anland_env")" \
    "$(json_bool "$anland_socket")" \
    "$(json_bool "$anland_render")" \
    "$(json_bool "$anland_config_env")" \
    "$(json_bool "$anland_config_bind")" \
    "$(json_bool "$anland_env_socket")" \
    "$(json_bool "$anland_env_kgsl")"
  printf '"fixed_paths":{"droidspaces_binary":%s,"container_config":%s,"anland_env":%s,"display_socket_host":%s,"display_socket_guest":%s,"render_node":%s},' \
    "$(json_string "$ANLAND_DROIDSPACES_BIN")" \
    "$(json_string "$ANLAND_CONFIG")" \
    "$(json_string "$ANLAND_ENV")" \
    "$(json_string "$ANLAND_SOCKET_HOST")" \
    "$(json_string "$ANLAND_SOCKET_GUEST")" \
    "$(json_string "$ANLAND_RENDER_NODE")"
  printf '"errors":[%s]' "$anland_errors"
}

display_anland_preflight_json() {
  printf '{"protocol_version":%s,"command":"display lane anland preflight",' "$PROTOCOL_VERSION"
  display_anland_preflight_payload
  printf '}\n'
}

