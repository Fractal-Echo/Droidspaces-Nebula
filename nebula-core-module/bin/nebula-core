#!/system/bin/sh
set -u

PROTOCOL_VERSION=1
MODULE_ID=nebula_core
DATA_DIR=${NEBULA_DATA_DIR:-/data/adb/nebula}
LOG_DIR="$DATA_DIR/logs"
STATE_DIR="$DATA_DIR/state"
LOG_FILE="$LOG_DIR/nebula-core.log"
PROFILE_FILE="$STATE_DIR/profile"
SNAPSHOT_DIR="$STATE_DIR/snapshots"
COOLING_SNAPSHOT_FILE="$SNAPSHOT_DIR/cooling.json"
ADB_WIFI_AUTO_FILE="$STATE_DIR/adb_wifi_auto_enable"
ADB_WIFI_STATE_FILE="$STATE_DIR/adb_wifi.state"
SAFE_MODE_FILE="$DATA_DIR/safe_mode"
SCRIPT_DIR=${0%/*}
MODDIR=${NEBULA_MODULE_DIR:-${SCRIPT_DIR%/*}}
MODULE_PROP=${NEBULA_MODULE_PROP:-$MODDIR/module.prop}
DEFAULTS_JSON=${NEBULA_DEFAULTS_JSON:-$MODDIR/config/defaults.json}
MODULES_ROOT=${NEBULA_MODULES_ROOT:-/data/adb/modules}
REDMAGIC_SOURCE_COMMIT=e94d36e8204c228c6e8781157dea22946cf715e3
REDMAGIC_SOURCE_FAN="Redmagic-Control-Center HardwareController.kt:25-28,48-77@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_PUMP="Redmagic-Control-Center HardwareController.kt:30-32,80-98; DashboardSnapshot.kt:16-18; DeviceCapabilityScanner.kt:43-45@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_THERMAL="Redmagic-Control-Center HardwareController.kt:275-288@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_IDENTITY="Redmagic-Control-Center DeviceCapabilityScanner.kt:33-36@$REDMAGIC_SOURCE_COMMIT"
LEGACY_DROIDSPACES_SOURCE="Droidspaces: Daemon & Init /data/adb/modules/droidspaces service.sh,post-fs-data.sh,sepolicy.rule captured 2026-06-22"
LEGACY_BRIDGE_SOURCE="RM11 Droidspaces Bridge FD Policy /data/adb/modules/rm11-droidspace-bridge-fd service.sh,sepolicy.rule captured 2026-06-22"

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$STATE_DIR"
  if [ ! -s "$PROFILE_FILE" ]; then
    printf '%s\n' safe > "$PROFILE_FILE"
  fi
}

prop_value() {
  key=$1
  if [ -f "$MODULE_PROP" ]; then
    sed -n "s/^$key=//p" "$MODULE_PROP" | head -n 1
  fi
}

module_version() {
  value=$(prop_value version)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

module_version_code() {
  value=$(prop_value versionCode)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' 0
  fi
}

git_commit() {
  value=${NEBULA_GIT_COMMIT:-}
  if [ -z "$value" ] && [ -f "$MODDIR/config/git-commit.txt" ]; then
    value=$(sed -n '1p' "$MODDIR/config/git-commit.txt")
  fi
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

json_string_or_null() {
  if [ -n "$1" ]; then
    json_string "$1"
  else
    printf '%s' null
  fi
}

json_int_or_null() {
  case "$1" in
    ''|*[!0-9-]*) printf '%s' null ;;
    *) printf '%s' "$1" ;;
  esac
}

is_unsigned_integer() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

json_number_from_milli() {
  milli=$1
  case "$milli" in
    ''|*[!0-9-]*) printf '%s' null; return ;;
  esac
  sign=
  case "$milli" in
    -*) sign=-; milli=${milli#-} ;;
  esac
  whole=$((milli / 1000))
  frac=$((milli % 1000))
  printf '%s%s.%03d' "$sign" "$whole" "$frac"
}

config_bool() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*true.*/true/p" \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*false.*/false/p" \
      "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\([-0-9.][0-9.]*\\).*/\\1/p" "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number_default() {
  key=$1
  fallback=$2
  value=$(config_number "$key")
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

json_bool() {
  if [ "$1" = "1" ]; then
    printf '%s' true
  else
    printf '%s' false
  fi
}

safe_mode_value() {
  if [ -f "$SAFE_MODE_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

current_profile() {
  if [ -s "$PROFILE_FILE" ]; then
    value=$(head -n 1 "$PROFILE_FILE")
  else
    value=safe
  fi
  case "$value" in
    safe|phone|dock|compatibility) printf '%s' "$value" ;;
    *) printf '%s' safe ;;
  esac
}

daemon_running_value() {
  pid_file="$STATE_DIR/service.pid"
  if [ -s "$pid_file" ]; then
    pid=$(head -n 1 "$pid_file")
    case "$pid" in
      *[!0-9]*|'') printf '%s' 0 ;;
      *)
        if kill -0 "$pid" 2>/dev/null; then
          printf '%s' 1
        else
          printf '%s' 0
        fi
        ;;
    esac
  else
    printf '%s' 0
  fi
}

service_status() {
  if [ "$(daemon_running_value)" = "1" ]; then
    printf '%s' running
  elif [ -d "$STATE_DIR" ]; then
    printf '%s' state_ready
  else
    printf '%s' missing_state
  fi
}

log_command() {
  ensure_dirs
  printf '%s command=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$1" >> "$LOG_FILE"
}

status_json() {
  ensure_dirs
  safe=$(safe_mode_value)
  daemon=$(daemon_running_value)
  profile=$(current_profile)
  printf '{"protocol_version":%s,"module_id":"%s","module_version":"%s","module_version_code":%s,"git_commit":"%s","safe_mode":%s,"profile":"%s","daemon_running":%s,"service_status":"%s"}\n' \
    "$PROTOCOL_VERSION" \
    "$MODULE_ID" \
    "$(json_escape "$(module_version)")" \
    "$(module_version_code)" \
    "$(json_escape "$(git_commit)")" \
    "$(json_bool "$safe")" \
    "$profile" \
    "$(json_bool "$daemon")" \
    "$(service_status)"
}

capabilities_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"capabilities":[' "$PROTOCOL_VERSION"
  printf '{"id":"profile.safe","title":"Recovery / Safe Mode","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.phone","title":"Phone / App Mode","status":"available_no_launch","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.dock","title":"Dock Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"profile.compatibility","title":"Compatibility Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"safe-mode","title":"Safe mode","status":"available","mutating":true,"source":"nebula-core"},'
  printf '{"id":"logs.tail","title":"Command logs","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"redmagic.probe","title":"RM11 Pro read-only RedMagic probe","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$REDMAGIC_SOURCE_FAN")"
  printf '{"id":"redmagic.pump.probe","title":"RM11 Pro read-only liquid-cooling pump probe","status":"available_read_only","mutating":false,"source":"%s"},' "$(json_escape "$REDMAGIC_SOURCE_PUMP")"
  printf '{"id":"cooling.policy","title":"Read-only automatic cooling policy preview","status":"available_read_only","mutating":false,"source":"nebula-core defaults.json"},'
  printf '{"id":"snapshot.cooling","title":"Cooling snapshot and rollback dry-run","status":"available_state_only","mutating":false,"source":"nebula-core state"},'
  printf '{"id":"legacy.modules","title":"Protected legacy Droidspaces module status","status":"available_read_only","mutating":false,"source":"protected module audit"},'
  printf '{"id":"adb.wifi","title":"ADB Wi-Fi guardrail","status":"available_opt_in","mutating":true,"source":"Android Settings.Global adb_wifi_enabled,enable_wireless_switch"}'
  printf ']}\n'
}

profile_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"profile":"%s","safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(current_profile)" "$(json_bool "$(safe_mode_value)")"
}

blocked_profile_json() {
  profile=$1
  printf '{"protocol_version":%s,"ok":false,"profile":"%s","error":"BLOCKED_NOT_READY"}\n' \
    "$PROTOCOL_VERSION" "$profile"
}

profile_set() {
  ensure_dirs
  profile=$1
  case "$profile" in
    safe)
      touch "$SAFE_MODE_FILE"
      printf '%s\n' safe > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"safe","safe_mode":true}\n' "$PROTOCOL_VERSION"
      ;;
    phone)
      rm -f "$SAFE_MODE_FILE"
      printf '%s\n' phone > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"phone","safe_mode":false,"launch_started":false}\n' "$PROTOCOL_VERSION"
      ;;
    dock|compatibility)
      blocked_profile_json "$profile"
      return 75
      ;;
    *)
      printf '{"protocol_version":%s,"ok":false,"error":"UNKNOWN_PROFILE"}\n' "$PROTOCOL_VERSION"
      return 2
      ;;
  esac
}

safe_mode_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(json_bool "$(safe_mode_value)")"
}

safe_mode_enable() {
  ensure_dirs
  touch "$SAFE_MODE_FILE"
  printf '%s\n' safe > "$PROFILE_FILE"
  printf '{"protocol_version":%s,"ok":true,"safe_mode":true,"profile":"safe"}\n' "$PROTOCOL_VERSION"
}

adb_wifi_read_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_wifi_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global enable_wireless_switch 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_write_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_enabled"
    return $?
  fi
  settings put global adb_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled"
    return $?
  fi
  settings put global adb_wifi_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch"
    return $?
  fi
  settings put global enable_wireless_switch 1 >/dev/null 2>&1
}

adb_wifi_bool_json() {
  case "$1" in
    1) printf '%s' true ;;
    0) printf '%s' false ;;
    *) printf '%s' null ;;
  esac
}

adb_wifi_effective_value() {
  wifi_value=$1
  switch_value=$2
  case "$switch_value" in
    1|0) printf '%s' "$switch_value" ;;
    *) printf '%s' "$wifi_value" ;;
  esac
}

adb_wifi_auto_value() {
  if [ -f "$ADB_WIFI_AUTO_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

adb_wifi_state_snapshot() {
  ensure_dirs
  if [ ! -s "$ADB_WIFI_STATE_FILE" ]; then
    adb_value=$(adb_wifi_read_adb_enabled 2>/dev/null || printf unknown)
    wifi_value=$(adb_wifi_read_wireless_enabled 2>/dev/null || printf unknown)
    switch_value=$(adb_wifi_read_ui_switch 2>/dev/null || printf unknown)
    {
      printf 'adb_enabled=%s\n' "$adb_value"
      printf 'adb_wifi_enabled=%s\n' "$wifi_value"
      printf 'enable_wireless_switch=%s\n' "$switch_value"
    } > "$ADB_WIFI_STATE_FILE"
  fi
}

adb_wifi_status_payload() {
  errors=
  adb_value=$(adb_wifi_read_adb_enabled)
  adb_rc=$?
  if [ "$adb_rc" != "0" ]; then
    adb_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_enabled")
  fi
  wifi_value=$(adb_wifi_read_wireless_enabled)
  wifi_rc=$?
  if [ "$wifi_rc" != "0" ]; then
    wifi_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_wifi_enabled")
  fi
  switch_value=$(adb_wifi_read_ui_switch)
  switch_rc=$?
  if [ "$switch_rc" != "0" ]; then
    switch_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_enable_wireless_switch")
  fi
  effective_value=$(adb_wifi_effective_value "$wifi_value" "$switch_value")

  printf '"adb_debugging":%s,' "$(adb_wifi_bool_json "$adb_value")"
  printf '"wireless_debugging":%s,' "$(adb_wifi_bool_json "$effective_value")"
  printf '"settings_wireless_debugging":%s,' "$(adb_wifi_bool_json "$wifi_value")"
  printf '"ui_wireless_switch":%s,' "$(adb_wifi_bool_json "$switch_value")"
  printf '"ui_switch_source":"Android Settings.Global enable_wireless_switch",'
  printf '"auto_enable":%s,' "$(json_bool "$(adb_wifi_auto_value)")"
  printf '"source":"Android Settings.Global adb_enabled,adb_wifi_enabled,enable_wireless_switch",'
  printf '"errors":[%s]' "$errors"
}

adb_wifi_status_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"command":"adb-wifi status",' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

adb_wifi_enable_json() {
  ensure_dirs
  adb_wifi_state_snapshot
  errors=
  ok=1
  if ! adb_wifi_write_adb_enabled; then
    ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_enabled")
  fi
  if ! adb_wifi_write_wireless_enabled; then
    ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_wifi_enabled")
  fi
  if ! adb_wifi_write_ui_switch; then
    ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_enable_wireless_switch")
  fi
  if [ "$ok" = "1" ]; then
    touch "$ADB_WIFI_AUTO_FILE" 2>/dev/null || {
      ok=0
      errors=$(list_append_json_string "$errors" "write_failed:adb_wifi_auto_enable")
    }
  fi
  printf '{"protocol_version":%s,"command":"adb-wifi enable","ok":%s,"applied":%s,' \
    "$PROTOCOL_VERSION" "$(json_bool "$ok")" "$(json_bool "$ok")"
  adb_wifi_status_payload
  printf '}\n'
  [ "$ok" = "1" ]
}

adb_wifi_auto_disable_json() {
  ensure_dirs
  rm -f "$ADB_WIFI_AUTO_FILE"
  printf '{"protocol_version":%s,"command":"adb-wifi auto-disable","ok":true,"current_session_changed":false,' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

logs_tail_json() {
  ensure_dirs
  lines=$1
  case "$lines" in
    ''|*[!0-9]*) lines=50 ;;
  esac
  if [ "$lines" -lt 1 ]; then lines=1; fi
  if [ "$lines" -gt 500 ]; then lines=500; fi
  printf '{"protocol_version":%s,"lines":[' "$PROTOCOL_VERSION"
  if [ -f "$LOG_FILE" ]; then
    out=$(tail -n "$lines" "$LOG_FILE" 2>/dev/null || true)
    if [ -n "$out" ]; then
      first=1
      printf '%s\n' "$out" | while IFS= read -r line; do
        if [ "$first" = "1" ]; then
          first=0
        else
          printf ','
        fi
        printf '"%s"' "$(json_escape "$line")"
      done
    fi
  fi
  printf ']}\n'
}

list_append_json_string() {
  current=$1
  item=$2
  if [ -n "$current" ]; then
    printf '%s,"%s"' "$current" "$(json_escape "$item")"
  else
    printf '"%s"' "$(json_escape "$item")"
  fi
}

is_test_denied_path() {
  path=$1
  deny_list=${NEBULA_TEST_DENY_PATHS:-}
  old_ifs=$IFS
  IFS=:
  for denied in $deny_list; do
    if [ "$denied" = "$path" ]; then
      IFS=$old_ifs
      return 0
    fi
  done
  IFS=$old_ifs
  return 1
}

resolve_read_path() {
  path=$1
  root=${NEBULA_SYSROOT:-}
  if [ -n "$root" ]; then
    printf '%s%s' "$root" "$path"
  else
    printf '%s' "$path"
  fi
}

is_allowlisted_read_path() {
  case "$1" in
    /sys/kernel/fan/fan_enable|\
    /sys/kernel/fan/fan_speed_level|\
    /sys/kernel/fan/fan_speed_count|\
    /proc/driver/micropump/enable|\
    /proc/driver/micropump/freq|\
    /proc/driver/micropump/speed|\
    /sys/class/thermal/thermal_zone0/temp|\
    /sys/class/thermal/thermal_zone1/temp|\
    /sys/class/thermal/thermal_zone2/temp|\
    /sys/class/thermal/thermal_zone3/temp|\
    /sys/devices/virtual/thermal/thermal_zone0/temp|\
    /sys/devices/virtual/thermal/thermal_zone1/temp|\
    /sys/devices/virtual/thermal/thermal_zone2/temp|\
    /sys/devices/virtual/thermal/thermal_zone3/temp)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_allowlisted_file() {
  path=$1
  if ! is_allowlisted_read_path "$path"; then
    return 8
  fi
  actual=$(resolve_read_path "$path")
  if [ ! -e "$actual" ]; then
    return 2
  fi
  if is_test_denied_path "$path"; then
    return 3
  fi
  if [ ! -r "$actual" ]; then
    return 3
  fi
  head -n 1 "$actual" 2>/dev/null | cut -c 1-128
}

path_present() {
  path=$1
  actual=$(resolve_read_path "$path")
  [ -e "$actual" ]
}

read_prop() {
  name=$1
  case "$name" in
    ro.product.manufacturer|ro.product.model|ro.product.product.name|\
    ro.product.device|ro.board.platform|ro.product.marketname|ro.build.fingerprint)
      ;;
    *)
      return 8
      ;;
  esac
  prop_dir=${NEBULA_TEST_PROP_DIR:-}
  if [ -n "$prop_dir" ] && [ -f "$prop_dir/$name" ]; then
    head -n 1 "$prop_dir/$name" 2>/dev/null | cut -c 1-128
    return 0
  fi
  if command -v getprop >/dev/null 2>&1; then
    getprop "$name" 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

read_kernel_release() {
  if [ -n "${NEBULA_TEST_KERNEL:-}" ]; then
    printf '%s' "$NEBULA_TEST_KERNEL"
  else
    uname -r 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

value_or_unknown() {
  if [ -n "$1" ]; then
    printf '%s' "$1"
  else
    printf '%s' unknown
  fi
}

normalize_temp_c() {
  raw=$1
  case "$raw" in
    ''|*[!0-9.-]*) printf '%s' null; return ;;
  esac
  case "$raw" in
    *.*) printf '%s' "$raw"; return ;;
  esac
  if [ "$raw" -gt 1000 ] 2>/dev/null && [ "$raw" -lt 200000 ] 2>/dev/null; then
    whole=$((raw / 1000))
    frac=$((raw % 1000))
    printf '%s.%03d' "$whole" "$frac"
  elif [ "$raw" -gt -100 ] 2>/dev/null && [ "$raw" -lt 200 ] 2>/dev/null; then
    printf '%s' "$raw"
  else
    printf '%s' null
  fi
}

temp_to_milli_c() {
  raw=$1
  case "$raw" in
    ''|*[!0-9.]*|*.*.*) return 1 ;;
  esac
  case "$raw" in
    *.*)
      whole=${raw%%.*}
      frac=${raw#*.}
      case "$whole$frac" in
        ''|*[!0-9]*) return 1 ;;
      esac
      frac3=$(printf '%-3.3s' "$frac" | tr ' ' '0')
      printf '%s' $((whole * 1000 + frac3))
      ;;
    *)
      if [ "$raw" -gt 1000 ] 2>/dev/null; then
        printf '%s' "$raw"
      else
        printf '%s' $((raw * 1000))
      fi
      ;;
  esac
}

state_rank() {
  case "$1" in
    COOL) printf '%s' 1 ;;
    BALANCED) printf '%s' 2 ;;
    HOT) printf '%s' 3 ;;
    CRITICAL) printf '%s' 4 ;;
    *) printf '%s' 0 ;;
  esac
}

state_threshold_milli() {
  state=$1
  case "$state" in
    BALANCED) printf '%s' "$cp_balanced_milli" ;;
    HOT) printf '%s' "$cp_hot_milli" ;;
    CRITICAL) printf '%s' "$cp_critical_milli" ;;
    *) printf '%s' 0 ;;
  esac
}

intent_for_state() {
  supported=$1
  state=$2
  channel=$3
  if [ "$supported" != "1" ]; then
    printf '%s' unavailable
    return
  fi
  case "$state" in
    SAFE_MODE) printf '%s' stock ;;
    UNAVAILABLE) printf '%s' stock ;;
    COOL) printf '%s' off ;;
    BALANCED)
      if [ "$channel" = "fan" ]; then
        printf '%s' medium
      else
        printf '%s' low
      fi
      ;;
    HOT) printf '%s' high ;;
    CRITICAL) printf '%s' maximum ;;
    *) printf '%s' unavailable ;;
  esac
}

cooling_policy_fields() {
  cp_errors=
  cp_reason=
  cp_configured_text=$(config_bool configured)
  cp_configured=0
  if [ "$cp_configured_text" = "true" ]; then
    cp_configured=1
  fi

  cp_min_c=$(config_number_default temperature_min_c 0)
  cp_max_c=$(config_number_default temperature_max_c 120)
  cp_balanced_c=$(config_number_default balanced_c 38)
  cp_hot_c=$(config_number_default hot_c 42)
  cp_critical_c=$(config_number_default critical_c 46)
  cp_hysteresis_c=$(config_number_default hysteresis_c 2)
  cp_dwell=$(config_number_default minimum_dwell_seconds 30)

  cp_limit_min_milli=$(temp_to_milli_c "$cp_min_c") || cp_configured=0
  cp_limit_max_milli=$(temp_to_milli_c "$cp_max_c") || cp_configured=0
  cp_balanced_milli=$(temp_to_milli_c "$cp_balanced_c") || cp_configured=0
  cp_hot_milli=$(temp_to_milli_c "$cp_hot_c") || cp_configured=0
  cp_critical_milli=$(temp_to_milli_c "$cp_critical_c") || cp_configured=0
  cp_hysteresis_milli=$(temp_to_milli_c "$cp_hysteresis_c") || cp_configured=0
  case "$cp_dwell" in
    ''|*[!0-9]*) cp_dwell=30; cp_configured=0 ;;
  esac
  if ! [ "$cp_limit_min_milli" -le "$cp_balanced_milli" ] 2>/dev/null || \
     ! [ "$cp_balanced_milli" -le "$cp_hot_milli" ] 2>/dev/null || \
     ! [ "$cp_hot_milli" -le "$cp_critical_milli" ] 2>/dev/null || \
     ! [ "$cp_critical_milli" -le "$cp_limit_max_milli" ] 2>/dev/null; then
    cp_configured=0
  fi

  if [ "$cp_configured" != "1" ]; then
    cp_errors=$(list_append_json_string "$cp_errors" "CALIBRATION_REQUIRED")
  fi

  cp_fan_present=0
  cp_fan_supported=0
  cp_fan_enabled=
  cp_fan_rpm=
  cp_fan_level=
  for cp_fan_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    if path_present "$cp_fan_path"; then
      cp_fan_present=1
      cp_fan_supported=1
    fi
  done
  if [ "$cp_fan_present" = "1" ]; then
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    cp_rc=$?
    if [ "$cp_rc" = "0" ]; then
      case "$cp_value" in
        0) cp_fan_enabled=false ;;
        1) cp_fan_enabled=true ;;
        *) cp_reason=$(list_append_json_string "$cp_reason" "invalid_fan_enabled:/sys/kernel/fan/fan_enable") ;;
      esac
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value"; then
      cp_fan_rpm=$cp_value
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value"; then
      cp_fan_level=$cp_value
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    cp_reason=$(list_append_json_string "$cp_reason" "fan_missing")
  fi

  cp_pump_present=0
  cp_pump_supported=0
  cp_pump_enabled=
  cp_pump_speed=
  cp_pump_freq=
  for cp_pump_path in /proc/driver/micropump/enable /proc/driver/micropump/freq /proc/driver/micropump/speed /proc/driver/micropump/mode; do
    if path_present "$cp_pump_path"; then
      cp_pump_present=1
    fi
  done
  if path_present /proc/driver/micropump/enable; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/enable)
    cp_rc=$?
    if [ "$cp_rc" = "0" ]; then
      case "$cp_value" in
        0) cp_pump_enabled=false; cp_pump_supported=1 ;;
        1) cp_pump_enabled=true; cp_pump_supported=1 ;;
        *) cp_reason=$(list_append_json_string "$cp_reason" "invalid_pump_enabled:/proc/driver/micropump/enable") ;;
      esac
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
  fi
  if path_present /proc/driver/micropump/speed; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/speed)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value" && [ "$cp_value" -le 100 ] 2>/dev/null; then
      cp_pump_speed=$cp_value
      cp_pump_supported=1
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
  fi
  if path_present /proc/driver/micropump/freq; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/freq)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value" && [ "$cp_value" -le 100 ] 2>/dev/null; then
      cp_pump_freq=$cp_value
      cp_pump_supported=1
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  fi
  if [ "$cp_pump_present" = "0" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "pump_missing")
  fi

  cp_valid=0
  cp_rejected=0
  cp_observed_max_milli=
  cp_sensor_name=
  cp_sensor_source=
  for cp_thermal_path in \
    /sys/class/thermal/thermal_zone0/temp \
    /sys/class/thermal/thermal_zone1/temp \
    /sys/class/thermal/thermal_zone2/temp \
    /sys/class/thermal/thermal_zone3/temp \
    /sys/devices/virtual/thermal/thermal_zone0/temp \
    /sys/devices/virtual/thermal/thermal_zone1/temp \
    /sys/devices/virtual/thermal/thermal_zone2/temp \
    /sys/devices/virtual/thermal/thermal_zone3/temp
  do
    if path_present "$cp_thermal_path"; then
      cp_value=$(read_allowlisted_file "$cp_thermal_path")
      cp_rc=$?
      if [ "$cp_rc" = "0" ]; then
        if cp_milli=$(temp_to_milli_c "$cp_value") && [ "$cp_milli" -ge "$cp_limit_min_milli" ] 2>/dev/null && [ "$cp_milli" -le "$cp_limit_max_milli" ] 2>/dev/null; then
          cp_valid=$((cp_valid + 1))
          if [ -z "$cp_observed_max_milli" ] || [ "$cp_milli" -gt "$cp_observed_max_milli" ] 2>/dev/null; then
            cp_observed_max_milli=$cp_milli
            cp_sensor_name=$cp_thermal_path
            cp_sensor_source=$REDMAGIC_SOURCE_THERMAL
          fi
        else
          cp_rejected=$((cp_rejected + 1))
          cp_reason=$(list_append_json_string "$cp_reason" "rejected_thermal:$cp_thermal_path")
        fi
      elif [ "$cp_rc" = "3" ]; then
        cp_rejected=$((cp_rejected + 1))
        cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:$cp_thermal_path")
      fi
    fi
  done

  cp_state=UNAVAILABLE
  if [ "$cp_configured" != "1" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "CALIBRATION_REQUIRED")
  elif [ "$(safe_mode_value)" = "1" ]; then
    cp_state=SAFE_MODE
    cp_reason=$(list_append_json_string "$cp_reason" "safe_mode")
  elif [ "$cp_configured" = "1" ] && [ "$cp_valid" -gt 0 ]; then
    if [ "$cp_observed_max_milli" -ge "$cp_critical_milli" ] 2>/dev/null; then
      cp_state=CRITICAL
    elif [ "$cp_observed_max_milli" -ge "$cp_hot_milli" ] 2>/dev/null; then
      cp_state=HOT
    elif [ "$cp_observed_max_milli" -ge "$cp_balanced_milli" ] 2>/dev/null; then
      cp_state=BALANCED
    else
      cp_state=COOL
    fi

    cp_previous=${NEBULA_POLICY_PREVIOUS_STATE:-}
    cp_age=${NEBULA_POLICY_PREVIOUS_STATE_AGE_SECONDS:-999999}
    case "$cp_age" in
      ''|*[!0-9]*) cp_age=999999 ;;
    esac
    cp_prev_rank=$(state_rank "$cp_previous")
    cp_state_rank=$(state_rank "$cp_state")
    if [ "$cp_prev_rank" -gt "$cp_state_rank" ] 2>/dev/null; then
      if [ "$cp_age" -lt "$cp_dwell" ] 2>/dev/null; then
        cp_state=$cp_previous
        cp_reason=$(list_append_json_string "$cp_reason" "minimum_dwell_active")
      else
        cp_hold_threshold=$(state_threshold_milli "$cp_previous")
        cp_hold_floor=$((cp_hold_threshold - cp_hysteresis_milli))
        if [ "$cp_hold_threshold" -gt 0 ] 2>/dev/null && [ "$cp_observed_max_milli" -ge "$cp_hold_floor" ] 2>/dev/null; then
          cp_state=$cp_previous
          cp_reason=$(list_append_json_string "$cp_reason" "hysteresis_hold")
        fi
      fi
    fi
  elif [ "$cp_valid" = "0" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "no_valid_thermal")
  fi

  cp_fan_intent=$(intent_for_state "$cp_fan_supported" "$cp_state" fan)
  cp_pump_intent=$(intent_for_state "$cp_pump_supported" "$cp_state" pump)

  if [ -z "$cp_fan_enabled" ]; then cp_fan_enabled_json=null; else cp_fan_enabled_json=$cp_fan_enabled; fi
  if [ -z "$cp_pump_enabled" ]; then cp_pump_enabled_json=null; else cp_pump_enabled_json=$cp_pump_enabled; fi
  if [ -z "$cp_observed_max_milli" ]; then cp_max_json=null; else cp_max_json=$(json_number_from_milli "$cp_observed_max_milli"); fi
  if [ -z "$cp_sensor_name" ]; then cp_sensor_name_json=null; else cp_sensor_name_json=$(json_string "$cp_sensor_name"); fi
  if [ -z "$cp_sensor_source" ]; then cp_sensor_source_json=null; else cp_sensor_source_json=$(json_string "$cp_sensor_source"); fi

  printf '"preview_only":true,'
  printf '"configured":%s,' "$(json_bool "$cp_configured")"
  printf '"safe_mode":%s,' "$(json_bool "$(safe_mode_value)")"
  printf '"state":%s,' "$(json_string "$cp_state")"
  printf '"controlling_sensor":{"name":%s,"source":%s,"temperature_c":%s},' \
    "$cp_sensor_name_json" "$cp_sensor_source_json" "$cp_max_json"
  printf '"thermal":{"maximum_c":%s,"valid_sensor_count":%s,"rejected_sensor_count":%s},' \
    "$cp_max_json" "$cp_valid" "$cp_rejected"
  printf '"fan":{"supported":%s,"present":%s,"current":{"enabled":%s,"rpm":%s,"level":%s},"intent":%s,"applied":false},' \
    "$(json_bool "$cp_fan_supported")" \
    "$(json_bool "$cp_fan_present")" \
    "$cp_fan_enabled_json" \
    "$(json_int_or_null "$cp_fan_rpm")" \
    "$(json_int_or_null "$cp_fan_level")" \
    "$(json_string "$cp_fan_intent")"
  printf '"pump":{"supported":%s,"present":%s,"current":{"enabled":%s,"speed":%s,"freq":%s},"intent":%s,"applied":false},' \
    "$(json_bool "$cp_pump_supported")" \
    "$(json_bool "$cp_pump_present")" \
    "$cp_pump_enabled_json" \
    "$(json_int_or_null "$cp_pump_speed")" \
    "$(json_int_or_null "$cp_pump_freq")" \
    "$(json_string "$cp_pump_intent")"
  printf '"policy":{"threshold_source":"defaults.json","hysteresis_c":%s,"minimum_dwell_seconds":%s},' \
    "$(json_number_from_milli "$cp_hysteresis_milli")" \
    "$cp_dwell"
  printf '"reason":[%s],"errors":[%s]' "$cp_reason" "$cp_errors"
}

cooling_policy_json() {
  printf '{"protocol_version":%s,"command":"cooling policy",' "$PROTOCOL_VERSION"
  cooling_policy_fields
  printf '}\n'
}

module_prop_from_dir() {
  dir=$1
  key=$2
  prop="$dir/module.prop"
  if [ -f "$prop" ]; then
    sed -n "s/^$key=//p" "$prop" | head -n 1
  fi
}

legacy_module_entry() {
  id=$1
  title=$2
  source=$3
  staged=$4
  dir="$MODULES_ROOT/$id"
  installed=0
  disabled=0
  remove_marker=0
  version=unknown
  version_code=0
  description=
  if [ -d "$dir" ]; then
    installed=1
    version=$(module_prop_from_dir "$dir" version)
    version_code=$(module_prop_from_dir "$dir" versionCode)
    description=$(module_prop_from_dir "$dir" description)
    [ -f "$dir/disable" ] && disabled=1
    [ -f "$dir/remove" ] && remove_marker=1
  fi
  [ -n "$version" ] || version=unknown
  case "$version_code" in
    ''|*[!0-9]*) version_code=0 ;;
  esac
  if [ -z "$description" ]; then description=unknown; fi
  printf '{"id":%s,"title":%s,"protected":true,"installed":%s,"disabled":%s,"remove_marker":%s,"version":%s,"version_code":%s,"description":%s,"nebula_import":%s,"source":%s}' \
    "$(json_string "$id")" \
    "$(json_string "$title")" \
    "$(json_bool "$installed")" \
    "$(json_bool "$disabled")" \
    "$(json_bool "$remove_marker")" \
    "$(json_string "$version")" \
    "$version_code" \
    "$(json_string "$description")" \
    "$(json_string "$staged")" \
    "$(json_string "$source")"
}

legacy_modules_json() {
  printf '{"protocol_version":%s,"command":"legacy modules","migration_enabled":false,"modules":[' "$PROTOCOL_VERSION"
  legacy_module_entry droidspaces "Droidspaces: Daemon & Init" "$LEGACY_DROIDSPACES_SOURCE" "staged_audit_only"
  printf ','
  legacy_module_entry rm11-droidspace-bridge-fd "RM11 Droidspaces Bridge FD Policy" "$LEGACY_BRIDGE_SOURCE" "staged_audit_only"
  printf '],"guardrails":["do_not_disable_both","do_not_delete_until_reboot_verified","nebula_core_does_not_start_targets_by_default"]}\n'
}

cooling_snapshot_payload() {
  snap_errors=
  snap_fan_present=0
  snap_pump_present=0
  snap_fan_enabled=
  snap_fan_rpm=
  snap_fan_level=
  snap_pump_enabled=
  snap_pump_speed=
  snap_pump_freq=

  for snap_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    path_present "$snap_path" && snap_fan_present=1
  done
  if [ "$snap_fan_present" = "1" ]; then
    value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        0) snap_fan_enabled=false ;;
        1) snap_fan_enabled=true ;;
        *) snap_errors=$(list_append_json_string "$snap_errors" "invalid_fan_enabled:/sys/kernel/fan/fan_enable") ;;
      esac
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi
    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value"; then
      snap_fan_rpm=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi
    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value"; then
      snap_fan_level=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    snap_errors=$(list_append_json_string "$snap_errors" "missing:/sys/kernel/fan")
  fi

  for snap_path in /proc/driver/micropump/enable /proc/driver/micropump/freq /proc/driver/micropump/speed; do
    path_present "$snap_path" && snap_pump_present=1
  done
  if [ "$snap_pump_present" = "1" ]; then
    value=$(read_allowlisted_file /proc/driver/micropump/enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        0) snap_pump_enabled=false ;;
        1) snap_pump_enabled=true ;;
        *) snap_errors=$(list_append_json_string "$snap_errors" "invalid_pump_enabled:/proc/driver/micropump/enable") ;;
      esac
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
    value=$(read_allowlisted_file /proc/driver/micropump/speed)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value" && [ "$value" -le 100 ] 2>/dev/null; then
      snap_pump_speed=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
    value=$(read_allowlisted_file /proc/driver/micropump/freq)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value" && [ "$value" -le 100 ] 2>/dev/null; then
      snap_pump_freq=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  else
    snap_errors=$(list_append_json_string "$snap_errors" "missing:/proc/driver/micropump")
  fi

  if [ -z "$snap_fan_enabled" ]; then snap_fan_enabled_json=null; else snap_fan_enabled_json=$snap_fan_enabled; fi
  if [ -z "$snap_pump_enabled" ]; then snap_pump_enabled_json=null; else snap_pump_enabled_json=$snap_pump_enabled; fi
  created=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)
  printf '{"scope":"cooling","created_utc":%s,"fan":{"present":%s,"enabled":%s,"rpm":%s,"level":%s},"pump":{"present":%s,"enabled":%s,"speed":%s,"freq":%s},"rollback_supported":true,"apply_supported":false,"errors":[%s]}' \
    "$(json_string "$created")" \
    "$(json_bool "$snap_fan_present")" \
    "$snap_fan_enabled_json" \
    "$(json_int_or_null "$snap_fan_rpm")" \
    "$(json_int_or_null "$snap_fan_level")" \
    "$(json_bool "$snap_pump_present")" \
    "$snap_pump_enabled_json" \
    "$(json_int_or_null "$snap_pump_speed")" \
    "$(json_int_or_null "$snap_pump_freq")" \
    "$snap_errors"
}

snapshot_cooling_create_json() {
  ensure_dirs
  mkdir -p "$SNAPSHOT_DIR"
  payload=$(cooling_snapshot_payload)
  printf '%s\n' "$payload" > "$COOLING_SNAPSHOT_FILE.tmp"
  mv "$COOLING_SNAPSHOT_FILE.tmp" "$COOLING_SNAPSHOT_FILE"
  printf '{"protocol_version":%s,"command":"snapshot cooling create","ok":true,"snapshot":%s}\n' "$PROTOCOL_VERSION" "$payload"
}

snapshot_cooling_get_json() {
  ensure_dirs
  if [ -s "$COOLING_SNAPSHOT_FILE" ]; then
    printf '{"protocol_version":%s,"command":"snapshot cooling get","present":true,"snapshot":' "$PROTOCOL_VERSION"
    sed -n '1p' "$COOLING_SNAPSHOT_FILE"
    printf '}\n'
  else
    printf '{"protocol_version":%s,"command":"snapshot cooling get","present":false,"snapshot":null}\n' "$PROTOCOL_VERSION"
  fi
}

snapshot_cooling_rollback_dry_run_json() {
  ensure_dirs
  if [ ! -s "$COOLING_SNAPSHOT_FILE" ]; then
    printf '{"protocol_version":%s,"command":"snapshot cooling rollback","ok":false,"dry_run":true,"applied":false,"error":"NO_SNAPSHOT"}\n' "$PROTOCOL_VERSION"
    return 66
  fi
  current=$(cooling_snapshot_payload)
  printf '{"protocol_version":%s,"command":"snapshot cooling rollback","ok":true,"dry_run":true,"applied":false,"writes_enabled":false,"snapshot":' "$PROTOCOL_VERSION"
  sed -n '1p' "$COOLING_SNAPSHOT_FILE"
  printf ',"current":%s,"rollback_plan":{"fan":"restore_snapshot_values_if_apply_enabled_later","pump":"restore_snapshot_values_if_apply_enabled_later"}}\n' "$current"
}

pump_json_payload() {
  pump_errors=
  pump_sources=
  pump_present=0
  pump_supported=0
  pump_enabled=
  pump_speed=

  for pump_path in \
    /proc/driver/micropump/enable \
    /proc/driver/micropump/freq \
    /proc/driver/micropump/speed \
    /proc/driver/micropump/mode
  do
    if path_present "$pump_path"; then
      pump_present=1
    fi
  done

  if path_present /proc/driver/micropump/enable; then
    value=$(read_allowlisted_file /proc/driver/micropump/enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/enable")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/enable")
      elif is_unsigned_integer "$value"; then
        case "$value" in
          0) pump_enabled=false; pump_supported=1 ;;
          1) pump_enabled=true; pump_supported=1 ;;
          *) pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/enable:$value") ;;
        esac
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/enable:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
  fi

  if path_present /proc/driver/micropump/freq; then
    value=$(read_allowlisted_file /proc/driver/micropump/freq)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/freq")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/freq")
      elif is_unsigned_integer "$value"; then
        if [ "$value" -le 100 ] 2>/dev/null; then
          pump_supported=1
        else
          pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/freq:$value")
        fi
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/freq:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  fi

  if path_present /proc/driver/micropump/speed; then
    value=$(read_allowlisted_file /proc/driver/micropump/speed)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/speed")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/speed")
      elif is_unsigned_integer "$value"; then
        if [ "$value" -le 100 ] 2>/dev/null; then
          pump_speed=$value
          pump_supported=1
        else
          pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/speed:$value")
        fi
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/speed:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
  fi

  if [ "$pump_present" = "0" ]; then
    pump_errors=$(list_append_json_string "$pump_errors" "missing:/proc/driver/micropump")
    pump_confidence=unsupported
  elif [ "$pump_supported" = "1" ]; then
    pump_confidence=confirmed
  else
    if [ -z "$pump_errors" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "presence_only:/proc/driver/micropump")
    fi
    pump_confidence=candidate
  fi

  if [ -z "$pump_enabled" ]; then
    pump_enabled_json=null
  else
    pump_enabled_json=$pump_enabled
  fi

  printf '{"supported":%s,"present":%s,"enabled":%s,"rpm":null,"speed":%s,"level":null,"flow_rate":null,"flow_rate_unit":null,"mode":null,"sources":[%s],"confidence":%s,"errors":[%s]}' \
    "$(json_bool "$pump_supported")" \
    "$(json_bool "$pump_present")" \
    "$pump_enabled_json" \
    "$(json_int_or_null "$pump_speed")" \
    "$pump_sources" \
    "$(json_string "$pump_confidence")" \
    "$pump_errors"
}

redmagic_pump_probe_json() {
  printf '{"protocol_version":%s,"command":"redmagic pump probe","pump":' "$PROTOCOL_VERSION"
  pump_json_payload
  printf '}\n'
}

redmagic_probe_json() {
  manufacturer=$(value_or_unknown "$(read_prop ro.product.manufacturer)")
  model=$(value_or_unknown "$(read_prop ro.product.model)")
  product=$(value_or_unknown "$(read_prop ro.product.product.name)")
  device=$(value_or_unknown "$(read_prop ro.product.device)")
  board_platform=$(value_or_unknown "$(read_prop ro.board.platform)")
  kernel=$(value_or_unknown "$(read_kernel_release)")

  fan_errors=
  fan_present=0
  fan_supported=0
  fan_enabled=
  fan_rpm=
  fan_level=

  for fan_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    if path_present "$fan_path"; then
      fan_present=1
      fan_supported=1
    fi
  done

  if [ "$fan_present" = "1" ]; then
    value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        1) fan_enabled=true ;;
        0) fan_enabled=false ;;
        *) fan_enabled= ;;
      esac
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_rpm=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_level=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    fan_errors=$(list_append_json_string "$fan_errors" "missing:/sys/kernel/fan")
  fi

  thermal_errors=
  thermal_readings=
  thermal_supported=0
  first=1
  for thermal_path in \
    /sys/class/thermal/thermal_zone0/temp \
    /sys/class/thermal/thermal_zone1/temp \
    /sys/class/thermal/thermal_zone2/temp \
    /sys/class/thermal/thermal_zone3/temp \
    /sys/devices/virtual/thermal/thermal_zone0/temp \
    /sys/devices/virtual/thermal/thermal_zone1/temp \
    /sys/devices/virtual/thermal/thermal_zone2/temp \
    /sys/devices/virtual/thermal/thermal_zone3/temp
  do
    if path_present "$thermal_path"; then
      value=$(read_allowlisted_file "$thermal_path")
      rc=$?
      if [ "$rc" = "0" ]; then
        thermal_supported=1
        temp_c=$(normalize_temp_c "$value")
        entry=$(printf '{"path":"%s","raw":"%s","temp_c":%s,"source":"%s"}' \
          "$(json_escape "$thermal_path")" \
          "$(json_escape "$value")" \
          "$temp_c" \
          "$(json_escape "$REDMAGIC_SOURCE_THERMAL")")
        if [ "$first" = "1" ]; then
          thermal_readings=$entry
          first=0
        else
          thermal_readings="$thermal_readings,$entry"
        fi
      elif [ "$rc" = "3" ]; then
        thermal_errors=$(list_append_json_string "$thermal_errors" "permission_denied:$thermal_path")
      fi
    fi
  done
  if [ "$thermal_supported" = "0" ] && [ -z "$thermal_errors" ]; then
    thermal_errors=$(list_append_json_string "$thermal_errors" "missing:thermal_temp_allowlist")
  fi

  if [ -z "$fan_enabled" ]; then
    fan_enabled_json=null
  else
    fan_enabled_json=$fan_enabled
  fi
  pump_payload=$(pump_json_payload)
  cooling_policy_payload=$(cooling_policy_fields)

  printf '{'
  printf '"protocol_version":%s,' "$PROTOCOL_VERSION"
  printf '"command":"redmagic probe",'
  printf '"device":{"manufacturer":%s,"model":%s,"product":%s,"device":%s,"board_platform":%s,"kernel":%s,"source":%s},' \
    "$(json_string "$manufacturer")" \
    "$(json_string "$model")" \
    "$(json_string "$product")" \
    "$(json_string "$device")" \
    "$(json_string "$board_platform")" \
    "$(json_string "$kernel")" \
    "$(json_string "$REDMAGIC_SOURCE_IDENTITY")"
  printf '"fan":{"supported":%s,"present":%s,"enabled":%s,"rpm":%s,"level":%s,"source":%s,"errors":[%s]},' \
    "$(json_bool "$fan_supported")" \
    "$(json_bool "$fan_present")" \
    "$fan_enabled_json" \
    "$(json_int_or_null "$fan_rpm")" \
    "$(json_int_or_null "$fan_level")" \
    "$(json_string "$REDMAGIC_SOURCE_FAN")" \
    "$fan_errors"
  printf '"pump":%s,' "$pump_payload"
  printf '"performance":{"supported":false,"mode":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"display":{"supported":false,"refresh_rate_hz":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"thermal":{"supported":%s,"readings":[%s],"source":%s,"errors":[%s]},' \
    "$(json_bool "$thermal_supported")" \
    "$thermal_readings" \
    "$(json_string "$REDMAGIC_SOURCE_THERMAL")" \
    "$thermal_errors"
  printf '"cooling_policy":{%s},' "$cooling_policy_payload"
  printf '"redmagic_button":{"supported":false,"configured":false,"reason":"disabled_in_pass_02"}'
  printf '}\n'
}

usage_json() {
  printf '{"protocol_version":%s,"ok":false,"error":"USAGE"}\n' "$PROTOCOL_VERSION"
}

main() {
  cmd=${1:-}
  case "$cmd" in
    status)
      if [ "${2:-}" = "--json" ]; then
        log_command "status"
        status_json
      else
        usage_json
        return 2
      fi
      ;;
    capabilities)
      if [ "${2:-}" = "--json" ]; then
        log_command "capabilities"
        capabilities_json
      else
        usage_json
        return 2
      fi
      ;;
    profile)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "profile_get"
            profile_get_json
          else
            usage_json
            return 2
          fi
          ;;
        set)
          target=${3:-}
          log_command "profile_set_$target"
          profile_set "$target"
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    safe-mode)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "safe_mode_get"
            safe_mode_get_json
          else
            usage_json
            return 2
          fi
          ;;
        enable)
          log_command "safe_mode_enable"
          safe_mode_enable
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    adb-wifi)
      sub=${2:-}
      case "$sub" in
        status)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_status"
            adb_wifi_status_json
          else
            usage_json
            return 2
          fi
          ;;
        enable)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_enable"
            adb_wifi_enable_json
          else
            usage_json
            return 2
          fi
          ;;
        auto-disable)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_auto_disable"
            adb_wifi_auto_disable_json
          else
            usage_json
            return 2
          fi
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    logs)
      if [ "${2:-}" = "tail" ] && [ "${3:-}" = "--lines" ]; then
        log_command "logs_tail"
        logs_tail_json "${4:-50}"
      else
        usage_json
        return 2
      fi
      ;;
    legacy)
      if [ "${2:-}" = "modules" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        legacy_modules_json
      else
        usage_json
        return 2
      fi
      ;;
    snapshot)
      if [ "${2:-}" = "cooling" ] && [ "${3:-}" = "create" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        snapshot_cooling_create_json
      elif [ "${2:-}" = "cooling" ] && [ "${3:-}" = "get" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        snapshot_cooling_get_json
      elif [ "${2:-}" = "cooling" ] && [ "${3:-}" = "rollback" ] && [ "${4:-}" = "--dry-run" ] && [ "${5:-}" = "--json" ] && [ -z "${6:-}" ]; then
        snapshot_cooling_rollback_dry_run_json
      else
        usage_json
        return 2
      fi
      ;;
    cooling)
      if [ "${2:-}" = "policy" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        cooling_policy_json
      else
        usage_json
        return 2
      fi
      ;;
    redmagic)
      if [ "${2:-}" = "probe" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        redmagic_probe_json
      elif [ "${2:-}" = "pump" ] && [ "${3:-}" = "probe" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        redmagic_pump_probe_json
      else
        usage_json
        return 2
      fi
      ;;
    *)
      usage_json
      return 2
      ;;
  esac
}

main "$@"
