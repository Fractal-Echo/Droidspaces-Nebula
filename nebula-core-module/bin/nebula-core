cooling_snapshot_payload() {
  snap_errors=
  snap_fan_present=0
  snap_pump_present=0
  snap_fan_enabled=
  snap_fan_rpm=
  snap_fan_level=
  snap_pump_enabled=
  snap_pump_speed=
  snap_pump_freq=

  for snap_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    path_present "$snap_path" && snap_fan_present=1
  done
  if [ "$snap_fan_present" = "1" ]; then
    value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        0) snap_fan_enabled=false ;;
        1) snap_fan_enabled=true ;;
        *) snap_errors=$(list_append_json_string "$snap_errors" "invalid_fan_enabled:/sys/kernel/fan/fan_enable") ;;
      esac
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi
    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value"; then
      snap_fan_rpm=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi
    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value"; then
      snap_fan_level=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    snap_errors=$(list_append_json_string "$snap_errors" "missing:/sys/kernel/fan")
  fi

  for snap_path in /proc/driver/micropump/enable /proc/driver/micropump/freq /proc/driver/micropump/speed; do
    path_present "$snap_path" && snap_pump_present=1
  done
  if [ "$snap_pump_present" = "1" ]; then
    value=$(read_allowlisted_file /proc/driver/micropump/enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        0) snap_pump_enabled=false ;;
        1) snap_pump_enabled=true ;;
        *) snap_errors=$(list_append_json_string "$snap_errors" "invalid_pump_enabled:/proc/driver/micropump/enable") ;;
      esac
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
    value=$(read_allowlisted_file /proc/driver/micropump/speed)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value" && [ "$value" -le 100 ] 2>/dev/null; then
      snap_pump_speed=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
    value=$(read_allowlisted_file /proc/driver/micropump/freq)
    rc=$?
    if [ "$rc" = "0" ] && is_unsigned_integer "$value" && [ "$value" -le 100 ] 2>/dev/null; then
      snap_pump_freq=$value
    elif [ "$rc" = "3" ]; then
      snap_errors=$(list_append_json_string "$snap_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  else
    snap_errors=$(list_append_json_string "$snap_errors" "missing:/proc/driver/micropump")
  fi

  if [ -z "$snap_fan_enabled" ]; then snap_fan_enabled_json=null; else snap_fan_enabled_json=$snap_fan_enabled; fi
  if [ -z "$snap_pump_enabled" ]; then snap_pump_enabled_json=null; else snap_pump_enabled_json=$snap_pump_enabled; fi
  created=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)
  printf '{"scope":"cooling","created_utc":%s,"fan":{"present":%s,"enabled":%s,"rpm":%s,"level":%s},"pump":{"present":%s,"enabled":%s,"speed":%s,"freq":%s},"rollback_supported":true,"apply_supported":false,"errors":[%s]}' \
    "$(json_string "$created")" \
    "$(json_bool "$snap_fan_present")" \
    "$snap_fan_enabled_json" \
    "$(json_int_or_null "$snap_fan_rpm")" \
    "$(json_int_or_null "$snap_fan_level")" \
    "$(json_bool "$snap_pump_present")" \
    "$snap_pump_enabled_json" \
    "$(json_int_or_null "$snap_pump_speed")" \
    "$(json_int_or_null "$snap_pump_freq")" \
    "$snap_errors"
}

snapshot_cooling_create_json() {
  ensure_dirs
  mkdir -p "$SNAPSHOT_DIR"
  payload=$(cooling_snapshot_payload)
  printf '%s\n' "$payload" > "$COOLING_SNAPSHOT_FILE.tmp"
  mv "$COOLING_SNAPSHOT_FILE.tmp" "$COOLING_SNAPSHOT_FILE"
  printf '{"protocol_version":%s,"command":"snapshot cooling create","ok":true,"snapshot":%s}\n' "$PROTOCOL_VERSION" "$payload"
}

snapshot_cooling_get_json() {
  ensure_dirs
  if [ -s "$COOLING_SNAPSHOT_FILE" ]; then
    printf '{"protocol_version":%s,"command":"snapshot cooling get","present":true,"snapshot":' "$PROTOCOL_VERSION"
    sed -n '1p' "$COOLING_SNAPSHOT_FILE"
    printf '}\n'
  else
    printf '{"protocol_version":%s,"command":"snapshot cooling get","present":false,"snapshot":null}\n' "$PROTOCOL_VERSION"
  fi
}

snapshot_cooling_rollback_dry_run_json() {
  ensure_dirs
  if [ ! -s "$COOLING_SNAPSHOT_FILE" ]; then
    printf '{"protocol_version":%s,"command":"snapshot cooling rollback","ok":false,"dry_run":true,"applied":false,"error":"NO_SNAPSHOT"}\n' "$PROTOCOL_VERSION"
    return 66
  fi
  current=$(cooling_snapshot_payload)
  printf '{"protocol_version":%s,"command":"snapshot cooling rollback","ok":true,"dry_run":true,"applied":false,"writes_enabled":false,"snapshot":' "$PROTOCOL_VERSION"
  sed -n '1p' "$COOLING_SNAPSHOT_FILE"
  printf ',"current":%s,"rollback_plan":{"fan":"restore_snapshot_values_if_apply_enabled_later","pump":"restore_snapshot_values_if_apply_enabled_later"}}\n' "$current"
}

pump_json_payload() {
  pump_errors=
  pump_sources=
  pump_present=0
  pump_supported=0
  pump_enabled=
  pump_speed=

  for pump_path in \
    /proc/driver/micropump/enable \
    /proc/driver/micropump/freq \
    /proc/driver/micropump/speed \
    /proc/driver/micropump/mode
  do
    if path_present "$pump_path"; then
      pump_present=1
    fi
  done

  if path_present /proc/driver/micropump/enable; then
    value=$(read_allowlisted_file /proc/driver/micropump/enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/enable")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/enable")
      elif is_unsigned_integer "$value"; then
        case "$value" in
          0) pump_enabled=false; pump_supported=1 ;;
          1) pump_enabled=true; pump_supported=1 ;;
          *) pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/enable:$value") ;;
        esac
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/enable:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
  fi

  if path_present /proc/driver/micropump/freq; then
    value=$(read_allowlisted_file /proc/driver/micropump/freq)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/freq")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/freq")
      elif is_unsigned_integer "$value"; then
        if [ "$value" -le 100 ] 2>/dev/null; then
          pump_supported=1
        else
          pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/freq:$value")
        fi
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/freq:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  fi

  if path_present /proc/driver/micropump/speed; then
    value=$(read_allowlisted_file /proc/driver/micropump/speed)
    rc=$?
    if [ "$rc" = "0" ]; then
      pump_sources=$(list_append_json_string "$pump_sources" "/proc/driver/micropump/speed")
      if [ -z "$value" ]; then
        pump_errors=$(list_append_json_string "$pump_errors" "empty:/proc/driver/micropump/speed")
      elif is_unsigned_integer "$value"; then
        if [ "$value" -le 100 ] 2>/dev/null; then
          pump_speed=$value
          pump_supported=1
        else
          pump_errors=$(list_append_json_string "$pump_errors" "out_of_range:/proc/driver/micropump/speed:$value")
        fi
      else
        pump_errors=$(list_append_json_string "$pump_errors" "invalid_numeric:/proc/driver/micropump/speed:$value")
      fi
    elif [ "$rc" = "3" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
  fi

  if [ "$pump_present" = "0" ]; then
    pump_errors=$(list_append_json_string "$pump_errors" "missing:/proc/driver/micropump")
    pump_confidence=unsupported
  elif [ "$pump_supported" = "1" ]; then
    pump_confidence=confirmed
  else
    if [ -z "$pump_errors" ]; then
      pump_errors=$(list_append_json_string "$pump_errors" "presence_only:/proc/driver/micropump")
    fi
    pump_confidence=candidate
  fi

  if [ -z "$pump_enabled" ]; then
    pump_enabled_json=null
  else
    pump_enabled_json=$pump_enabled
  fi

  printf '{"supported":%s,"present":%s,"enabled":%s,"rpm":null,"speed":%s,"level":null,"flow_rate":null,"flow_rate_unit":null,"mode":null,"sources":[%s],"confidence":%s,"errors":[%s]}' \
    "$(json_bool "$pump_supported")" \
    "$(json_bool "$pump_present")" \
    "$pump_enabled_json" \
    "$(json_int_or_null "$pump_speed")" \
    "$pump_sources" \
    "$(json_string "$pump_confidence")" \
    "$pump_errors"
}

redmagic_pump_probe_json() {
  printf '{"protocol_version":%s,"command":"redmagic pump probe","pump":' "$PROTOCOL_VERSION"
  pump_json_payload
  printf '}\n'
}

redmagic_probe_json() {
  manufacturer=$(value_or_unknown "$(read_prop ro.product.manufacturer)")
  model=$(value_or_unknown "$(read_prop ro.product.model)")
  product=$(value_or_unknown "$(read_prop ro.product.product.name)")
  device=$(value_or_unknown "$(read_prop ro.product.device)")
  board_platform=$(value_or_unknown "$(read_prop ro.board.platform)")
  kernel=$(value_or_unknown "$(read_kernel_release)")

  fan_errors=
  fan_present=0
  fan_supported=0
  fan_enabled=
  fan_rpm=
  fan_level=

  for fan_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    if path_present "$fan_path"; then
      fan_present=1
      fan_supported=1
    fi
  done

  if [ "$fan_present" = "1" ]; then
    value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        1) fan_enabled=true ;;
        0) fan_enabled=false ;;
        *) fan_enabled= ;;
      esac
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_rpm=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_level=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    fan_errors=$(list_append_json_string "$fan_errors" "missing:/sys/kernel/fan")
  fi

  thermal_errors=
  thermal_readings=
  thermal_supported=0
  first=1
  for thermal_path in \
    /sys/class/thermal/thermal_zone0/temp \
    /sys/class/thermal/thermal_zone1/temp \
    /sys/class/thermal/thermal_zone2/temp \
    /sys/class/thermal/thermal_zone3/temp \
    /sys/devices/virtual/thermal/thermal_zone0/temp \
    /sys/devices/virtual/thermal/thermal_zone1/temp \
    /sys/devices/virtual/thermal/thermal_zone2/temp \
    /sys/devices/virtual/thermal/thermal_zone3/temp
  do
    if path_present "$thermal_path"; then
      value=$(read_allowlisted_file "$thermal_path")
      rc=$?
      if [ "$rc" = "0" ]; then
        thermal_supported=1
        temp_c=$(normalize_temp_c "$value")
        entry=$(printf '{"path":"%s","raw":"%s","temp_c":%s,"source":"%s"}' \
          "$(json_escape "$thermal_path")" \
          "$(json_escape "$value")" \
          "$temp_c" \
          "$(json_escape "$REDMAGIC_SOURCE_THERMAL")")
        if [ "$first" = "1" ]; then
          thermal_readings=$entry
          first=0
        else
          thermal_readings="$thermal_readings,$entry"
        fi
      elif [ "$rc" = "3" ]; then
        thermal_errors=$(list_append_json_string "$thermal_errors" "permission_denied:$thermal_path")
      fi
    fi
  done
  if [ "$thermal_supported" = "0" ] && [ -z "$thermal_errors" ]; then
    thermal_errors=$(list_append_json_string "$thermal_errors" "missing:thermal_temp_allowlist")
  fi

  if [ -z "$fan_enabled" ]; then
    fan_enabled_json=null
  else
    fan_enabled_json=$fan_enabled
  fi
  pump_payload=$(pump_json_payload)
  cooling_policy_payload=$(cooling_policy_fields)

  printf '{'
  printf '"protocol_version":%s,' "$PROTOCOL_VERSION"
  printf '"command":"redmagic probe",'
  printf '"device":{"manufacturer":%s,"model":%s,"product":%s,"device":%s,"board_platform":%s,"kernel":%s,"source":%s},' \
    "$(json_string "$manufacturer")" \
    "$(json_string "$model")" \
    "$(json_string "$product")" \
    "$(json_string "$device")" \
    "$(json_string "$board_platform")" \
    "$(json_string "$kernel")" \
    "$(json_string "$REDMAGIC_SOURCE_IDENTITY")"
  printf '"fan":{"supported":%s,"present":%s,"enabled":%s,"rpm":%s,"level":%s,"source":%s,"errors":[%s]},' \
    "$(json_bool "$fan_supported")" \
    "$(json_bool "$fan_present")" \
    "$fan_enabled_json" \
    "$(json_int_or_null "$fan_rpm")" \
    "$(json_int_or_null "$fan_level")" \
    "$(json_string "$REDMAGIC_SOURCE_FAN")" \
    "$fan_errors"
  printf '"pump":%s,' "$pump_payload"
  printf '"performance":{"supported":false,"mode":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"display":{"supported":false,"refresh_rate_hz":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"thermal":{"supported":%s,"readings":[%s],"source":%s,"errors":[%s]},' \
    "$(json_bool "$thermal_supported")" \
    "$thermal_readings" \
    "$(json_string "$REDMAGIC_SOURCE_THERMAL")" \
    "$thermal_errors"
  printf '"cooling_policy":{%s},' "$cooling_policy_payload"
  printf '"redmagic_button":{"supported":false,"configured":false,"reason":"disabled_in_pass_02"}'
  printf '}\n'
}

usage_json() {
  printf '{"protocol_version":%s,"ok":false,"error":"USAGE"}\n' "$PROTOCOL_VERSION"
}

main() {
  cmd=${1:-}
  case "$cmd" in
    status)
      if [ "${2:-}" = "--json" ]; then
        log_command "status"
        status_json
      else
        usage_json
        return 2
      fi
      ;;
    capabilities)
      if [ "${2:-}" = "--json" ]; then
        log_command "capabilities"
        capabilities_json
      else
        usage_json
        return 2
      fi
      ;;
    profile)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "profile_get"
            profile_get_json
          else
            usage_json
            return 2
          fi
          ;;
        set)
          target=${3:-}
          log_command "profile_set_$target"
          profile_set "$target"
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    safe-mode)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "safe_mode_get"
            safe_mode_get_json
          else
            usage_json
            return 2
          fi
          ;;
        enable)
          log_command "safe_mode_enable"
          safe_mode_enable
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    adb-wifi)
      sub=${2:-}
      case "$sub" in
        status)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_status"
            adb_wifi_status_json
          else
            usage_json
            return 2
          fi
          ;;
        enable)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_enable"
            adb_wifi_enable_json
          else
            usage_json
            return 2
          fi
          ;;
        auto-disable)
          if [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
            log_command "adb_wifi_auto_disable"
            adb_wifi_auto_disable_json
          else
            usage_json
            return 2
          fi
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    logs)
      if [ "${2:-}" = "tail" ] && [ "${3:-}" = "--lines" ]; then
        log_command "logs_tail"
        logs_tail_json "${4:-50}"
      else
        usage_json
        return 2
      fi
      ;;
    legacy)
      if [ "${2:-}" = "modules" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        legacy_modules_json
      else
        usage_json
        return 2
      fi
      ;;
    integrations)
      if [ "${2:-}" = "baseline" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        log_command "integrations_baseline"
        integrations_baseline_json
      else
        usage_json
        return 2
      fi
      ;;
    nubia)
      if [ "${2:-}" = "toolkit" ] && [ "${3:-}" = "status" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        log_command "nubia_toolkit_status"
        nubia_toolkit_status_json
      else
        usage_json
        return 2
      fi
      ;;
    runtime)
      if [ "${2:-}" = "waylandie" ] && [ "${3:-}" = "status" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        log_command "runtime_waylandie_status"
        waylandie_runtime_status_json
      elif [ "${2:-}" = "waylandie" ] && [ "${3:-}" = "proton-smoke" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        log_command "runtime_waylandie_proton_smoke"
        waylandie_runtime_smoke_json
      else
        usage_json
        return 2
      fi
      ;;
    snapshot)
      if [ "${2:-}" = "cooling" ] && [ "${3:-}" = "create" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        snapshot_cooling_create_json
      elif [ "${2:-}" = "cooling" ] && [ "${3:-}" = "get" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        snapshot_cooling_get_json
      elif [ "${2:-}" = "cooling" ] && [ "${3:-}" = "rollback" ] && [ "${4:-}" = "--dry-run" ] && [ "${5:-}" = "--json" ] && [ -z "${6:-}" ]; then
        snapshot_cooling_rollback_dry_run_json
      else
        usage_json
        return 2
      fi
      ;;
    cooling)
      if [ "${2:-}" = "policy" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        cooling_policy_json
      else
        usage_json
        return 2
      fi
      ;;
    display)
      if [ "${2:-}" = "lanes" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        log_command "display_lanes"
        display_lanes_json
      elif [ "${2:-}" = "method-containers" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        log_command "display_method_containers"
        display_method_containers_json
      elif [ "${2:-}" = "method-profiles" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        log_command "display_method_profiles"
        display_method_profiles_json
      elif [ "${2:-}" = "lane" ] && [ "${3:-}" = "phone" ] && [ "${4:-}" = "preflight" ] && [ "${5:-}" = "--json" ] && [ -z "${6:-}" ]; then
        log_command "display_lane_phone_preflight"
        display_phone_preflight_json
      elif [ "${2:-}" = "lane" ] && [ "${3:-}" = "anland" ] && [ "${4:-}" = "preflight" ] && [ "${5:-}" = "--json" ] && [ -z "${6:-}" ]; then
        log_command "display_lane_anland_preflight"
        display_anland_preflight_json
      elif [ "${2:-}" = "lane" ] && [ "${3:-}" = "dock" ] && [ "${4:-}" = "preflight" ] && [ "${5:-}" = "--json" ] && [ -z "${6:-}" ]; then
        log_command "display_lane_dock_preflight"
        display_dock_preflight_json
      else
        usage_json
        return 2
      fi
      ;;
    redmagic)
      if [ "${2:-}" = "probe" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        redmagic_probe_json
      elif [ "${2:-}" = "pump" ] && [ "${3:-}" = "probe" ] && [ "${4:-}" = "--json" ] && [ -z "${5:-}" ]; then
        redmagic_pump_probe_json
      else
        usage_json
        return 2
      fi
      ;;
    *)
      usage_json
      return 2
      ;;
  esac
}

main "$@"
