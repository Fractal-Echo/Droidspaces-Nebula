    "$(json_bool "$wl_installed")" \
    "$(json_bool "$wl_imagefs_present")" \
    "$(json_bool "$wl_proton_present")" \
    "$(json_bool "$wl_wine_present")"
  printf '"errors":[%s]' "$wl_errors"
}

display_phone_preflight_json() {
  printf '{"protocol_version":%s,"command":"display lane phone preflight",' "$PROTOCOL_VERSION"
