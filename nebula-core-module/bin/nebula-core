display_anland_preflight_payload() {
  anland_collect
  anland_container_status=missing
  anland_display_status=display_missing
  anland_runtime_status=runtime_missing
  anland_requirement_status=missing_requirements
  if [ "$anland_selection_ambiguous" = "1" ]; then
    anland_container_status=ambiguous
    anland_requirement_status=ambiguous_selection
  elif [ -z "$anland_selected_container" ]; then
    anland_container_status=missing
    anland_requirement_status=invalid_selection
  elif [ "$anland_container_active" = "1" ]; then
    anland_container_status=active
  elif [ "$anland_runtime_ready" = "1" ]; then
    anland_container_status=ready
  elif [ "$anland_config" = "1" ]; then
    anland_container_status=idle
  fi
  if [ "$anland_runtime_ready" = "1" ]; then
    anland_runtime_status=runtime_ready
  fi
  if [ "$anland_ready" = "1" ]; then
    anland_display_status=display_ready
    anland_requirement_status=complete
  elif [ "$anland_requirement_status" = "ambiguous_selection" ] || [ "$anland_requirement_status" = "invalid_selection" ]; then
    true
  elif [ "$anland_rootfs_allowed" != "1" ]; then
    anland_requirement_status=invalid_rootfs_path
  elif [ "$anland_rootfs" != "1" ]; then
    anland_requirement_status=missing_requirements
  elif [ "$anland_socket" != "1" ] && [ "$anland_env" != "1" ]; then
    anland_requirement_status=missing_requirements
  elif [ "$anland_socket" != "1" ]; then
    anland_requirement_status=missing_requirements
  elif [ "$anland_socket_writable" != "1" ]; then
    anland_requirement_status=missing_requirements
  elif [ "$anland_env" != "1" ]; then
    anland_requirement_status=missing_requirements
  fi

  printf '"id":"anland_surface",'
  printf '"method_id":"anland_surface",'
  printf '"title":"Anland Surface Mode",'
  printf '"status":%s,' "$(json_string "$anland_status")"
  printf '"available":%s,' "$(json_bool "$anland_ready")"
  printf '"runtime_ready":%s,' "$(json_bool "$anland_runtime_ready")"
  printf '"container_ref":%s,' "$(json_string "$anland_selected_container")"
  printf '"container_kind":"droidspaces",'
  printf '"container_status":%s,' "$(json_string "$anland_container_status")"
  printf '"display_status":%s,' "$(json_string "$anland_display_status")"
  printf '"runtime_status":%s,' "$(json_string "$anland_runtime_status")"
  printf '"start_command_status":"not_available",'
  printf '"requirement_status":%s,' "$(json_string "$anland_requirement_status")"
  printf '"missing_requirements":[%s],' "$anland_errors"
  printf '"required_config":'
  anland_required_config_json
  printf ','
  printf '"required_env":'
  anland_required_env_json
  printf ','
  printf '"setup_commands":'
  anland_setup_commands_json
  printf ','
  printf '"mutating":false,'
  printf '"repair_command_available":false,'
  printf '"source":%s,' "$(json_string "$ANLAND_REPAIR_SOURCE")"
  printf '"selected_container":%s,' "$(json_string "$anland_selected_container")"
  printf '"container_selection_source":%s,' "$(json_string "$anland_selection_source")"
  printf '"container_active":%s,' "$(json_bool "$anland_container_active")"
  printf '"container_pid":%s,' "$(json_int_or_null "$anland_container_pid")"
  printf '"checks":{"droidspaces_binary":%s,"container_selected":%s,"container_config":%s,"active_container_pidfile":%s,"rootfs_path":%s,"rootfs_image":%s,"anland_env":%s,"display_daemon_socket":%s,"display_daemon_socket_writable":%s,"render_node":%s,"config_env_file":%s,"config_socket_bind":%s,"env_socket":%s,"env_kgsl":%s,"anland_producer":%s},' \
    "$(json_bool "$anland_bin")" \
    "$(json_bool "$([ -n "$anland_selected_container" ] && printf 1 || printf 0)")" \
    "$(json_bool "$anland_config")" \
    "$(json_bool "$anland_container_active")" \
    "$(json_bool "$anland_rootfs")" \
    "$(json_bool "$anland_rootfs_image")" \
    "$(json_bool "$anland_env")" \
    "$(json_bool "$anland_socket")" \
    "$(json_bool "$anland_socket_writable")" \
    "$(json_bool "$anland_render")" \
    "$(json_bool "$anland_config_env")" \
    "$(json_bool "$anland_config_bind")" \
    "$(json_bool "$anland_env_socket")" \
    "$(json_bool "$anland_env_kgsl")" \
    "$(json_bool "$anland_producer")"
  printf '"selected_paths":{"droidspaces_binary":%s,"containers_dir":%s,"pids_dir":%s,"pidfile":%s,"container_config":%s,"anland_env":%s,"rootfs_path":%s,"rootfs_mode":%s,"display_socket_host":%s,"display_socket_guest":%s,"render_node":%s},' \
    "$(json_string "$ANLAND_DROIDSPACES_BIN")" \
    "$(json_string "$ANLAND_CONTAINERS_DIR")" \
    "$(json_string "$ANLAND_PIDS_DIR")" \
    "$(json_string_or_null "$anland_selected_pidfile")" \
    "$(json_string "$anland_selected_config")" \
    "$(json_string "$anland_selected_env")" \
    "$(json_string "$anland_selected_rootfs")" \
    "$(json_string "$anland_selected_rootfs_mode")" \
    "$(json_string "$ANLAND_SOCKET_HOST")" \
    "$(json_string "$ANLAND_SOCKET_GUEST")" \
    "$(json_string "$ANLAND_RENDER_NODE")"
  printf '"errors":[%s]' "$anland_errors"
}

display_anland_preflight_json() {
  printf '{"protocol_version":%s,"command":"display lane anland preflight",' "$PROTOCOL_VERSION"
  display_anland_preflight_payload
  printf '}\n'
}

