ANLAND_RECOMMENDED_ROOTFS_ARCHIVE=/sdcard/Download/anland-ubuntu26-kde.tar.xz
ANLAND_RECOMMENDED_ROOTFS_SIZE=32G
ANLAND_DAEMON_MODULE_ID=virtual-drm-daemon
ANLAND_CONSUMER_PACKAGE=com.anland.consumer
DROIDSPACES_NATIVE_METHOD_SOURCE="Droidspaces-OSS README.md, Documentation/Features.md, src/config.c, src/environment.c, src/android/x11.c, src/android/virgl.c, src/android/pulseaudio.c"
DROIDSPACES_ROOTFS_METHOD_SOURCE="Droidspaces-OSS src/main.c, src/utils.c, src/config.c rootfs flags and persisted container.config"

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$STATE_DIR" 2>/dev/null || return 0
  if [ ! -s "$PROFILE_FILE" ]; then
    printf '%s\n' safe > "$PROFILE_FILE" 2>/dev/null || true
  fi
}

prop_value() {
  key=$1
  if [ -f "$MODULE_PROP" ]; then
    sed -n "s/^$key=//p" "$MODULE_PROP" | head -n 1
  fi
}

module_version() {
  value=$(prop_value version)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

module_version_code() {
  value=$(prop_value versionCode)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' 0
  fi
}

git_commit() {
  value=${NEBULA_GIT_COMMIT:-}
  if [ -z "$value" ] && [ -f "$MODDIR/config/git-commit.txt" ]; then
    value=$(sed -n '1p' "$MODDIR/config/git-commit.txt")
  fi
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

json_output_string() {
  value=$(printf '%s' "$1" | tr '\r\n' '  ' | cut -c 1-2048)
  json_string "$value"
}

json_string_or_null() {
  if [ -n "$1" ]; then
    json_string "$1"
  else
    printf '%s' null
  fi
}

json_int_or_null() {
  case "$1" in
    ''|*[!0-9-]*) printf '%s' null ;;
    *) printf '%s' "$1" ;;
  esac
}

is_unsigned_integer() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

json_number_from_milli() {
  milli=$1
  case "$milli" in
    ''|*[!0-9-]*) printf '%s' null; return ;;
  esac
  sign=
  case "$milli" in
    -*) sign=-; milli=${milli#-} ;;
  esac
  whole=$((milli / 1000))
  frac=$((milli % 1000))
  printf '%s%s.%03d' "$sign" "$whole" "$frac"
}

config_bool() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*true.*/true/p" \
      -e "s/.*\"$key\"[[:space:]]*:[[:space:]]*false.*/false/p" \
      "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number() {
  key=$1
  if [ -f "$DEFAULTS_JSON" ]; then
    sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\([-0-9.][0-9.]*\\).*/\\1/p" "$DEFAULTS_JSON" | head -n 1
  fi
}

config_number_default() {
  key=$1
  fallback=$2
  value=$(config_number "$key")
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

json_bool() {
  if [ "$1" = "1" ]; then
    printf '%s' true
  else
    printf '%s' false
  fi
}

safe_mode_value() {
  if [ -f "$SAFE_MODE_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

current_profile() {
  if [ -s "$PROFILE_FILE" ]; then
    value=$(head -n 1 "$PROFILE_FILE")
  else
    value=safe
  fi
  case "$value" in
    safe|phone|dock|compatibility) printf '%s' "$value" ;;
    *) printf '%s' safe ;;
  esac
}

daemon_running_value() {
  pid_file="$STATE_DIR/service.pid"
  if [ -s "$pid_file" ]; then
    pid=$(head -n 1 "$pid_file")
    case "$pid" in
      *[!0-9]*|'') printf '%s' 0 ;;
      *)
        if kill -0 "$pid" 2>/dev/null; then
          printf '%s' 1
        else
          printf '%s' 0
        fi
        ;;
    esac
  else
    printf '%s' 0
  fi
}

service_status() {
  if [ "$(daemon_running_value)" = "1" ]; then
    printf '%s' running
  elif [ -d "$STATE_DIR" ]; then
    printf '%s' state_ready
  else
    printf '%s' missing_state
  fi
}

log_command() {
  ensure_dirs
  if [ -d "$LOG_DIR" ]; then
    printf '%s command=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$1" >> "$LOG_FILE" 2>/dev/null || true
  fi
}

status_json() {
  ensure_dirs
  safe=$(safe_mode_value)
  daemon=$(daemon_running_value)
  profile=$(current_profile)
  printf '{"protocol_version":%s,"module_id":"%s","module_version":"%s","module_version_code":%s,"git_commit":"%s","safe_mode":%s,"profile":"%s","daemon_running":%s,"service_status":"%s"}\n' \
    "$PROTOCOL_VERSION" \
    "$MODULE_ID" \
    "$(json_escape "$(module_version)")" \
    "$(module_version_code)" \
    "$(json_escape "$(git_commit)")" \
    "$(json_bool "$safe")" \
    "$profile" \
    "$(json_bool "$daemon")" \
    "$(service_status)"
}

