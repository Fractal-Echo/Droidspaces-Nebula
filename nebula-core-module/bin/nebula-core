	    "$wl_display_errors"
	  printf '{"id":"droidspaces","method_id":"anland_surface","title":"DroidSpaces / Anland runtime","owner":"DroidSpaces ecosystem","role":"container_surface_fallback","status":%s,"installed":%s,"ready":%s,"runtime_ready":%s,"display_socket_ready":%s,"container_ref":%s,"container_kind":"droidspaces","container_status":%s,"display_status":%s,"runtime_status":%s,"requirement_status":%s,"missing_requirements":[%s],"mutating":false,"package":%s,"module_installed":%s,"module_disabled":%s,"bridge_module_installed":%s,"selected_container":%s,"container_selection_source":%s,"container_active":%s,"container_pid":%s,"checks":{"droidspaces_binary":%s,"container_selected":%s,"container_config":%s,"active_container_pidfile":%s,"rootfs_path":%s,"anland_env":%s,"display_daemon_socket":%s,"display_daemon_socket_writable":%s,"render_node":%s,"anland_producer":%s},"selected_paths":{"containers_dir":%s,"pids_dir":%s,"pidfile":%s,"container_config":%s,"anland_env":%s,"rootfs_path":%s},"source":%s,"errors":[%s]},' \
