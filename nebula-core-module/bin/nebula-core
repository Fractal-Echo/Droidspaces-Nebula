}

profile_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"profile":"%s","safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(current_profile)" "$(json_bool "$(safe_mode_value)")"
}

blocked_profile_json() {
  profile=$1
  printf '{"protocol_version":%s,"ok":false,"profile":"%s","error":"BLOCKED_NOT_READY"}\n' \
    "$PROTOCOL_VERSION" "$profile"
}

profile_set() {
  ensure_dirs
  profile=$1
  case "$profile" in
    safe)
      touch "$SAFE_MODE_FILE"
      printf '%s\n' safe > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"safe","safe_mode":true}\n' "$PROTOCOL_VERSION"
      ;;
    phone)
      rm -f "$SAFE_MODE_FILE"
      printf '%s\n' phone > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"phone","safe_mode":false,"launch_started":false}\n' "$PROTOCOL_VERSION"
      ;;
    dock|compatibility)
      blocked_profile_json "$profile"
      return 75
      ;;
    *)
      printf '{"protocol_version":%s,"ok":false,"error":"UNKNOWN_PROFILE"}\n' "$PROTOCOL_VERSION"
      return 2
      ;;
  esac
}

safe_mode_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(json_bool "$(safe_mode_value)")"
}

safe_mode_enable() {
  ensure_dirs
  touch "$SAFE_MODE_FILE"
  printf '%s\n' safe > "$PROFILE_FILE"
  printf '{"protocol_version":%s,"ok":true,"safe_mode":true,"profile":"safe"}\n' "$PROTOCOL_VERSION"
}

adb_wifi_read_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global adb_wifi_enabled 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_read_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  settings get global enable_wireless_switch 2>/dev/null | head -n 1 | tr -d '\r'
}

adb_wifi_write_adb_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_enabled"
    return $?
  fi
  settings put global adb_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_wireless_enabled() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_adb_wifi_enabled"
    return $?
  fi
  settings put global adb_wifi_enabled 1 >/dev/null 2>&1
}

adb_wifi_write_ui_switch() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' 1 > "$NEBULA_SETTINGS_DIR/global_enable_wireless_switch"
    return $?
  fi
  settings put global enable_wireless_switch 1 >/dev/null 2>&1
}

adb_wifi_bool_json() {
  case "$1" in
    1) printf '%s' true ;;
    0) printf '%s' false ;;
    *) printf '%s' null ;;
  esac
}

adb_wifi_effective_value() {
  wifi_value=$1
  switch_value=$2
  port_value=${3:-}
  if adb_wifi_port_active "$port_value"; then
    printf '%s' 1
    return
  fi
  if [ "$wifi_value" = "1" ] || [ "$switch_value" = "1" ]; then
    printf '%s' 0
    return
  fi
  case "$wifi_value$switch_value" in
    *0*) printf '%s' 0 ;;
    *) printf '%s' unknown ;;
  esac
}

adb_wifi_port_active() {
  port_value=${1:-}
  [ -n "$port_value" ] && [ "$port_value" -gt 0 ] 2>/dev/null && [ "$port_value" -le 65535 ] 2>/dev/null
}

adb_wifi_port_valid_or_zero() {
  port_value=${1:-}
  case "$port_value" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$port_value" -ge 0 ] 2>/dev/null && [ "$port_value" -le 65535 ] 2>/dev/null
}

adb_wifi_requested_value() {
  adb_value=$1
  wifi_value=$2
  switch_value=$3
  if [ "$adb_value" = "1" ] && { [ "$wifi_value" = "1" ] || [ "$switch_value" = "1" ]; }; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

adb_wifi_activation_state() {
  effective_value=$1
  requested_value=$2
  if [ "$effective_value" = "1" ]; then
    printf '%s' live
  elif [ "$requested_value" = "1" ]; then
    printf '%s' manual_toggle_required
  elif [ "$effective_value" = "0" ]; then
    printf '%s' disabled
  else
    printf '%s' unknown
  fi
}

adb_wifi_current_bssid() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/current_bssid" ]; then
      head -n 1 "$NEBULA_SETTINGS_DIR/current_bssid" | tr -d '\r'
      return 0
    fi
    return 2
  fi
  cmd wifi status 2>/dev/null \
    | sed -n 's/.*BSSID: \([0-9A-Fa-f:][0-9A-Fa-f:]*\),.*/\1/p' \
    | head -n 1 \
    | tr -d '\r'
}

adb_wifi_valid_bssid() {
  case "$1" in
    [0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f])
      [ "$1" != "02:00:00:00:00:00" ]
      ;;
    *) return 1 ;;
  esac
}

adb_wifi_manager_allow() {
  bssid=$1
  if ! adb_wifi_valid_bssid "$bssid"; then
    return 2
  fi
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    mkdir -p "$NEBULA_SETTINGS_DIR" || return 1
    printf '%s\n' "$bssid" > "$NEBULA_SETTINGS_DIR/manager_allow_bssid"
    return $?
  fi
  service call adb 4 i32 1 s16 "$bssid" >/dev/null 2>&1
}

adb_wifi_read_wireless_port() {
  if [ -n "${NEBULA_SETTINGS_DIR:-}" ]; then
    if [ -f "$NEBULA_SETTINGS_DIR/adb_wireless_port" ]; then
      value=$(head -n 1 "$NEBULA_SETTINGS_DIR/adb_wireless_port" | tr -d '\r')
      if adb_wifi_port_valid_or_zero "$value"; then
        printf '%s' "$value"
        return 0
      fi
      return 2
    fi
    return 2
  fi
  parcel=$(service call adb 10 2>/dev/null | tr -d '\r')
  value=$(printf '%s\n' "$parcel" | sed -n 's/.*00000000 \([0-9A-Fa-f][0-9A-Fa-f]*\).*/\1/p' | head -n 1)
  if [ -n "$value" ]; then
    port=$(printf '%d' "0x$value" 2>/dev/null || true)
    if adb_wifi_port_valid_or_zero "$port"; then
      printf '%s' "$port"
      return 0
    fi
  fi
  return 2
}

adb_wifi_auto_value() {
  if [ -f "$ADB_WIFI_AUTO_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

adb_wifi_state_snapshot() {
  ensure_dirs
  if [ ! -s "$ADB_WIFI_STATE_FILE" ]; then
    adb_value=$(adb_wifi_read_adb_enabled 2>/dev/null || printf unknown)
    wifi_value=$(adb_wifi_read_wireless_enabled 2>/dev/null || printf unknown)
    switch_value=$(adb_wifi_read_ui_switch 2>/dev/null || printf unknown)
    bssid_value=$(adb_wifi_current_bssid 2>/dev/null || printf unknown)
    {
      printf 'adb_enabled=%s\n' "$adb_value"
      printf 'adb_wifi_enabled=%s\n' "$wifi_value"
      printf 'enable_wireless_switch=%s\n' "$switch_value"
      printf 'current_bssid=%s\n' "$bssid_value"
    } > "$ADB_WIFI_STATE_FILE"
  fi
}

adb_wifi_status_payload() {
  errors=
  adb_value=$(adb_wifi_read_adb_enabled)
  adb_rc=$?
  if [ "$adb_rc" != "0" ]; then
    adb_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_enabled")
  fi
  wifi_value=$(adb_wifi_read_wireless_enabled)
  wifi_rc=$?
  if [ "$wifi_rc" != "0" ]; then
    wifi_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_adb_wifi_enabled")
  fi
  switch_value=$(adb_wifi_read_ui_switch)
  switch_rc=$?
  if [ "$switch_rc" != "0" ]; then
    switch_value=
    errors=$(list_append_json_string "$errors" "unreadable:settings_global_enable_wireless_switch")
  fi
  port_value=$(adb_wifi_read_wireless_port)
  port_rc=$?
  if [ "$port_rc" != "0" ]; then
    port_value=
    errors=$(list_append_json_string "$errors" "unreadable:adb_manager_wireless_port")
  fi
  bssid_value=$(adb_wifi_current_bssid)
  bssid_rc=$?
  if [ "$bssid_rc" != "0" ] || ! adb_wifi_valid_bssid "$bssid_value"; then
    bssid_value=
    errors=$(list_append_json_string "$errors" "unreadable:current_wifi_bssid")
  fi
  effective_value=$(adb_wifi_effective_value "$wifi_value" "$switch_value" "$port_value")
  requested_value=$(adb_wifi_requested_value "$adb_value" "$wifi_value" "$switch_value")
  manual_required=0
  if [ "$requested_value" = "1" ] && [ "$effective_value" != "1" ]; then
    manual_required=1
    errors=$(list_append_json_string "$errors" "manual_toggle_required:wireless_port_inactive")
  fi

  printf '"adb_debugging":%s,' "$(adb_wifi_bool_json "$adb_value")"
  printf '"wireless_debugging":%s,' "$(adb_wifi_bool_json "$effective_value")"
  printf '"settings_wireless_debugging":%s,' "$(adb_wifi_bool_json "$wifi_value")"
  printf '"ui_wireless_switch":%s,' "$(adb_wifi_bool_json "$switch_value")"
  if [ -n "$port_value" ] && [ "$port_value" -ge 0 ] 2>/dev/null; then
    printf '"wireless_port":%s,' "$port_value"
  else
    printf '"wireless_port":null,'
  fi
  printf '"manager_bssid_available":%s,' "$(json_bool "$([ -n "$bssid_value" ] && printf 1 || printf 0)")"
  printf '"settings_requested":%s,' "$(json_bool "$requested_value")"
  printf '"manual_toggle_required":%s,' "$(json_bool "$manual_required")"
  printf '"activation_state":"%s",' "$(adb_wifi_activation_state "$effective_value" "$requested_value")"
  printf '"ui_switch_source":"Android Settings.Global enable_wireless_switch",'
  printf '"auto_enable":%s,' "$(json_bool "$(adb_wifi_auto_value)")"
  printf '"source":"Android Settings.Global adb_enabled,adb_wifi_enabled,enable_wireless_switch; android.debug.IAdbManager allowWirelessDebugging/getAdbWirelessPort",'
  printf '"errors":[%s]' "$errors"
}

adb_wifi_status_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"command":"adb-wifi status",' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

adb_wifi_enable_json() {
  ensure_dirs
  adb_wifi_state_snapshot
  errors=
  settings_ok=1
  manager_ok=1
  if ! adb_wifi_write_adb_enabled; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_enabled")
  fi
  if ! adb_wifi_write_wireless_enabled; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_adb_wifi_enabled")
  fi
  if ! adb_wifi_write_ui_switch; then
    settings_ok=0
    errors=$(list_append_json_string "$errors" "write_failed:settings_global_enable_wireless_switch")
  fi
  bssid_value=$(adb_wifi_current_bssid 2>/dev/null || true)
  if adb_wifi_valid_bssid "$bssid_value"; then
    if ! adb_wifi_manager_allow "$bssid_value"; then
      manager_ok=0
      errors=$(list_append_json_string "$errors" "write_failed:adb_manager_allow_wireless_debugging")
    fi
  else
    manager_ok=0
    errors=$(list_append_json_string "$errors" "unavailable:current_wifi_bssid")
  fi
  requested=0
  if [ "$settings_ok" = "1" ]; then
    requested=1
    touch "$ADB_WIFI_AUTO_FILE" 2>/dev/null || {
      requested=0
      errors=$(list_append_json_string "$errors" "write_failed:adb_wifi_auto_enable")
    }
  fi
  port_value=$(adb_wifi_read_wireless_port 2>/dev/null || true)
  live=0
  if adb_wifi_port_active "$port_value"; then
    live=1
  elif [ "$settings_ok" = "1" ]; then
    errors=$(list_append_json_string "$errors" "manual_toggle_required:wireless_port_inactive")
  fi
  printf '{"protocol_version":%s,"command":"adb-wifi enable","ok":%s,"applied":%s,"requested":%s,"manager_request_ok":%s,' \
    "$PROTOCOL_VERSION" "$(json_bool "$live")" "$(json_bool "$live")" "$(json_bool "$requested")" "$(json_bool "$manager_ok")"
  adb_wifi_status_payload
  printf '}\n'
  [ "$live" = "1" ]
}

adb_wifi_auto_disable_json() {
  ensure_dirs
  rm -f "$ADB_WIFI_AUTO_FILE"
  printf '{"protocol_version":%s,"command":"adb-wifi auto-disable","ok":true,"current_session_changed":false,' "$PROTOCOL_VERSION"
  adb_wifi_status_payload
  printf '}\n'
}

logs_tail_json() {
  ensure_dirs
  lines=$1
  case "$lines" in
    ''|*[!0-9]*) lines=50 ;;
  esac
  if [ "$lines" -lt 1 ]; then lines=1; fi
  if [ "$lines" -gt 500 ]; then lines=500; fi
  printf '{"protocol_version":%s,"lines":[' "$PROTOCOL_VERSION"
  if [ -f "$LOG_FILE" ]; then
    out=$(tail -n "$lines" "$LOG_FILE" 2>/dev/null || true)
    if [ -n "$out" ]; then
      first=1
      printf '%s\n' "$out" | while IFS= read -r line; do
        if [ "$first" = "1" ]; then
          first=0
        else
          printf ','
        fi
        printf '"%s"' "$(json_escape "$line")"
      done
    fi
  fi
  printf ']}\n'
}

list_append_json_string() {
  current=$1
  item=$2
  if [ -n "$current" ]; then
    printf '%s,"%s"' "$current" "$(json_escape "$item")"
  else
    printf '"%s"' "$(json_escape "$item")"
  fi
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

package_visible() {
  pkg=$1
  if [ -n "${NEBULA_TEST_PACKAGE_DIR:-}" ]; then
    [ -e "$NEBULA_TEST_PACKAGE_DIR/$pkg" ]
    return
  fi
  cmd package path "$pkg" >/dev/null 2>&1
}

nubia_package_json() {
  key=$1
  pkg=$2
  role=$3
  visible=0
  if package_visible "$pkg"; then visible=1; fi
  printf '"%s":{"package":%s,"visible":%s,"role":%s}' \
    "$key" \
    "$(json_string "$pkg")" \
    "$(json_bool "$visible")" \
    "$(json_string "$role")"
}

nubia_toolkit_status_json() {
  vector_dir="$MODULES_ROOT/zygisk_vector"
  vector_installed=0
  vector_enabled=0
  vector_version=unknown
  vector_version_code=0
  if [ -d "$vector_dir" ]; then
    vector_installed=1
    [ ! -f "$vector_dir/disable" ] && vector_enabled=1
    vector_version=$(module_prop_from_dir "$vector_dir" version)
    vector_version_code=$(module_prop_from_dir "$vector_dir" versionCode)
  fi
  if [ "$vector_installed" != "1" ] && [ -x /data/adb/ksu/bin/ksud ]; then
    vector_entry=$(/data/adb/ksu/bin/ksud module list 2>/dev/null \
      | tr '\n' ' ' \
      | sed 's/[{]/\
{/g' \
      | grep '"id": "zygisk_vector"' \
      | head -n 1)
    if [ -n "$vector_entry" ]; then
      vector_installed=1
      vector_enabled_value=$(printf '%s' "$vector_entry" | sed -n 's/.*"enabled": "\([^"]*\)".*/\1/p')
      [ "$vector_enabled_value" = "true" ] && vector_enabled=1
      vector_version=$(printf '%s' "$vector_entry" | sed -n 's/.*"version": "\([^"]*\)".*/\1/p')
      vector_version_code=$(printf '%s' "$vector_entry" | sed -n 's/.*"versionCode": "\([^"]*\)".*/\1/p')
    fi
  fi
  [ -n "$vector_version" ] || vector_version=unknown
  case "$vector_version_code" in
    ''|*[!0-9]*) vector_version_code=0 ;;
  esac

  printf '{"protocol_version":%s,"command":"nubia toolkit status",' "$PROTOCOL_VERSION"
  printf '"source_project":"NubiaToolkit","source_commit":%s,"license":"Apache-2.0",' \
    "$(json_string "$NUBIA_TOOLKIT_SOURCE_COMMIT")"
  printf '"integration":"ported_status_only","old_toolkit_required":false,'
  printf '"lsposed_required_for_hooks":true,"lsposed_hooks_active":false,'
  printf '"hook_framework":{"id":"zygisk_vector","name":"Vector","installed":%s,"enabled":%s,"version":%s,"version_code":%s,"android_16_compatible":true},' \
    "$(json_bool "$vector_installed")" \
    "$(json_bool "$vector_enabled")" \
    "$(json_string "$vector_version")" \
    "$vector_version_code"
  printf '"packages":{'
  nubia_package_json game_assist "$NUBIA_GAME_ASSIST_PACKAGE" "Game Assist hook target"
  printf ','
  nubia_package_json game_launcher "$NUBIA_GAME_LAUNCHER_PACKAGE" "Game Launcher hook target"
  printf ','
  nubia_package_json toolkit_reference "$NUBIA_TOOLKIT_PACKAGE" "Old standalone LSPosed reference APK"
  printf '},'
  printf '"features":['
  printf '{"id":"no_kill","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"global_game_mode","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"hide_energy_cube","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"small_window_bypass","owner":"future_hook_lane","state":"deferred","mutating":true},'
  printf '{"id":"super_resolution_unlock","owner":"future_hook_or_reimplementation","state":"reference_only","mutating":true},'
  printf '{"id":"watermark_length","owner":"future_hook_lane","state":"deferred","mutating":true}'
  printf '],"errors":[]}\n'
}

waylandie_data_dir() {
  if [ -n "${NEBULA_WAYLANDIE_DATA_DIR:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_DATA_DIR"
  else
    printf '/data/user/0/%s' "$WAYLANDIE_PACKAGE"
  fi
}

waylandie_native_lib_dir() {
  if [ -n "${NEBULA_WAYLANDIE_NATIVE_LIB_DIR:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_NATIVE_LIB_DIR"
    return
  fi
  apk=$(cmd package path "$WAYLANDIE_PACKAGE" 2>/dev/null | sed -n 's/^package://p' | head -n 1)
  if [ -n "$apk" ]; then
    printf '%s/lib/arm64' "${apk%/base.apk}"
  fi
}

waylandie_uid() {
  if [ -n "${NEBULA_WAYLANDIE_UID:-}" ]; then
    printf '%s' "$NEBULA_WAYLANDIE_UID"
    return
  fi
  data_dir=$(waylandie_data_dir)
  if [ -d "$data_dir" ]; then
    uid=$(ls -ldn "$data_dir" 2>/dev/null | awk '{print $3}' | head -n 1)
    case "$uid" in
      ''|*[!0-9]*) ;;
      *) printf '%s' "$uid"; return ;;
    esac
  fi
  cmd package list packages -U "$WAYLANDIE_PACKAGE" 2>/dev/null \
    | sed -n 's/.*uid:\([0-9][0-9]*\).*/\1/p' \
    | head -n 1
}

waylandie_find_wine_host() {
  proton=$1
  for rel in \
    files/lib/wine/aarch64-unix/wine \
    files/bin-arm64/wine \
    files/bin-arm64/wine64 \
    files/bin/wine \
    files/bin/wine64 \
    dist/bin/wine \
    dist/bin/wine64 \
    bin/wine \
    bin/wine64
  do
    if [ -f "$proton/$rel" ]; then
      printf '%s' "$proton/$rel"
      return
    fi
  done
}

waylandie_guest_wine_path() {
  wine_host=$1
  proton=$2
  rel=${wine_host#"$proton"/}
  if [ "$rel" != "$wine_host" ]; then
    printf '/opt/proton/%s' "$rel"
  else
    printf '/opt/proton/files/lib/wine/aarch64-unix/wine'
  fi
}

waylandie_collect() {
  wl_data=$(waylandie_data_dir)
  wl_native=$(waylandie_native_lib_dir)
  wl_uid=$(waylandie_uid)
  wl_rootfs="$wl_data/files/imagefs"
  wl_proton="$wl_data/files/contents/proton/active"
  wl_proot="$wl_native/libproot.so"
  wl_loader="$wl_native/libld_glibc.so"
  wl_wine_host=$(waylandie_find_wine_host "$wl_proton")
  wl_wine_guest=$(waylandie_guest_wine_path "$wl_wine_host" "$wl_proton")
  wl_bridge="$wl_rootfs/usr/local/bin/waylandie-wayland-bridge"
  wl_local_icd="$wl_rootfs/usr/local/etc/vulkan/icd.d/freedreno_icd.json"
  wl_local_vulkan_driver="$wl_rootfs/usr/local/lib/libvulkan_freedreno.so"
  wl_gamescope_sidecar="$wl_data/files/sidecars/$DISPLAY_PHONE_GAMESCOPE_SIDECAR"
  wl_xwayland_sidecar="$wl_data/files/sidecars/$DISPLAY_PHONE_XWAYLAND_SIDECAR"
  wl_gamescope_bin="$wl_gamescope_sidecar/usr/local/bin/gamescope"
  wl_xwayland_bin="$wl_xwayland_sidecar/usr/bin/Xwayland"
  wl_errors=
  wl_display_errors=
  wl_installed=0
  wl_data_present=0
  wl_imagefs_present=0
  wl_native_present=0
  wl_proot_present=0
  wl_loader_present=0
  wl_proton_present=0
  wl_wine_present=0
  wl_uid_present=0
  wl_bridge_present=0
  wl_local_icd_present=0
  wl_local_vulkan_driver_present=0
  wl_gamescope_sidecar_present=0
  wl_xwayland_sidecar_present=0
  wl_ready=1
  wl_display_ready=1

  if package_visible "$WAYLANDIE_PACKAGE"; then
    wl_installed=1
  else
    wl_ready=0
    wl_display_ready=0
    wl_errors=$(list_append_json_string "$wl_errors" "missing:package")
    wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:package")
  fi
  if [ -d "$wl_data" ]; then wl_data_present=1; else wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:app_data"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:app_data"); fi
  if [ -d "$wl_rootfs" ]; then wl_imagefs_present=1; else wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:imagefs"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:imagefs"); fi
  if [ -n "$wl_native" ] && [ -d "$wl_native" ]; then wl_native_present=1; else wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:native_lib_dir"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:native_lib_dir"); fi
  if [ -f "$wl_proot" ]; then wl_proot_present=1; else wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:libproot.so"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:libproot.so"); fi
  if [ -f "$wl_loader" ]; then wl_loader_present=1; else wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:libld_glibc.so"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:libld_glibc.so"); fi
  if [ -x "$wl_bridge" ]; then wl_bridge_present=1; else wl_display_ready=0; wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:waylandie_wayland_bridge"); fi
  if [ -f "$wl_local_icd" ]; then wl_local_icd_present=1; else wl_display_ready=0; wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:local_freedreno_icd"); fi
  if [ -f "$wl_local_vulkan_driver" ]; then wl_local_vulkan_driver_present=1; else wl_display_ready=0; wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:local_freedreno_driver"); fi
  if [ -x "$wl_gamescope_bin" ]; then wl_gamescope_sidecar_present=1; else wl_display_ready=0; wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:gamescope_sidecar"); fi
  if [ -x "$wl_xwayland_bin" ]; then wl_xwayland_sidecar_present=1; else wl_display_ready=0; wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:xwayland_sidecar"); fi
  if [ -d "$wl_proton" ]; then wl_proton_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:proton_active"); fi
  if [ -n "$wl_wine_host" ]; then wl_wine_present=1; else wl_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:proton_wine"); fi
  case "$wl_uid" in
    ''|*[!0-9]*) wl_ready=0; wl_display_ready=0; wl_errors=$(list_append_json_string "$wl_errors" "missing:app_uid"); wl_display_errors=$(list_append_json_string "$wl_display_errors" "missing:app_uid") ;;
    *) wl_uid_present=1 ;;
  esac
}

waylandie_runtime_status_payload() {
  waylandie_collect
  printf '"package":%s,' "$(json_string "$WAYLANDIE_PACKAGE")"
  printf '"source":%s,' "$(json_string "$WAYLANDIE_SOURCE")"
  printf '"method":"root_assisted_proot","safe_mode":%s,' "$(json_bool "$(safe_mode_value)")"
  printf '"installed":%s,"app_uid_known":%s,"data_dir_present":%s,"imagefs_present":%s,' \
    "$(json_bool "$wl_installed")" \
    "$(json_bool "$wl_uid_present")" \
    "$(json_bool "$wl_data_present")" \
    "$(json_bool "$wl_imagefs_present")"
  printf '"native_lib_dir_present":%s,"proot_present":%s,"glibc_loader_present":%s,' \
    "$(json_bool "$wl_native_present")" \
    "$(json_bool "$wl_proot_present")" \
    "$(json_bool "$wl_loader_present")"
  printf '"proton_present":%s,"wine_present":%s,"ready":%s,' \
    "$(json_bool "$wl_proton_present")" \
    "$(json_bool "$wl_wine_present")" \
    "$(json_bool "$wl_ready")"
  printf '"display_ready":%s,"bridge_present":%s,"local_icd_present":%s,"local_vulkan_driver_present":%s,' \
    "$(json_bool "$wl_display_ready")" \
    "$(json_bool "$wl_bridge_present")" \
    "$(json_bool "$wl_local_icd_present")" \
    "$(json_bool "$wl_local_vulkan_driver_present")"
  printf '"gamescope_sidecar_present":%s,"xwayland_sidecar_present":%s,' \
    "$(json_bool "$wl_gamescope_sidecar_present")" \
    "$(json_bool "$wl_xwayland_sidecar_present")"
  printf '"selected_icd":%s,"selected_vulkan_driver":%s,' \
    "$(json_string "$wl_local_icd")" \
    "$(json_string "$wl_local_vulkan_driver")"
  printf '"loader_pin":{"VK_ICD_FILENAMES":%s,"VK_DRIVER_FILES":%s},' \
    "$(json_string "$wl_local_icd")" \
    "$(json_string "$wl_local_icd")"
  printf '"errors":[%s],"display_errors":[%s]' "$wl_errors" "$wl_display_errors"
}

waylandie_runtime_status_json() {
  printf '{"protocol_version":%s,"command":"runtime waylandie status",' "$PROTOCOL_VERSION"
  waylandie_runtime_status_payload
  printf '}\n'
}

waylandie_test_smoke_json() {
  mode=${NEBULA_TEST_WAYLANDIE_SMOKE_RESULT:-}
  case "$mode" in
    pass)
      printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":true,"safe_mode":false,"method":"root_assisted_proot","exit_code":0,"stdout":"Nebula Proton smoke fixture","stderr":"","source":%s,"errors":[]}\n' \
        "$PROTOCOL_VERSION" "$(json_string "$WAYLANDIE_SOURCE")"
      return 0
      ;;
    fail)
      printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"method":"root_assisted_proot","exit_code":1,"stdout":"","stderr":"fixture failure","source":%s,"errors":["fixture_failure"]}\n' \
        "$PROTOCOL_VERSION" "$(json_string "$WAYLANDIE_SOURCE")"
      return 1
      ;;
  esac
  return 99
}

waylandie_runtime_smoke_json() {
  ensure_dirs
  if [ "$(safe_mode_value)" = "1" ]; then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":true,"error":"SAFE_MODE_ACTIVE","errors":["SAFE_MODE_ACTIVE"]}\n' "$PROTOCOL_VERSION"
    return 75
  fi

  if [ -n "${NEBULA_TEST_WAYLANDIE_SMOKE_RESULT:-}" ]; then
    waylandie_test_smoke_json
    return $?
  fi

  waylandie_collect
  if [ "$wl_ready" != "1" ]; then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"error":"RUNTIME_NOT_READY","status":{' "$PROTOCOL_VERSION"
    waylandie_runtime_status_payload
    printf '}}\n'
    return 2
  fi

  script_path="$wl_data/files/nebula-core-proton-smoke-$$.sh"
  out_path="$wl_data/files/nebula-core-proton-smoke-$$.out"
  err_path="$wl_data/files/nebula-core-proton-smoke-$$.err"
  q_script=$(shell_quote "$script_path")
  q_out=$(shell_quote "$out_path")
  q_err=$(shell_quote "$err_path")
  q_rootfs=$(shell_quote "$wl_rootfs")
  q_native=$(shell_quote "$wl_native")
  q_data=$(shell_quote "$wl_data")
  q_proton=$(shell_quote "$wl_proton")
  q_wine_guest=$(shell_quote "$wl_wine_guest")

  if ! su "$wl_uid" -c "cat > $q_script" <<EOF
#!/system/bin/sh
set -u
ROOTFS=$q_rootfs
NATIVE=$q_native
DATA=$q_data
PROTON=$q_proton
WINE_GUEST=$q_wine_guest
PROOT="\$NATIVE/libproot.so"
mkdir -p "\$ROOTFS/home/xuser" "\$ROOTFS/tmp" "\$ROOTFS/android-lib" "\$ROOTFS/opt/proton" "\$DATA/cache/proot-tmp" "\$DATA/cache/proot-l2s"
export HOME=/home/xuser
export USER=xuser
export LOGNAME=xuser
export LANG=en_US.UTF-8
export TERM=xterm-256color
export TMPDIR=/tmp
export XDG_RUNTIME_DIR=/tmp
export WINEPREFIX=/home/xuser/.wine
export WINEDEBUG=-all
export WINE_NO_DUPLICATE_EXPLORER=1
export WINE_GST_NO_GL=1
export WINE_DISABLE_FULLSCREEN_HACK=1
export PROOT_TMP_DIR="\$DATA/cache/proot-tmp"
export PROOT_L2S_DIR="\$DATA/cache/proot-l2s"
export WAYLANDIE_CONTENTS_DIR=/waylandie-contents
export PATH=/waylandie-scripts:/opt/proton/files/bin-arm64:/opt/proton/files/bin:/opt/proton/bin:/usr/local/bin:/usr/bin:/bin
export LD_LIBRARY_PATH=/opt/proton/files/lib/wine/aarch64-unix:/opt/proton/files/lib/wine/aarch64-windows:/opt/proton/files/lib:/opt/proton/lib:/usr/lib:/usr/local/lib:/system/lib64
exec "\$PROOT" -r "\$ROOTFS" -w /home/xuser -b /dev:/dev -b /dev/urandom:/dev/random -b /proc:/proc -b /sys:/sys -b /sdcard:/sdcard -b /storage:/storage:ro -b "\$ROOTFS/home/xuser:/home/xuser" -b "\$ROOTFS/tmp:/tmp" -b "\$DATA/files/contents:/waylandie-contents" -b "\$NATIVE:/android-lib" -b "\$PROTON:/opt/proton" /android-lib/libld_glibc.so --library-path /usr/lib/aarch64-linux-gnu:/lib/aarch64-linux-gnu:/usr/lib:/lib:/usr/local/lib "\$WINE_GUEST" cmd /c ver
EOF
  then
    printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":false,"safe_mode":false,"error":"SCRIPT_WRITE_FAILED","errors":["SCRIPT_WRITE_FAILED"]}\n' "$PROTOCOL_VERSION"
    return 1
  fi

  su "$wl_uid" -c "chmod 700 $q_script" >/dev/null 2>&1 || true
  if command -v timeout >/dev/null 2>&1; then
    su "$wl_uid" -c "timeout 25 sh $q_script > $q_out 2> $q_err"
    rc=$?
  else
    su "$wl_uid" -c "sh $q_script > $q_out 2> $q_err"
    rc=$?
  fi
  stdout=$(head -c 4096 "$out_path" 2>/dev/null || true)
  stderr=$(head -c 4096 "$err_path" 2>/dev/null || true)
  su "$wl_uid" -c "rm -f $q_script $q_out $q_err" >/dev/null 2>&1 || rm -f "$script_path" "$out_path" "$err_path"

  errors=
  if [ "$rc" -ne 0 ]; then
    errors=$(list_append_json_string "$errors" "exit_code:$rc")
  fi
  printf '{"protocol_version":%s,"command":"runtime waylandie proton-smoke","ok":%s,"safe_mode":false,"method":"root_assisted_proot","exit_code":%s,"stdout":%s,"stderr":%s,"source":%s,"errors":[%s]}\n' \
    "$PROTOCOL_VERSION" \
    "$(json_bool "$([ "$rc" -eq 0 ] && printf 1 || printf 0)")" \
    "$rc" \
    "$(json_output_string "$stdout")" \
    "$(json_output_string "$stderr")" \
    "$(json_string "$WAYLANDIE_SOURCE")" \
    "$errors"
  [ "$rc" -eq 0 ]
}

fixed_device_path() {
  path=$1
  root=${NEBULA_TEST_DEVICE_ROOT:-}
  if [ -n "$root" ]; then
    printf '%s%s' "$root" "$path"
  else
    printf '%s' "$path"
  fi
}

fixed_path_exists() {
  resolved_path=$(fixed_device_path "$1")
  [ -e "$resolved_path" ]
}

fixed_path_executable() {
  resolved_path=$(fixed_device_path "$1")
  [ -x "$resolved_path" ]
}

fixed_path_socket() {
  resolved_path=$(fixed_device_path "$1")
  [ -S "$resolved_path" ]
}

fixed_path_socket_world_writable() {
  resolved_path=$(fixed_device_path "$1")
  [ -S "$resolved_path" ] || return 1
  perms=$(ls -ld "$resolved_path" 2>/dev/null | sed -n 's/^\(..........\).*/\1/p')
  case "$perms" in
    ????????w*) return 0 ;;
    *) return 1 ;;
  esac
}

fixed_path_dir() {
  resolved_path=$(fixed_device_path "$1")
  [ -d "$resolved_path" ]
}

fixed_file_contains() {
  resolved_path=$(fixed_device_path "$1")
  pattern=$2
  [ -f "$resolved_path" ] && grep -F "$pattern" "$resolved_path" >/dev/null 2>&1
}

fixed_file_value() {
  resolved_path=$(fixed_device_path "$1")
  key=$2
  if [ -f "$resolved_path" ]; then
    sed -n "s/^$key=//p" "$resolved_path" | head -n 1
  fi
}

anland_config_for_container() {
  printf '%s/%s/container.config' "$ANLAND_CONTAINERS_DIR" "$1"
}

anland_env_for_container() {
  printf '%s/%s/anland.env' "$ANLAND_CONTAINERS_DIR" "$1"
}

anland_safe_container_name() {
  case "$1" in
    ''|*/*|*..*|*[!A-Za-z0-9._-]*) return 1 ;;
    *) return 0 ;;
  esac
}

anland_pid_from_real_file() {
  pid=$(sed -n '1{s/[^0-9].*$//;p;q}' "$1" 2>/dev/null)
  case "$pid" in
    ''|*[!0-9]*) ;;
    *) printf '%s' "$pid" ;;
  esac
}

anland_pid_running() {
  pid=$1
  case "$pid" in
    ''|*[!0-9]*) return 1 ;;
  esac
  fixed_path_exists "/proc/$pid"
}

anland_collect_active_pidfiles() {
  anland_active_name=
  anland_active_pidfile=
  anland_active_pid=
  anland_active_ambiguous=0
  dir=$(fixed_device_path "$ANLAND_PIDS_DIR")
  [ -d "$dir" ] || return 0
  for pid_file in "$dir"/*.pid "$dir"/*.init; do
    [ -s "$pid_file" ] || continue
    base=${pid_file##*/}
    suffix=${base##*.}
    name=${base%."$suffix"}
    anland_safe_container_name "$name" || continue
	    fixed_path_exists "$(anland_config_for_container "$name")" || continue
	    canonical_pidfile="$ANLAND_PIDS_DIR/$name.$suffix"
	    pid=$(anland_pid_from_real_file "$pid_file")
	    anland_pid_running "$pid" || continue
	    if [ -z "$anland_active_name" ]; then
      anland_active_name=$name
      anland_active_pidfile=$canonical_pidfile
      anland_active_pid=$pid
    elif [ "$anland_active_name" = "$name" ]; then
      case "$anland_active_pidfile" in
        *.init)
          if [ "$suffix" = "pid" ]; then
            anland_active_pidfile=$canonical_pidfile
            anland_active_pid=$pid
          fi
          ;;
      esac
    else
      anland_active_ambiguous=1
    fi
  done
}

anland_pidfile_for_container() {
  container=$1
  for suffix in pid init; do
    candidate_path="$ANLAND_PIDS_DIR/$container.$suffix"
    real_path=$(fixed_device_path "$candidate_path")
    if [ -s "$real_path" ]; then
      pid=$(anland_pid_from_real_file "$real_path")
      if anland_pid_running "$pid"; then
        printf '%s' "$candidate_path"
        return
      fi
    fi
  done
}

anland_pid_for_canonical_file() {
  path=$1
  [ -n "$path" ] || return
  anland_pid_from_real_file "$(fixed_device_path "$path")"
}

anland_env_from_config() {
  config=$1
  container=$2
  configured_env=$(fixed_file_value "$config" env_file)
  case "$configured_env" in
    "$ANLAND_CONTAINERS_DIR/$container"/*)
      case "$configured_env" in
        *..*) ;;
        *) printf '%s' "$configured_env"; return ;;
      esac
      ;;
  esac
  anland_env_for_container "$container"
}

anland_rootfs_from_config() {
  config=$1
  container=$2
  rootfs=$(fixed_file_value "$config" rootfs_path)
  if [ -n "$rootfs" ]; then
    printf '%s' "$rootfs"
  else
    printf '%s/%s/rootfs' "$ANLAND_CONTAINERS_DIR" "$container"
  fi
}

anland_rootfs_mode_for_path() {
  path=$1
  case "$path" in
    *.img|*.img.raw|*.qcow2) printf '%s' image ;;
    *) printf '%s' directory ;;
  esac
}

anland_path_belongs_to_container() {
  container=$1
  path=$2
  case "$container:$path" in
    :*) return 1 ;;
    *:"$ANLAND_CONTAINERS_DIR/$container"/*) return 0 ;;
    *) return 1 ;;
  esac
}

anland_rootfs_has_producer() {
  rootfs=$1
  [ -n "$rootfs" ] || return 1
  [ "$(anland_rootfs_mode_for_path "$rootfs")" = "directory" ] || return 1
  real_rootfs=$(fixed_device_path "$rootfs")
  [ -d "$real_rootfs" ] || return 1
  [ -x "$real_rootfs/usr/local/bin/startanland-kde.sh" ] && return 0
  [ -x "$real_rootfs/usr/bin/kwin_wayland" ] && return 0
  [ -x "$real_rootfs/usr/bin/weston" ] && return 0
  find "$real_rootfs/usr" -maxdepth 6 -iname '*anland*' -print -quit 2>/dev/null | grep . >/dev/null 2>&1
}

anland_active_image_has_producer() {
  container=$1
  [ -n "$container" ] || return 1
  [ "$anland_container_active" = "1" ] || return 1
  bin=$(fixed_device_path "$ANLAND_DROIDSPACES_BIN")
  [ -x "$bin" ] || return 1
  if command -v timeout >/dev/null 2>&1; then
    timeout 8 "$bin" --name="$container" run sh -lc 'test -x /usr/local/bin/startanland-kde.sh' >/dev/null 2>&1
  else
    "$bin" --name="$container" run sh -lc 'test -x /usr/local/bin/startanland-kde.sh' >/dev/null 2>&1
  fi
}

anland_required_env_json() {
  printf '["ANLAND=1","ANLAND_SOCKET=%s","ANLAND_DRM_DEVICE=%s","WAYLAND_DISPLAY=wayland-0","XDG_SESSION_TYPE=wayland","QT_QPA_PLATFORM=wayland","MESA_LOADER_DRIVER_OVERRIDE=kgsl","GALLIUM_DRIVER=kgsl","FD_FORCE_KGSL=1","TU_DEBUG=noconform"]' \
    "$(json_escape "$ANLAND_SOCKET_GUEST")" \
    "$(json_escape "$ANLAND_RENDER_NODE")"
}

anland_required_config_json() {
  printf '["enable_termux_x11=0","enable_hw_access=1","enable_gpu_mode=1","selinux_permissive=1","privileged=nocaps,noseccomp","env_file=<container>/anland.env","bind_mounts=%s:%s"]' \
    "$(json_escape "$ANLAND_SOCKET_HOST")" \
    "$(json_escape "$ANLAND_SOCKET_GUEST")"
}

anland_recommended_start_command() {
  printf '%s --name=%s --rootfs-img=%s --net=host --hw-access --gpu --selinux-permissive --privileged=nocaps,noseccomp --env=%s --bind=%s:%s start' \
    "$ANLAND_DROIDSPACES_BIN" \
    "$ANLAND_RECOMMENDED_CONTAINER" \
    "$ANLAND_RECOMMENDED_ROOTFS_IMG" \
    "$ANLAND_RECOMMENDED_ENV" \
    "$ANLAND_SOCKET_HOST" \
	    "$ANLAND_SOCKET_GUEST"
}

anland_recommended_create_command() {
  printf '%s --rootfs-arc=%s --rootfs-img=%s --size=%s create' \
    "$ANLAND_DROIDSPACES_BIN" \
    "$ANLAND_RECOMMENDED_ROOTFS_ARCHIVE" \
    "$ANLAND_RECOMMENDED_ROOTFS_IMG" \
    "$ANLAND_RECOMMENDED_ROOTFS_SIZE"
}

anland_recommended_producer_verify_command() {
  printf "%s --name=%s run sh -lc 'test -x /usr/local/bin/startanland-kde.sh'" \
    "$ANLAND_DROIDSPACES_BIN" \
    "$ANLAND_RECOMMENDED_CONTAINER"
}

anland_recommended_producer_run_command() {
  printf "%s --name=%s run sh -lc 'nohup /usr/local/bin/startanland-kde.sh >/tmp/anland-kde.log 2>&1 &'" \
    "$ANLAND_DROIDSPACES_BIN" \
    "$ANLAND_RECOMMENDED_CONTAINER"
}

anland_selected_restart_command() {
  [ -n "$anland_selected_container" ] || return 0
  printf '%s --name=%s --env=%s --bind=%s:%s restart' \
    "$ANLAND_DROIDSPACES_BIN" \
    "$anland_selected_container" \
    "$anland_selected_env" \
    "$ANLAND_SOCKET_HOST" \
    "$ANLAND_SOCKET_GUEST"
}

anland_setup_commands_json() {
  selected_restart=$(anland_selected_restart_command)
  printf '{"recommended_container":%s,' "$(json_string "$ANLAND_RECOMMENDED_CONTAINER")"
  printf '"recommended_rootfs_archive":%s,' "$(json_string "$ANLAND_RECOMMENDED_ROOTFS_ARCHIVE")"
  printf '"recommended_rootfs_img":%s,' "$(json_string "$ANLAND_RECOMMENDED_ROOTFS_IMG")"
  printf '"recommended_rootfs_size":%s,' "$(json_string "$ANLAND_RECOMMENDED_ROOTFS_SIZE")"
  printf '"recommended_env_file":%s,' "$(json_string "$ANLAND_RECOMMENDED_ENV")"
  printf '"droidspaces_create_rootfs_img":%s,' "$(json_string "$(anland_recommended_create_command)")"
  printf '"droidspaces_start_recommended":%s,' "$(json_string "$(anland_recommended_start_command)")"
  printf '"droidspaces_restart_selected":%s,' "$(json_string "$selected_restart")"
  printf '"daemon_module_install":"ksud module install /data/local/tmp/anland-2.0-virtual-drm-daemon.zip",'
  printf '"consumer_apk_package":%s,' "$(json_string "$ANLAND_CONSUMER_PACKAGE")"
  printf '"producer_start_command":"startanland-kde.sh",'
  printf '"producer_verify_command":%s,' "$(json_string "$(anland_recommended_producer_verify_command)")"
  printf '"producer_run_command":%s,' "$(json_string "$(anland_recommended_producer_run_command)")"
  printf '"repo_build_profile":"Droidspaces-rootfs-KDE-builder Ubuntu26 with KDE auto-start and anland_kde enabled"}'
}

anland_collect() {
  anland_errors=
  anland_collect_active_pidfiles
  anland_selected_container=$ANLAND_DEFAULT_CONTAINER
  anland_selection_source=default_fallback
  anland_selected_pidfile=
  anland_container_pid=
  anland_container_active=0
  anland_selection_ambiguous=0
  anland_selection_invalid=0

  if [ -n "${NEBULA_ANLAND_CONTAINER:-}" ]; then
    if anland_safe_container_name "$NEBULA_ANLAND_CONTAINER"; then
      anland_selected_container=$NEBULA_ANLAND_CONTAINER
      anland_selection_source=env_override
    else
      anland_selected_container=
      anland_selection_source=invalid_env_override
      anland_selection_invalid=1
      anland_errors=$(list_append_json_string "$anland_errors" "invalid:env_override_container")
    fi
  elif [ "$anland_active_ambiguous" = "1" ]; then
    anland_selection_source=ambiguous_active_pidfiles
    anland_selection_ambiguous=1
    anland_errors=$(list_append_json_string "$anland_errors" "ambiguous:active_containers")
    if [ -n "$anland_active_name" ]; then
      anland_selected_container=$anland_active_name
    fi
  elif [ -n "$anland_active_name" ]; then
    anland_selected_container=$anland_active_name
    anland_selection_source=active_pidfile
  fi

  anland_selected_pidfile=$(anland_pidfile_for_container "$anland_selected_container")
  if [ -n "$anland_selected_pidfile" ]; then
    anland_container_active=1
    anland_container_pid=$(anland_pid_for_canonical_file "$anland_selected_pidfile")
  fi
  anland_selected_config=
  anland_selected_env=
  anland_selected_rootfs=
  anland_selected_rootfs_mode=missing
  if [ -n "$anland_selected_container" ]; then
    anland_selected_config=$(anland_config_for_container "$anland_selected_container")
    anland_selected_env=$(anland_env_from_config "$anland_selected_config" "$anland_selected_container")
    anland_selected_rootfs=$(anland_rootfs_from_config "$anland_selected_config" "$anland_selected_container")
    anland_selected_rootfs_mode=$(anland_rootfs_mode_for_path "$anland_selected_rootfs")
  fi
  anland_bin=0
  anland_config=0
  anland_env=0
  anland_socket=0
  anland_socket_writable=0
  anland_render=0
  anland_rootfs=0
  anland_rootfs_image=0
  anland_config_env=0
  anland_config_bind=0
  anland_env_socket=0
  anland_env_kgsl=0
  anland_producer=0
  anland_rootfs_allowed=0
  anland_runtime_ready=0
  anland_ready=0
  anland_status=missing

  fixed_path_executable "$ANLAND_DROIDSPACES_BIN" && anland_bin=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:droidspaces_binary")
  [ -n "$anland_selected_config" ] && fixed_path_exists "$anland_selected_config" && anland_config=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:container_config")
  [ -n "$anland_selected_env" ] && fixed_path_exists "$anland_selected_env" && anland_env=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:anland_env")
  if fixed_path_socket "$ANLAND_SOCKET_HOST"; then
    anland_socket=1
    fixed_path_socket_world_writable "$ANLAND_SOCKET_HOST" && anland_socket_writable=1 || anland_errors=$(list_append_json_string "$anland_errors" "blocked:display_daemon_socket_not_app_writable")
  else
    anland_errors=$(list_append_json_string "$anland_errors" "missing:display_daemon_socket")
  fi
  fixed_path_exists "$ANLAND_RENDER_NODE" && anland_render=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:render_node")
  if anland_path_belongs_to_container "$anland_selected_container" "$anland_selected_rootfs"; then
    anland_rootfs_allowed=1
    if [ "$anland_selected_rootfs_mode" = "image" ]; then
      anland_rootfs_image=1
    fi
  elif [ -n "$anland_selected_rootfs" ]; then
    anland_errors=$(list_append_json_string "$anland_errors" "invalid:rootfs_path_outside_container")
  fi
  [ "$anland_rootfs_allowed" = "1" ] && fixed_path_exists "$anland_selected_rootfs" && anland_rootfs=1 || anland_errors=$(list_append_json_string "$anland_errors" "missing:rootfs_path")
  [ -n "$anland_selected_config" ] && fixed_file_contains "$anland_selected_config" "env_file=$anland_selected_env" && anland_config_env=1 || true
  [ -n "$anland_selected_config" ] && fixed_file_contains "$anland_selected_config" "$ANLAND_SOCKET_HOST:$ANLAND_SOCKET_GUEST" && anland_config_bind=1 || true
  [ -n "$anland_selected_env" ] && fixed_file_contains "$anland_selected_env" "ANLAND_SOCKET=$ANLAND_SOCKET_GUEST" && anland_env_socket=1 || true
  [ -n "$anland_selected_env" ] && fixed_file_contains "$anland_selected_env" "MESA_LOADER_DRIVER_OVERRIDE=kgsl" && anland_env_kgsl=1 || true
  if anland_rootfs_has_producer "$anland_selected_rootfs"; then
    anland_producer=1
  elif [ "$anland_rootfs_image" = "1" ] && anland_active_image_has_producer "$anland_selected_container"; then
    anland_producer=1
  elif [ "$anland_rootfs_image" = "1" ] && [ "$anland_rootfs" = "1" ]; then
    anland_errors=$(list_append_json_string "$anland_errors" "unknown:anland_producer_inside_rootfs_image_run_verify_required")
  else
    anland_errors=$(list_append_json_string "$anland_errors" "missing:anland_producer")
  fi

  if [ "$anland_selection_ambiguous" = "1" ] || [ "$anland_selection_invalid" = "1" ]; then
    anland_status=partial
  elif [ "$anland_bin" = "1" ] && [ "$anland_config" = "1" ] && [ "$anland_rootfs" = "1" ] && [ "$anland_render" = "1" ]; then
    anland_status=container_runtime_ready
    anland_runtime_ready=1
  elif [ "$anland_bin" = "1" ] || [ "$anland_config" = "1" ] || [ "$anland_env" = "1" ]; then
    anland_status=partial
  fi

  if [ "$anland_runtime_ready" = "1" ] \
    && [ "$anland_env" = "1" ] \
    && [ "$anland_socket" = "1" ] \
    && [ "$anland_socket_writable" = "1" ] \
    && [ "$anland_config_env" = "1" ] \
    && [ "$anland_config_bind" = "1" ] \
    && [ "$anland_env_socket" = "1" ] \
    && [ "$anland_env_kgsl" = "1" ] \
    && [ "$anland_producer" = "1" ]; then
    anland_status=preflight_ready
    anland_ready=1
  fi
}

display_bool_source() {
  bool_value=$1
  true_label=$2
  false_label=$3
  if [ "$bool_value" = "1" ]; then
    printf '%s' "$true_label"
  else
    printf '%s' "$false_label"
  fi
}

display_phone_preflight_payload() {
  waylandie_collect
  phone_status=missing
  active_blocker=WAYLAND_DISPLAY_PREFLIGHT_INCOMPLETE
  canonical_blocker=WAYLAND_DISPLAY_PREFLIGHT_INCOMPLETE
  phone_container_status=missing
  phone_display_status=display_missing
  phone_runtime_status=runtime_missing
  if [ "$wl_display_ready" = "1" ]; then
    phone_status=wayland_display_pass
    active_blocker=NONE_WAYLAND_DISPLAY
    canonical_blocker=NONE_WAYLAND_DISPLAY
    phone_display_status=display_proven
  elif [ "$wl_installed" = "1" ]; then
    phone_status=partial
  fi
  if [ "$wl_ready" = "1" ]; then
    phone_container_status=ready
    phone_runtime_status=runtime_ready
  elif [ "$wl_installed" = "1" ]; then
    phone_container_status=partial
  fi
  printf '"id":"phone_app_bridge",'
  printf '"method_id":"phone_app_bridge",'
  printf '"title":"Phone / App Mode",'
  printf '"status":%s,' "$(json_string "$phone_status")"
  printf '"available":%s,' "$(json_bool "$wl_display_ready")"
  printf '"container_ref":"waylandie_app_imagefs",'
  printf '"container_kind":"app_proot",'
  printf '"container_status":%s,' "$(json_string "$phone_container_status")"
  printf '"display_status":%s,' "$(json_string "$phone_display_status")"
  printf '"runtime_status":%s,' "$(json_string "$phone_runtime_status")"
  printf '"start_command_status":"not_available",'
  printf '"requirement_status":"display_requirements_met",'
  printf '"missing_requirements":["game_client_runtime_proof_not_promoted_39bit_va"],'
  printf '"mutating":false,'
  printf '"launch_command_available":false,'
  printf '"active_blocker":%s,' "$(json_string "$active_blocker")"
  printf '"canonical_blocker":%s,' "$(json_string "$canonical_blocker")"
  printf '"current_endpoint":"SurfaceControl Vulkan native dmabuf-present via WayLandIE bridge, Gamescope, and Xwayland",'
  printf '"proof_classification":%s,' "$(json_string "$DISPLAY_PHONE_PROOF_CLASSIFICATION")"
  printf '"proof_result":%s,' "$(json_string "$DISPLAY_PHONE_PROOF_RESULT")"
  printf '"proof_metrics":{"summary_commits":7189,"summary_failures":0,"vkGetMemoryFdKHR_failures":0,"real_buffer_commits":2,"xwayland_ready":true,"gamescope_exit":0,"bridge_exit":0},'
  printf '"lead_status":"display_proven",'
  printf '"proven_trick":"gamescope_force_composition_full_size_ar24_parent_xdg_dmabuf",'
  printf '"next_reversa_action":"bounded_game_client_runtime_before_steam",'
  printf '"steam_allowed":false,'
  printf '"kernel_va_bits_constraint":39,'
  printf '"kernel_va_bits_evidence":"live_proc_config_gz",'
  printf '"runtime_blocker":"GAME_CLIENT_RUNTIME_NOT_PROMOTED_39BIT_VA",'
  printf '"runtime_blocker_detail":%s,' "$(json_string "$DISPLAY_PHONE_RUNTIME_BLOCKER")"
  printf '"runtime_constraint":%s,' "$(json_string "$DISPLAY_PHONE_RUNTIME_CONSTRAINT")"
  printf '"sidecar_source":%s,' "$(json_string "$DISPLAY_PHONE_PROMOTION_SOURCE")"
  printf '"gamescope_sidecar":%s,' "$(json_string "$DISPLAY_PHONE_GAMESCOPE_SIDECAR")"
  printf '"xwayland_sidecar":%s,' "$(json_string "$DISPLAY_PHONE_XWAYLAND_SIDECAR")"
  printf '"selected_icd":%s,' "$(json_string "$wl_local_icd")"
  printf '"selected_vulkan_driver":%s,' "$(json_string "$wl_local_vulkan_driver")"
  printf '"loader_pin":{"VK_ICD_FILENAMES":%s,"VK_DRIVER_FILES":%s},' \
    "$(json_string "$wl_local_icd")" \
    "$(json_string "$wl_local_icd")"
  printf '"source":%s,' "$(json_string "$DISPLAY_PHONE_SOURCE")"
  printf '"checks":{"display_ready":%s,"runtime_ready":%s,"package_installed":%s,"imagefs_present":%s,"bridge_present":%s,"local_icd_present":%s,"local_vulkan_driver_present":%s,"gamescope_sidecar_present":%s,"xwayland_sidecar_present":%s,"proton_present":%s,"wine_present":%s},' \
    "$(json_bool "$wl_display_ready")" \
    "$(json_bool "$wl_ready")" \
    "$(json_bool "$wl_installed")" \
    "$(json_bool "$wl_imagefs_present")" \
    "$(json_bool "$wl_bridge_present")" \
    "$(json_bool "$wl_local_icd_present")" \
    "$(json_bool "$wl_local_vulkan_driver_present")" \
    "$(json_bool "$wl_gamescope_sidecar_present")" \
    "$(json_bool "$wl_xwayland_sidecar_present")" \
    "$(json_bool "$wl_proton_present")" \
    "$(json_bool "$wl_wine_present")"
  printf '"errors":[%s],"runtime_errors":[%s]' "$wl_display_errors" "$wl_errors"
