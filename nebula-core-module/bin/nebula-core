  printf '"active_blocker":"RGB_GLX_VISUAL_FBCONFIG_EXPOSURE",'
  printf '"canonical_blocker":"RGB_GLX_VISUAL_FBCONFIG_EXPOSURE",'
  printf '"current_endpoint":"Xwayland launches",'
