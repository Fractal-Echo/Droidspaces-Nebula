#!/system/bin/sh
set -u

PROTOCOL_VERSION=1
MODULE_ID=nebula_core
DATA_DIR=${NEBULA_DATA_DIR:-/data/adb/nebula}
LOG_DIR="$DATA_DIR/logs"
STATE_DIR="$DATA_DIR/state"
LOG_FILE="$LOG_DIR/nebula-core.log"
PROFILE_FILE="$STATE_DIR/profile"
SAFE_MODE_FILE="$DATA_DIR/safe_mode"
SCRIPT_DIR=${0%/*}
MODDIR=${NEBULA_MODULE_DIR:-${SCRIPT_DIR%/*}}
MODULE_PROP=${NEBULA_MODULE_PROP:-$MODDIR/module.prop}
REDMAGIC_SOURCE_COMMIT=e94d36e8204c228c6e8781157dea22946cf715e3
REDMAGIC_SOURCE_FAN="Redmagic-Control-Center HardwareController.kt:25-28,48-77@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_THERMAL="Redmagic-Control-Center HardwareController.kt:275-288@$REDMAGIC_SOURCE_COMMIT"
REDMAGIC_SOURCE_IDENTITY="Redmagic-Control-Center DeviceCapabilityScanner.kt:33-36@$REDMAGIC_SOURCE_COMMIT"

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$STATE_DIR"
  if [ ! -s "$PROFILE_FILE" ]; then
    printf '%s\n' safe > "$PROFILE_FILE"
  fi
}

prop_value() {
  key=$1
  if [ -f "$MODULE_PROP" ]; then
    sed -n "s/^$key=//p" "$MODULE_PROP" | head -n 1
  fi
}

module_version() {
  value=$(prop_value version)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' unknown
  fi
}

module_version_code() {
  value=$(prop_value versionCode)
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' 0
  fi
}

git_commit() {
  value=${NEBULA_GIT_COMMIT:-unknown}
  printf '%s' "$value"
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

json_string_or_null() {
  if [ -n "$1" ]; then
    json_string "$1"
  else
    printf '%s' null
  fi
}

json_int_or_null() {
  case "$1" in
    ''|*[!0-9-]*) printf '%s' null ;;
    *) printf '%s' "$1" ;;
  esac
}

json_bool() {
  if [ "$1" = "1" ]; then
    printf '%s' true
  else
    printf '%s' false
  fi
}

safe_mode_value() {
  if [ -f "$SAFE_MODE_FILE" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

current_profile() {
  if [ -s "$PROFILE_FILE" ]; then
    value=$(head -n 1 "$PROFILE_FILE")
  else
    value=safe
  fi
  case "$value" in
    safe|phone|dock|compatibility) printf '%s' "$value" ;;
    *) printf '%s' safe ;;
  esac
}

daemon_running_value() {
  pid_file="$STATE_DIR/service.pid"
  if [ -s "$pid_file" ]; then
    pid=$(head -n 1 "$pid_file")
    case "$pid" in
      *[!0-9]*|'') printf '%s' 0 ;;
      *)
        if kill -0 "$pid" 2>/dev/null; then
          printf '%s' 1
        else
          printf '%s' 0
        fi
        ;;
    esac
  else
    printf '%s' 0
  fi
}

service_status() {
  if [ "$(daemon_running_value)" = "1" ]; then
    printf '%s' running
  elif [ -d "$STATE_DIR" ]; then
    printf '%s' state_ready
  else
    printf '%s' missing_state
  fi
}

log_command() {
  ensure_dirs
  printf '%s command=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$1" >> "$LOG_FILE"
}

status_json() {
  ensure_dirs
  safe=$(safe_mode_value)
  daemon=$(daemon_running_value)
  profile=$(current_profile)
  printf '{"protocol_version":%s,"module_id":"%s","module_version":"%s","module_version_code":%s,"git_commit":"%s","safe_mode":%s,"profile":"%s","daemon_running":%s,"service_status":"%s"}\n' \
    "$PROTOCOL_VERSION" \
    "$MODULE_ID" \
    "$(json_escape "$(module_version)")" \
    "$(module_version_code)" \
    "$(json_escape "$(git_commit)")" \
    "$(json_bool "$safe")" \
    "$profile" \
    "$(json_bool "$daemon")" \
    "$(service_status)"
}

capabilities_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"capabilities":[' "$PROTOCOL_VERSION"
  printf '{"id":"profile.safe","title":"Recovery / Safe Mode","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.phone","title":"Phone / App Mode","status":"available_no_launch","mutating":false,"source":"nebula-core"},'
  printf '{"id":"profile.dock","title":"Dock Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"profile.compatibility","title":"Compatibility Mode","status":"BLOCKED_NOT_READY","mutating":true,"source":"nebula-core"},'
  printf '{"id":"safe-mode","title":"Safe mode","status":"available","mutating":true,"source":"nebula-core"},'
  printf '{"id":"logs.tail","title":"Command logs","status":"available","mutating":false,"source":"nebula-core"},'
  printf '{"id":"redmagic.probe","title":"RM11 Pro read-only RedMagic probe","status":"available_read_only","mutating":false,"source":"%s"}' "$(json_escape "$REDMAGIC_SOURCE_FAN")"
  printf ']}\n'
}

profile_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"profile":"%s","safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(current_profile)" "$(json_bool "$(safe_mode_value)")"
}

blocked_profile_json() {
  profile=$1
  printf '{"protocol_version":%s,"ok":false,"profile":"%s","error":"BLOCKED_NOT_READY"}\n' \
    "$PROTOCOL_VERSION" "$profile"
}

profile_set() {
  ensure_dirs
  profile=$1
  case "$profile" in
    safe)
      touch "$SAFE_MODE_FILE"
      printf '%s\n' safe > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"safe","safe_mode":true}\n' "$PROTOCOL_VERSION"
      ;;
    phone)
      rm -f "$SAFE_MODE_FILE"
      printf '%s\n' phone > "$PROFILE_FILE"
      printf '{"protocol_version":%s,"ok":true,"profile":"phone","safe_mode":false,"launch_started":false}\n' "$PROTOCOL_VERSION"
      ;;
    dock|compatibility)
      blocked_profile_json "$profile"
      return 75
      ;;
    *)
      printf '{"protocol_version":%s,"ok":false,"error":"UNKNOWN_PROFILE"}\n' "$PROTOCOL_VERSION"
      return 2
      ;;
  esac
}

safe_mode_get_json() {
  ensure_dirs
  printf '{"protocol_version":%s,"safe_mode":%s}\n' \
    "$PROTOCOL_VERSION" "$(json_bool "$(safe_mode_value)")"
}

safe_mode_enable() {
  ensure_dirs
  touch "$SAFE_MODE_FILE"
  printf '%s\n' safe > "$PROFILE_FILE"
  printf '{"protocol_version":%s,"ok":true,"safe_mode":true,"profile":"safe"}\n' "$PROTOCOL_VERSION"
}

logs_tail_json() {
  ensure_dirs
  lines=$1
  case "$lines" in
    ''|*[!0-9]*) lines=50 ;;
  esac
  if [ "$lines" -lt 1 ]; then lines=1; fi
  if [ "$lines" -gt 500 ]; then lines=500; fi
  printf '{"protocol_version":%s,"lines":[' "$PROTOCOL_VERSION"
  if [ -f "$LOG_FILE" ]; then
    out=$(tail -n "$lines" "$LOG_FILE" 2>/dev/null || true)
    if [ -n "$out" ]; then
      first=1
      printf '%s\n' "$out" | while IFS= read -r line; do
        if [ "$first" = "1" ]; then
          first=0
        else
          printf ','
        fi
        printf '"%s"' "$(json_escape "$line")"
      done
    fi
  fi
  printf ']}\n'
}

list_append_json_string() {
  current=$1
  item=$2
  if [ -n "$current" ]; then
    printf '%s,"%s"' "$current" "$(json_escape "$item")"
  else
    printf '"%s"' "$(json_escape "$item")"
  fi
}

is_test_denied_path() {
  path=$1
  deny_list=${NEBULA_TEST_DENY_PATHS:-}
  old_ifs=$IFS
  IFS=:
  for denied in $deny_list; do
    if [ "$denied" = "$path" ]; then
      IFS=$old_ifs
      return 0
    fi
  done
  IFS=$old_ifs
  return 1
}

resolve_read_path() {
  path=$1
  root=${NEBULA_SYSROOT:-}
  if [ -n "$root" ]; then
    printf '%s%s' "$root" "$path"
  else
    printf '%s' "$path"
  fi
}

is_allowlisted_read_path() {
  case "$1" in
    /sys/kernel/fan/fan_enable|\
    /sys/kernel/fan/fan_speed_level|\
    /sys/kernel/fan/fan_speed_count|\
    /sys/class/thermal/thermal_zone0/temp|\
    /sys/class/thermal/thermal_zone1/temp|\
    /sys/class/thermal/thermal_zone2/temp|\
    /sys/class/thermal/thermal_zone3/temp|\
    /sys/devices/virtual/thermal/thermal_zone0/temp|\
    /sys/devices/virtual/thermal/thermal_zone1/temp|\
    /sys/devices/virtual/thermal/thermal_zone2/temp|\
    /sys/devices/virtual/thermal/thermal_zone3/temp)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_allowlisted_file() {
  path=$1
  if ! is_allowlisted_read_path "$path"; then
    return 8
  fi
  actual=$(resolve_read_path "$path")
  if [ ! -e "$actual" ]; then
    return 2
  fi
  if is_test_denied_path "$path"; then
    return 3
  fi
  if [ ! -r "$actual" ]; then
    return 3
  fi
  head -n 1 "$actual" 2>/dev/null | cut -c 1-128
}

path_present() {
  path=$1
  actual=$(resolve_read_path "$path")
  [ -e "$actual" ]
}

read_prop() {
  name=$1
  case "$name" in
    ro.product.manufacturer|ro.product.model|ro.product.product.name|\
    ro.product.device|ro.board.platform|ro.product.marketname|ro.build.fingerprint)
      ;;
    *)
      return 8
      ;;
  esac
  prop_dir=${NEBULA_TEST_PROP_DIR:-}
  if [ -n "$prop_dir" ] && [ -f "$prop_dir/$name" ]; then
    head -n 1 "$prop_dir/$name" 2>/dev/null | cut -c 1-128
    return 0
  fi
  if command -v getprop >/dev/null 2>&1; then
    getprop "$name" 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

read_kernel_release() {
  if [ -n "${NEBULA_TEST_KERNEL:-}" ]; then
    printf '%s' "$NEBULA_TEST_KERNEL"
  else
    uname -r 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

value_or_unknown() {
  if [ -n "$1" ]; then
    printf '%s' "$1"
  else
    printf '%s' unknown
  fi
}

normalize_temp_c() {
  raw=$1
  case "$raw" in
    ''|*[!0-9.-]*) printf '%s' null; return ;;
  esac
  case "$raw" in
    *.*) printf '%s' "$raw"; return ;;
  esac
  if [ "$raw" -gt 1000 ] 2>/dev/null && [ "$raw" -lt 200000 ] 2>/dev/null; then
    whole=$((raw / 1000))
    frac=$((raw % 1000))
    printf '%s.%03d' "$whole" "$frac"
  elif [ "$raw" -gt -100 ] 2>/dev/null && [ "$raw" -lt 200 ] 2>/dev/null; then
    printf '%s' "$raw"
  else
    printf '%s' null
  fi
}

redmagic_probe_json() {
  manufacturer=$(value_or_unknown "$(read_prop ro.product.manufacturer)")
  model=$(value_or_unknown "$(read_prop ro.product.model)")
  product=$(value_or_unknown "$(read_prop ro.product.product.name)")
  device=$(value_or_unknown "$(read_prop ro.product.device)")
  board_platform=$(value_or_unknown "$(read_prop ro.board.platform)")
  kernel=$(value_or_unknown "$(read_kernel_release)")

  fan_errors=
  fan_present=0
  fan_supported=0
  fan_enabled=
  fan_rpm=
  fan_level=

  for fan_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    if path_present "$fan_path"; then
      fan_present=1
      fan_supported=1
    fi
  done

  if [ "$fan_present" = "1" ]; then
    value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    rc=$?
    if [ "$rc" = "0" ]; then
      case "$value" in
        1) fan_enabled=true ;;
        0) fan_enabled=false ;;
        *) fan_enabled= ;;
      esac
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_rpm=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi

    value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    rc=$?
    if [ "$rc" = "0" ]; then
      fan_level=$value
    elif [ "$rc" = "3" ]; then
      fan_errors=$(list_append_json_string "$fan_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    fan_errors=$(list_append_json_string "$fan_errors" "missing:/sys/kernel/fan")
  fi

  thermal_errors=
  thermal_readings=
  thermal_supported=0
  first=1
  for thermal_path in \
    /sys/class/thermal/thermal_zone0/temp \
    /sys/class/thermal/thermal_zone1/temp \
    /sys/class/thermal/thermal_zone2/temp \
    /sys/class/thermal/thermal_zone3/temp \
    /sys/devices/virtual/thermal/thermal_zone0/temp \
    /sys/devices/virtual/thermal/thermal_zone1/temp \
    /sys/devices/virtual/thermal/thermal_zone2/temp \
    /sys/devices/virtual/thermal/thermal_zone3/temp
  do
    if path_present "$thermal_path"; then
      value=$(read_allowlisted_file "$thermal_path")
      rc=$?
      if [ "$rc" = "0" ]; then
        thermal_supported=1
        temp_c=$(normalize_temp_c "$value")
        entry=$(printf '{"path":"%s","raw":"%s","temp_c":%s,"source":"%s"}' \
          "$(json_escape "$thermal_path")" \
          "$(json_escape "$value")" \
          "$temp_c" \
          "$(json_escape "$REDMAGIC_SOURCE_THERMAL")")
        if [ "$first" = "1" ]; then
          thermal_readings=$entry
          first=0
        else
          thermal_readings="$thermal_readings,$entry"
        fi
      elif [ "$rc" = "3" ]; then
        thermal_errors=$(list_append_json_string "$thermal_errors" "permission_denied:$thermal_path")
      fi
    fi
  done
  if [ "$thermal_supported" = "0" ] && [ -z "$thermal_errors" ]; then
    thermal_errors=$(list_append_json_string "$thermal_errors" "missing:thermal_temp_allowlist")
  fi

  if [ -z "$fan_enabled" ]; then
    fan_enabled_json=null
  else
    fan_enabled_json=$fan_enabled
  fi

  printf '{'
  printf '"protocol_version":%s,' "$PROTOCOL_VERSION"
  printf '"command":"redmagic probe",'
  printf '"device":{"manufacturer":%s,"model":%s,"product":%s,"device":%s,"board_platform":%s,"kernel":%s,"source":%s},' \
    "$(json_string "$manufacturer")" \
    "$(json_string "$model")" \
    "$(json_string "$product")" \
    "$(json_string "$device")" \
    "$(json_string "$board_platform")" \
    "$(json_string "$kernel")" \
    "$(json_string "$REDMAGIC_SOURCE_IDENTITY")"
  printf '"fan":{"supported":%s,"present":%s,"enabled":%s,"rpm":%s,"level":%s,"source":%s,"errors":[%s]},' \
    "$(json_bool "$fan_supported")" \
    "$(json_bool "$fan_present")" \
    "$fan_enabled_json" \
    "$(json_int_or_null "$fan_rpm")" \
    "$(json_int_or_null "$fan_level")" \
    "$(json_string "$REDMAGIC_SOURCE_FAN")" \
    "$fan_errors"
  printf '"performance":{"supported":false,"mode":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"display":{"supported":false,"refresh_rate_hz":null,"source":"no_confirmed_read_only_source","errors":["NO_CONFIRMED_READ_ONLY_SOURCE"]},'
  printf '"thermal":{"supported":%s,"readings":[%s],"source":%s,"errors":[%s]},' \
    "$(json_bool "$thermal_supported")" \
    "$thermal_readings" \
    "$(json_string "$REDMAGIC_SOURCE_THERMAL")" \
    "$thermal_errors"
  printf '"redmagic_button":{"supported":false,"configured":false,"reason":"disabled_in_pass_02"}'
  printf '}\n'
}

usage_json() {
  printf '{"protocol_version":%s,"ok":false,"error":"USAGE"}\n' "$PROTOCOL_VERSION"
}

main() {
  cmd=${1:-}
  case "$cmd" in
    status)
      if [ "${2:-}" = "--json" ]; then
        log_command "status"
        status_json
      else
        usage_json
        return 2
      fi
      ;;
    capabilities)
      if [ "${2:-}" = "--json" ]; then
        log_command "capabilities"
        capabilities_json
      else
        usage_json
        return 2
      fi
      ;;
    profile)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "profile_get"
            profile_get_json
          else
            usage_json
            return 2
          fi
          ;;
        set)
          target=${3:-}
          log_command "profile_set_$target"
          profile_set "$target"
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    safe-mode)
      sub=${2:-}
      case "$sub" in
        get)
          if [ "${3:-}" = "--json" ]; then
            log_command "safe_mode_get"
            safe_mode_get_json
          else
            usage_json
            return 2
          fi
          ;;
        enable)
          log_command "safe_mode_enable"
          safe_mode_enable
          ;;
        *)
          usage_json
          return 2
          ;;
      esac
      ;;
    logs)
      if [ "${2:-}" = "tail" ] && [ "${3:-}" = "--lines" ]; then
        log_command "logs_tail"
        logs_tail_json "${4:-50}"
      else
        usage_json
        return 2
      fi
      ;;
    redmagic)
      if [ "${2:-}" = "probe" ] && [ "${3:-}" = "--json" ] && [ -z "${4:-}" ]; then
        redmagic_probe_json
      else
        usage_json
        return 2
      fi
      ;;
    *)
      usage_json
      return 2
      ;;
  esac
}

main "$@"
