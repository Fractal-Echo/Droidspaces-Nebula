    "$(json_string "$DROIDSPACES_NATIVE_METHOD_SOURCE")"
  printf '{"profile_id":"turnip_kgsl_desktop","method_id":"droidspaces_turnip_kgsl","container_name":"rm11-turnip-kgsl","rootfs_mode":"image","rootfs_image":"/data/local/Droidspaces/Containers/rm11-turnip-kgsl/rootfs.img","env_file":"/data/local/Droidspaces/Containers/rm11-turnip-kgsl/turnip-kgsl.env","config_path":"/data/local/Droidspaces/Containers/rm11-turnip-kgsl/container.config","config_lines":["name=rm11-turnip-kgsl","hostname=rm11-turnip-kgsl","rootfs_path=/data/local/Droidspaces/Containers/rm11-turnip-kgsl/rootfs.img","disable_ipv6=0","enable_android_storage=0","enable_termux_x11=1","enable_virgl=0","enable_pulseaudio=1","enable_hw_access=1","enable_gpu_mode=1","selinux_permissive=1","volatile_mode=0","force_cgroupv1=0","block_nested_ns=0","foreground=0","env_file=/data/local/Droidspaces/Containers/rm11-turnip-kgsl/turnip-kgsl.env","net_mode=host","run_at_boot=0","use_sparse_image=1","sparse_image_size_gb=32"],"env_lines":["MESA_LOADER_DRIVER_OVERRIDE=kgsl","GALLIUM_DRIVER=kgsl","FD_FORCE_KGSL=1","TU_DEBUG=noconform","PULSE_SERVER=unix:/tmp/.pulse-socket"],"commands":{"create_image":"/data/local/Droidspaces/bin/droidspaces --rootfs-arc=<rootfs.tar.xz> --rootfs-img=/data/local/Droidspaces/Containers/rm11-turnip-kgsl/rootfs.img --size=32G create","start":"/data/local/Droidspaces/bin/droidspaces --config=/data/local/Droidspaces/Containers/rm11-turnip-kgsl/container.config start"},"source":%s},' \
    "$(json_string "$DROIDSPACES_NATIVE_METHOD_SOURCE")"
  printf '{"profile_id":"llvmpipe_software","method_id":"droidspaces_llvmpipe","container_name":"rm11-llvmpipe","rootfs_mode":"image","rootfs_image":"/data/local/Droidspaces/Containers/rm11-llvmpipe/rootfs.img","env_file":"/data/local/Droidspaces/Containers/rm11-llvmpipe/llvmpipe.env","config_path":"/data/local/Droidspaces/Containers/rm11-llvmpipe/container.config","config_lines":["name=rm11-llvmpipe","hostname=rm11-llvmpipe","rootfs_path=/data/local/Droidspaces/Containers/rm11-llvmpipe/rootfs.img","disable_ipv6=0","enable_android_storage=0","enable_termux_x11=1","enable_virgl=0","enable_pulseaudio=1","enable_hw_access=0","enable_gpu_mode=0","selinux_permissive=0","volatile_mode=0","force_cgroupv1=0","block_nested_ns=0","foreground=0","env_file=/data/local/Droidspaces/Containers/rm11-llvmpipe/llvmpipe.env","net_mode=host","run_at_boot=0","use_sparse_image=1","sparse_image_size_gb=32"],"env_lines":["LIBGL_ALWAYS_SOFTWARE=1","GALLIUM_DRIVER=llvmpipe","PULSE_SERVER=unix:/tmp/.pulse-socket"],"commands":{"create_image":"/data/local/Droidspaces/bin/droidspaces --rootfs-arc=<rootfs.tar.xz> --rootfs-img=/data/local/Droidspaces/Containers/rm11-llvmpipe/rootfs.img --size=32G create","start":"/data/local/Droidspaces/bin/droidspaces --config=/data/local/Droidspaces/Containers/rm11-llvmpipe/container.config start"},"source":%s},' \
    "$(json_string "$DROIDSPACES_NATIVE_METHOD_SOURCE")"
  printf '{"profile_id":"pulse_audio","method_id":"droidspaces_pulseaudio","container_name":"rm11-pulseaudio","rootfs_mode":"image","rootfs_image":"/data/local/Droidspaces/Containers/rm11-pulseaudio/rootfs.img","config_path":"/data/local/Droidspaces/Containers/rm11-pulseaudio/container.config","config_lines":["name=rm11-pulseaudio","hostname=rm11-pulseaudio","rootfs_path=/data/local/Droidspaces/Containers/rm11-pulseaudio/rootfs.img","disable_ipv6=0","enable_android_storage=0","enable_termux_x11=0","enable_virgl=0","enable_pulseaudio=1","enable_hw_access=0","enable_gpu_mode=0","selinux_permissive=0","volatile_mode=0","force_cgroupv1=0","block_nested_ns=0","foreground=0","net_mode=host","run_at_boot=0","use_sparse_image=1","sparse_image_size_gb=32"],"expected_env":["PULSE_SERVER=unix:/tmp/.pulse-socket"],"commands":{"create_image":"/data/local/Droidspaces/bin/droidspaces --rootfs-arc=<rootfs.tar.xz> --rootfs-img=/data/local/Droidspaces/Containers/rm11-pulseaudio/rootfs.img --size=32G create","start":"/data/local/Droidspaces/bin/droidspaces --config=/data/local/Droidspaces/Containers/rm11-pulseaudio/container.config start"},"source":%s}' \
    "$(json_string "$DROIDSPACES_NATIVE_METHOD_SOURCE")"
  printf '],"materialization_rules":["templates are read-only and safe to inspect","safe config-only materialization is direct atomic file creation, not a DroidSpaces CLI command","write container.config.tmp then move to container.config and chmod 0644","create only creates the image; start persists or mirrors the profile config","start later with droidspaces --config=<container.config> start","never share one writable rootfs.img across active profiles","prefer copying or rebuilding a rootfs image per profile before live testing"]}\n'
}

is_test_denied_path() {
  path=$1
  deny_list=${NEBULA_TEST_DENY_PATHS:-}
  old_ifs=$IFS
  IFS=:
  for denied in $deny_list; do
    if [ "$denied" = "$path" ]; then
      IFS=$old_ifs
      return 0
    fi
  done
  IFS=$old_ifs
  return 1
}

resolve_read_path() {
  path=$1
  root=${NEBULA_SYSROOT:-}
  if [ -n "$root" ]; then
    printf '%s%s' "$root" "$path"
  else
    printf '%s' "$path"
  fi
}

is_allowlisted_read_path() {
  case "$1" in
    /sys/kernel/fan/fan_enable|\
    /sys/kernel/fan/fan_speed_level|\
    /sys/kernel/fan/fan_speed_count|\
    /proc/driver/micropump/enable|\
    /proc/driver/micropump/freq|\
    /proc/driver/micropump/speed|\
    /sys/class/thermal/thermal_zone0/temp|\
    /sys/class/thermal/thermal_zone1/temp|\
    /sys/class/thermal/thermal_zone2/temp|\
    /sys/class/thermal/thermal_zone3/temp|\
    /sys/devices/virtual/thermal/thermal_zone0/temp|\
    /sys/devices/virtual/thermal/thermal_zone1/temp|\
    /sys/devices/virtual/thermal/thermal_zone2/temp|\
    /sys/devices/virtual/thermal/thermal_zone3/temp)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_allowlisted_file() {
  path=$1
  if ! is_allowlisted_read_path "$path"; then
    return 8
  fi
  actual=$(resolve_read_path "$path")
  if [ ! -e "$actual" ]; then
    return 2
  fi
  if is_test_denied_path "$path"; then
    return 3
  fi
  if [ ! -r "$actual" ]; then
    return 3
  fi
  head -n 1 "$actual" 2>/dev/null | cut -c 1-128
}

path_present() {
  path=$1
  actual=$(resolve_read_path "$path")
  [ -e "$actual" ]
}

read_prop() {
  name=$1
  case "$name" in
    ro.product.manufacturer|ro.product.model|ro.product.product.name|\
    ro.product.device|ro.board.platform|ro.product.marketname|ro.build.fingerprint)
      ;;
    *)
      return 8
      ;;
  esac
  prop_dir=${NEBULA_TEST_PROP_DIR:-}
  if [ -n "$prop_dir" ] && [ -f "$prop_dir/$name" ]; then
    head -n 1 "$prop_dir/$name" 2>/dev/null | cut -c 1-128
    return 0
  fi
  if command -v getprop >/dev/null 2>&1; then
    getprop "$name" 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

read_kernel_release() {
  if [ -n "${NEBULA_TEST_KERNEL:-}" ]; then
    printf '%s' "$NEBULA_TEST_KERNEL"
  else
    uname -r 2>/dev/null | head -n 1 | cut -c 1-128
  fi
}

value_or_unknown() {
  if [ -n "$1" ]; then
    printf '%s' "$1"
  else
    printf '%s' unknown
  fi
}

normalize_temp_c() {
  raw=$1
  case "$raw" in
    ''|*[!0-9.-]*) printf '%s' null; return ;;
  esac
  case "$raw" in
    *.*) printf '%s' "$raw"; return ;;
  esac
  if [ "$raw" -gt 1000 ] 2>/dev/null && [ "$raw" -lt 200000 ] 2>/dev/null; then
    whole=$((raw / 1000))
    frac=$((raw % 1000))
    printf '%s.%03d' "$whole" "$frac"
  elif [ "$raw" -gt -100 ] 2>/dev/null && [ "$raw" -lt 200 ] 2>/dev/null; then
    printf '%s' "$raw"
  else
    printf '%s' null
  fi
}

temp_to_milli_c() {
  raw=$1
  case "$raw" in
    ''|*[!0-9.]*|*.*.*) return 1 ;;
  esac
  case "$raw" in
    *.*)
      whole=${raw%%.*}
      frac=${raw#*.}
      case "$whole$frac" in
        ''|*[!0-9]*) return 1 ;;
      esac
      frac3=$(printf '%-3.3s' "$frac" | tr ' ' '0')
      printf '%s' $((whole * 1000 + frac3))
      ;;
    *)
      if [ "$raw" -gt 1000 ] 2>/dev/null; then
        printf '%s' "$raw"
      else
        printf '%s' $((raw * 1000))
      fi
      ;;
  esac
}

state_rank() {
  case "$1" in
    COOL) printf '%s' 1 ;;
    BALANCED) printf '%s' 2 ;;
    HOT) printf '%s' 3 ;;
    CRITICAL) printf '%s' 4 ;;
    *) printf '%s' 0 ;;
  esac
}

state_threshold_milli() {
  state=$1
  case "$state" in
    BALANCED) printf '%s' "$cp_balanced_milli" ;;
    HOT) printf '%s' "$cp_hot_milli" ;;
    CRITICAL) printf '%s' "$cp_critical_milli" ;;
    *) printf '%s' 0 ;;
  esac
}

intent_for_state() {
  supported=$1
  state=$2
  channel=$3
  if [ "$supported" != "1" ]; then
    printf '%s' unavailable
    return
  fi
  case "$state" in
    SAFE_MODE) printf '%s' stock ;;
    UNAVAILABLE) printf '%s' stock ;;
    COOL) printf '%s' off ;;
    BALANCED)
      if [ "$channel" = "fan" ]; then
        printf '%s' medium
      else
        printf '%s' low
      fi
      ;;
    HOT) printf '%s' high ;;
    CRITICAL) printf '%s' maximum ;;
    *) printf '%s' unavailable ;;
  esac
}

cooling_policy_fields() {
  cp_errors=
  cp_reason=
  cp_configured_text=$(config_bool configured)
  cp_configured=0
  if [ "$cp_configured_text" = "true" ]; then
    cp_configured=1
  fi

  cp_min_c=$(config_number_default temperature_min_c 0)
  cp_max_c=$(config_number_default temperature_max_c 120)
  cp_balanced_c=$(config_number_default balanced_c 38)
  cp_hot_c=$(config_number_default hot_c 42)
  cp_critical_c=$(config_number_default critical_c 46)
  cp_hysteresis_c=$(config_number_default hysteresis_c 2)
  cp_dwell=$(config_number_default minimum_dwell_seconds 30)

  cp_limit_min_milli=$(temp_to_milli_c "$cp_min_c") || cp_configured=0
  cp_limit_max_milli=$(temp_to_milli_c "$cp_max_c") || cp_configured=0
  cp_balanced_milli=$(temp_to_milli_c "$cp_balanced_c") || cp_configured=0
  cp_hot_milli=$(temp_to_milli_c "$cp_hot_c") || cp_configured=0
  cp_critical_milli=$(temp_to_milli_c "$cp_critical_c") || cp_configured=0
  cp_hysteresis_milli=$(temp_to_milli_c "$cp_hysteresis_c") || cp_configured=0
  case "$cp_dwell" in
    ''|*[!0-9]*) cp_dwell=30; cp_configured=0 ;;
  esac
  if ! [ "$cp_limit_min_milli" -le "$cp_balanced_milli" ] 2>/dev/null || \
     ! [ "$cp_balanced_milli" -le "$cp_hot_milli" ] 2>/dev/null || \
     ! [ "$cp_hot_milli" -le "$cp_critical_milli" ] 2>/dev/null || \
     ! [ "$cp_critical_milli" -le "$cp_limit_max_milli" ] 2>/dev/null; then
    cp_configured=0
  fi

  if [ "$cp_configured" != "1" ]; then
    cp_errors=$(list_append_json_string "$cp_errors" "CALIBRATION_REQUIRED")
  fi

  cp_fan_present=0
  cp_fan_supported=0
  cp_fan_enabled=
  cp_fan_rpm=
  cp_fan_level=
  for cp_fan_path in /sys/kernel/fan/fan_enable /sys/kernel/fan/fan_speed_level /sys/kernel/fan/fan_speed_count; do
    if path_present "$cp_fan_path"; then
      cp_fan_present=1
      cp_fan_supported=1
    fi
  done
  if [ "$cp_fan_present" = "1" ]; then
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_enable)
    cp_rc=$?
    if [ "$cp_rc" = "0" ]; then
      case "$cp_value" in
        0) cp_fan_enabled=false ;;
        1) cp_fan_enabled=true ;;
        *) cp_reason=$(list_append_json_string "$cp_reason" "invalid_fan_enabled:/sys/kernel/fan/fan_enable") ;;
      esac
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_enable")
    fi
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_count)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value"; then
      cp_fan_rpm=$cp_value
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_speed_count")
    fi
    cp_value=$(read_allowlisted_file /sys/kernel/fan/fan_speed_level)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value"; then
      cp_fan_level=$cp_value
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/sys/kernel/fan/fan_speed_level")
    fi
  else
    cp_reason=$(list_append_json_string "$cp_reason" "fan_missing")
  fi

  cp_pump_present=0
  cp_pump_supported=0
  cp_pump_enabled=
  cp_pump_speed=
  cp_pump_freq=
  for cp_pump_path in /proc/driver/micropump/enable /proc/driver/micropump/freq /proc/driver/micropump/speed /proc/driver/micropump/mode; do
    if path_present "$cp_pump_path"; then
      cp_pump_present=1
    fi
  done
  if path_present /proc/driver/micropump/enable; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/enable)
    cp_rc=$?
    if [ "$cp_rc" = "0" ]; then
      case "$cp_value" in
        0) cp_pump_enabled=false; cp_pump_supported=1 ;;
        1) cp_pump_enabled=true; cp_pump_supported=1 ;;
        *) cp_reason=$(list_append_json_string "$cp_reason" "invalid_pump_enabled:/proc/driver/micropump/enable") ;;
      esac
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/enable")
    fi
  fi
  if path_present /proc/driver/micropump/speed; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/speed)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value" && [ "$cp_value" -le 100 ] 2>/dev/null; then
      cp_pump_speed=$cp_value
      cp_pump_supported=1
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/speed")
    fi
  fi
  if path_present /proc/driver/micropump/freq; then
    cp_value=$(read_allowlisted_file /proc/driver/micropump/freq)
    cp_rc=$?
    if [ "$cp_rc" = "0" ] && is_unsigned_integer "$cp_value" && [ "$cp_value" -le 100 ] 2>/dev/null; then
      cp_pump_freq=$cp_value
      cp_pump_supported=1
    elif [ "$cp_rc" = "3" ]; then
      cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:/proc/driver/micropump/freq")
    fi
  fi
  if [ "$cp_pump_present" = "0" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "pump_missing")
  fi

  cp_valid=0
  cp_rejected=0
  cp_observed_max_milli=
  cp_sensor_name=
  cp_sensor_source=
  for cp_thermal_path in \
    /sys/class/thermal/thermal_zone0/temp \
    /sys/class/thermal/thermal_zone1/temp \
    /sys/class/thermal/thermal_zone2/temp \
    /sys/class/thermal/thermal_zone3/temp \
    /sys/devices/virtual/thermal/thermal_zone0/temp \
    /sys/devices/virtual/thermal/thermal_zone1/temp \
    /sys/devices/virtual/thermal/thermal_zone2/temp \
    /sys/devices/virtual/thermal/thermal_zone3/temp
  do
    if path_present "$cp_thermal_path"; then
      cp_value=$(read_allowlisted_file "$cp_thermal_path")
      cp_rc=$?
      if [ "$cp_rc" = "0" ]; then
        if cp_milli=$(temp_to_milli_c "$cp_value") && [ "$cp_milli" -ge "$cp_limit_min_milli" ] 2>/dev/null && [ "$cp_milli" -le "$cp_limit_max_milli" ] 2>/dev/null; then
          cp_valid=$((cp_valid + 1))
          if [ -z "$cp_observed_max_milli" ] || [ "$cp_milli" -gt "$cp_observed_max_milli" ] 2>/dev/null; then
            cp_observed_max_milli=$cp_milli
            cp_sensor_name=$cp_thermal_path
            cp_sensor_source=$REDMAGIC_SOURCE_THERMAL
          fi
        else
          cp_rejected=$((cp_rejected + 1))
          cp_reason=$(list_append_json_string "$cp_reason" "rejected_thermal:$cp_thermal_path")
        fi
      elif [ "$cp_rc" = "3" ]; then
        cp_rejected=$((cp_rejected + 1))
        cp_errors=$(list_append_json_string "$cp_errors" "permission_denied:$cp_thermal_path")
      fi
    fi
  done

  cp_state=UNAVAILABLE
  if [ "$cp_configured" != "1" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "CALIBRATION_REQUIRED")
  elif [ "$(safe_mode_value)" = "1" ]; then
    cp_state=SAFE_MODE
    cp_reason=$(list_append_json_string "$cp_reason" "safe_mode")
  elif [ "$cp_configured" = "1" ] && [ "$cp_valid" -gt 0 ]; then
    if [ "$cp_observed_max_milli" -ge "$cp_critical_milli" ] 2>/dev/null; then
      cp_state=CRITICAL
    elif [ "$cp_observed_max_milli" -ge "$cp_hot_milli" ] 2>/dev/null; then
      cp_state=HOT
    elif [ "$cp_observed_max_milli" -ge "$cp_balanced_milli" ] 2>/dev/null; then
      cp_state=BALANCED
    else
      cp_state=COOL
    fi

    cp_previous=${NEBULA_POLICY_PREVIOUS_STATE:-}
    cp_age=${NEBULA_POLICY_PREVIOUS_STATE_AGE_SECONDS:-999999}
    case "$cp_age" in
      ''|*[!0-9]*) cp_age=999999 ;;
    esac
    cp_prev_rank=$(state_rank "$cp_previous")
    cp_state_rank=$(state_rank "$cp_state")
    if [ "$cp_prev_rank" -gt "$cp_state_rank" ] 2>/dev/null; then
      if [ "$cp_age" -lt "$cp_dwell" ] 2>/dev/null; then
        cp_state=$cp_previous
        cp_reason=$(list_append_json_string "$cp_reason" "minimum_dwell_active")
      else
        cp_hold_threshold=$(state_threshold_milli "$cp_previous")
        cp_hold_floor=$((cp_hold_threshold - cp_hysteresis_milli))
        if [ "$cp_hold_threshold" -gt 0 ] 2>/dev/null && [ "$cp_observed_max_milli" -ge "$cp_hold_floor" ] 2>/dev/null; then
          cp_state=$cp_previous
          cp_reason=$(list_append_json_string "$cp_reason" "hysteresis_hold")
        fi
      fi
    fi
  elif [ "$cp_valid" = "0" ]; then
    cp_reason=$(list_append_json_string "$cp_reason" "no_valid_thermal")
  fi

  cp_fan_intent=$(intent_for_state "$cp_fan_supported" "$cp_state" fan)
  cp_pump_intent=$(intent_for_state "$cp_pump_supported" "$cp_state" pump)

  if [ -z "$cp_fan_enabled" ]; then cp_fan_enabled_json=null; else cp_fan_enabled_json=$cp_fan_enabled; fi
  if [ -z "$cp_pump_enabled" ]; then cp_pump_enabled_json=null; else cp_pump_enabled_json=$cp_pump_enabled; fi
  if [ -z "$cp_observed_max_milli" ]; then cp_max_json=null; else cp_max_json=$(json_number_from_milli "$cp_observed_max_milli"); fi
  if [ -z "$cp_sensor_name" ]; then cp_sensor_name_json=null; else cp_sensor_name_json=$(json_string "$cp_sensor_name"); fi
  if [ -z "$cp_sensor_source" ]; then cp_sensor_source_json=null; else cp_sensor_source_json=$(json_string "$cp_sensor_source"); fi

  printf '"preview_only":true,'
  printf '"configured":%s,' "$(json_bool "$cp_configured")"
  printf '"safe_mode":%s,' "$(json_bool "$(safe_mode_value)")"
  printf '"state":%s,' "$(json_string "$cp_state")"
  printf '"controlling_sensor":{"name":%s,"source":%s,"temperature_c":%s},' \
    "$cp_sensor_name_json" "$cp_sensor_source_json" "$cp_max_json"
  printf '"thermal":{"maximum_c":%s,"valid_sensor_count":%s,"rejected_sensor_count":%s},' \
    "$cp_max_json" "$cp_valid" "$cp_rejected"
  printf '"fan":{"supported":%s,"present":%s,"current":{"enabled":%s,"rpm":%s,"level":%s},"intent":%s,"applied":false},' \
    "$(json_bool "$cp_fan_supported")" \
    "$(json_bool "$cp_fan_present")" \
    "$cp_fan_enabled_json" \
    "$(json_int_or_null "$cp_fan_rpm")" \
    "$(json_int_or_null "$cp_fan_level")" \
    "$(json_string "$cp_fan_intent")"
  printf '"pump":{"supported":%s,"present":%s,"current":{"enabled":%s,"speed":%s,"freq":%s},"intent":%s,"applied":false},' \
    "$(json_bool "$cp_pump_supported")" \
    "$(json_bool "$cp_pump_present")" \
    "$cp_pump_enabled_json" \
    "$(json_int_or_null "$cp_pump_speed")" \
    "$(json_int_or_null "$cp_pump_freq")" \
    "$(json_string "$cp_pump_intent")"
  printf '"policy":{"threshold_source":"defaults.json","hysteresis_c":%s,"minimum_dwell_seconds":%s},' \
    "$(json_number_from_milli "$cp_hysteresis_milli")" \
    "$cp_dwell"
  printf '"reason":[%s],"errors":[%s]' "$cp_reason" "$cp_errors"
}

cooling_policy_json() {
  printf '{"protocol_version":%s,"command":"cooling policy",' "$PROTOCOL_VERSION"
  cooling_policy_fields
  printf '}\n'
}

module_prop_from_dir() {
  dir=$1
  key=$2
  prop="$dir/module.prop"
  if [ -f "$prop" ]; then
    sed -n "s/^$key=//p" "$prop" | head -n 1
  fi
}

legacy_module_entry() {
  id=$1
  title=$2
  source=$3
  staged=$4
  dir="$MODULES_ROOT/$id"
  installed=0
  disabled=0
  remove_marker=0
  version=unknown
  version_code=0
  description=
  if [ -d "$dir" ]; then
    installed=1
    version=$(module_prop_from_dir "$dir" version)
    version_code=$(module_prop_from_dir "$dir" versionCode)
    description=$(module_prop_from_dir "$dir" description)
    [ -f "$dir/disable" ] && disabled=1
    [ -f "$dir/remove" ] && remove_marker=1
  fi
  [ -n "$version" ] || version=unknown
  case "$version_code" in
    ''|*[!0-9]*) version_code=0 ;;
  esac
  if [ -z "$description" ]; then description=unknown; fi
  printf '{"id":%s,"title":%s,"protected":true,"installed":%s,"disabled":%s,"remove_marker":%s,"version":%s,"version_code":%s,"description":%s,"nebula_import":%s,"source":%s}' \
    "$(json_string "$id")" \
    "$(json_string "$title")" \
    "$(json_bool "$installed")" \
    "$(json_bool "$disabled")" \
    "$(json_bool "$remove_marker")" \
    "$(json_string "$version")" \
    "$version_code" \
    "$(json_string "$description")" \
    "$(json_string "$staged")" \
    "$(json_string "$source")"
}

legacy_modules_json() {
  printf '{"protocol_version":%s,"command":"legacy modules","migration_enabled":false,"modules":[' "$PROTOCOL_VERSION"
  legacy_module_entry droidspaces "Droidspaces: Daemon & Init" "$LEGACY_DROIDSPACES_SOURCE" "staged_audit_only"
  printf ','
  legacy_module_entry rm11-droidspace-bridge-fd "RM11 Droidspaces Bridge FD Policy" "$LEGACY_BRIDGE_SOURCE" "staged_audit_only"
  printf '],"guardrails":["do_not_disable_both","do_not_delete_until_reboot_verified","nebula_core_does_not_start_targets_by_default"]}\n'
}

module_installed_value() {
  if [ -d "$MODULES_ROOT/$1" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

module_disabled_value() {
  if [ -f "$MODULES_ROOT/$1/disable" ]; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

package_visible_value() {
  if package_visible "$1"; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

path_present_value() {
  if path_present "$1"; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

fixed_path_executable_value() {
  if fixed_path_executable "$1"; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

fixed_path_exists_value() {
  if fixed_path_exists "$1"; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

fixed_path_socket_value() {
  if fixed_path_socket "$1"; then
    printf '%s' 1
  else
    printf '%s' 0
  fi
}

integrations_baseline_json() {
  ensure_dirs
  waylandie_collect

  droidspaces_package=$(package_visible_value "$DROIDSPACES_PACKAGE")
  droidspaces_module=$(module_installed_value droidspaces)
  droidspaces_module_disabled=$(module_disabled_value droidspaces)
  droidspaces_bridge_module=$(module_installed_value rm11-droidspace-bridge-fd)
  anland_collect
  droidspaces_installed=0
  if [ "$droidspaces_package" = "1" ] || [ "$droidspaces_module" = "1" ] || [ "$anland_bin" = "1" ]; then
    droidspaces_installed=1
  fi
  droidspaces_status=$anland_status
  droidspaces_ready=$anland_runtime_ready
  if [ "$droidspaces_installed" = "0" ]; then
    droidspaces_status=missing
    droidspaces_ready=0
	  elif [ "$anland_runtime_ready" != "1" ] && [ "$droidspaces_installed" = "1" ] && [ "$anland_status" = "missing" ]; then
	    droidspaces_status=partial
	  fi
	  wl_integration_status=missing
	  wl_container_status=missing
	  wl_display_status=display_missing
	  wl_runtime_status=runtime_missing
	  if [ "$wl_display_ready" = "1" ]; then
	    wl_integration_status=display_ready
	    wl_display_status=display_proven
	  elif [ "$wl_installed" = "1" ]; then
	    wl_integration_status=partial
	  fi
	  if [ "$wl_ready" = "1" ]; then
	    wl_container_status=ready
	    wl_runtime_status=runtime_ready
	  elif [ "$wl_installed" = "1" ]; then
	    wl_container_status=partial
	  fi
	  droidspaces_container_status=missing
	  droidspaces_display_status=display_missing
	  droidspaces_runtime_status=runtime_missing
	  droidspaces_requirement_status=missing_requirements
	  if [ "$droidspaces_installed" = "0" ]; then
	    droidspaces_requirement_status=droidspaces_missing
	  elif [ "$anland_selection_ambiguous" = "1" ]; then
	    droidspaces_container_status=ambiguous
	    droidspaces_requirement_status=ambiguous_selection
	  elif [ -z "$anland_selected_container" ]; then
	    droidspaces_requirement_status=invalid_selection
	  elif [ "$anland_container_active" = "1" ]; then
	    droidspaces_container_status=active
	  elif [ "$anland_runtime_ready" = "1" ]; then
	    droidspaces_container_status=ready
	  elif [ "$anland_config" = "1" ]; then
	    droidspaces_container_status=idle
	  fi
	  if [ "$anland_runtime_ready" = "1" ]; then
	    droidspaces_runtime_status=runtime_ready
	  fi
	  if [ "$anland_ready" = "1" ]; then
	    droidspaces_display_status=display_ready
	    droidspaces_requirement_status=complete
	  elif [ "$droidspaces_requirement_status" = "ambiguous_selection" ] || [ "$droidspaces_requirement_status" = "invalid_selection" ] || [ "$droidspaces_requirement_status" = "droidspaces_missing" ]; then
	    true
	  elif [ "$anland_rootfs_allowed" != "1" ]; then
	    droidspaces_requirement_status=invalid_rootfs_path
	  elif [ "$anland_rootfs" != "1" ]; then
	    droidspaces_requirement_status=missing_requirements
	  elif [ "$anland_socket" != "1" ] && [ "$anland_env" != "1" ]; then
	    droidspaces_requirement_status=missing_requirements
    elif [ "$anland_socket" != "1" ]; then
      droidspaces_requirement_status=missing_requirements
    elif [ "$anland_socket_writable" != "1" ]; then
      droidspaces_requirement_status=missing_requirements
    elif [ "$anland_env" != "1" ]; then
      droidspaces_requirement_status=missing_requirements
	  fi

  vector_installed=$(module_installed_value zygisk_vector)
  vector_enabled=0
  if [ "$vector_installed" = "1" ] && [ "$(module_disabled_value zygisk_vector)" = "0" ]; then
    vector_enabled=1
  fi
  nubia_game_assist=$(package_visible_value "$NUBIA_GAME_ASSIST_PACKAGE")
  nubia_game_launcher=$(package_visible_value "$NUBIA_GAME_LAUNCHER_PACKAGE")
  nubia_toolkit_reference=$(package_visible_value "$NUBIA_TOOLKIT_PACKAGE")
  nubia_status=hook_lane_deferred
  nubia_installed=0
  nubia_ready=0
  if [ "$nubia_game_assist" = "1" ] || [ "$nubia_game_launcher" = "1" ] || [ "$nubia_toolkit_reference" = "1" ]; then
    nubia_installed=1
  fi
  if [ "$vector_enabled" = "1" ] && { [ "$nubia_game_assist" = "1" ] || [ "$nubia_game_launcher" = "1" ]; }; then
    nubia_status=hook_framework_ready_scope_deferred
    nubia_ready=1
  elif [ "$vector_installed" = "1" ] || [ "$nubia_game_assist" = "1" ] || [ "$nubia_game_launcher" = "1" ]; then
    nubia_status=partial
  fi

  redmagic_control_package=$(package_visible_value "$REDMAGIC_CONTROL_PACKAGE")
  redmagic_fan=$(path_present_value /sys/kernel/fan/fan_enable)
  redmagic_fan_level=$(path_present_value /sys/kernel/fan/fan_speed_level)
  redmagic_pump=$(path_present_value /proc/driver/micropump/enable)
  redmagic_led=$(path_present_value /sys/class/leds/aw22xxx_led/effect)
  redmagic_triggers=0
  if path_present /sys/class/leds/sar0/mode_operation || path_present /sys/class/leds/sar1/mode_operation; then
    redmagic_triggers=1
  fi
  redmagic_status=nodes_missing
  redmagic_ready=0
  if [ "$redmagic_fan" = "1" ] || [ "$redmagic_fan_level" = "1" ] || [ "$redmagic_pump" = "1" ]; then
    redmagic_status=read_only_nodes_visible
    redmagic_ready=1
  elif [ "$redmagic_control_package" = "1" ]; then
    redmagic_status=reference_apk_visible
  fi

  powerdeck_module=$(module_installed_value "$POWERDECK_MODULE_ID")
  powerdeck_disabled=$(module_disabled_value "$POWERDECK_MODULE_ID")
  powerdeck_tmp_apply=$(fixed_path_executable_value /data/local/tmp/redmagic_powerdeck/rm-powerdeck-apply.sh)
  powerdeck_status=nebula_preview_ready
  if [ "$powerdeck_module" = "1" ]; then
    powerdeck_status=external_module_detected_dry_run_required
  fi

  overall_status=baseline_partial
  if [ "$wl_display_ready" = "1" ] \
    && { [ "$droidspaces_ready" = "1" ] || [ "$droidspaces_module" = "1" ] || [ "$droidspaces_package" = "1" ]; } \
    && { [ "$redmagic_fan" = "1" ] || [ "$redmagic_pump" = "1" ]; }; then
    overall_status=baseline_ready_read_only
  elif [ "$wl_installed" != "1" ] && [ "$droidspaces_package" != "1" ] && [ "$droidspaces_module" != "1" ]; then
    overall_status=baseline_bootstrap
  fi

  printf '{"protocol_version":%s,"command":"integrations baseline",' "$PROTOCOL_VERSION"
  printf '"baseline_id":"nebula_rm11pro_baseline","overall_status":%s,' "$(json_string "$overall_status")"
  printf '"apk_package":"io.droidspaces.nebula","module_id":"%s","safe_default":true,"mutating_controls_enabled":false,' "$MODULE_ID"
  printf '"requirements":["Root with KernelSU/Magisk-compatible module support","Nebula Core module installed for root-side status","WayLandIE companion APK for Phone/App display lane","DroidSpaces/Anland files for container surface fallback","RM11 Pro/NX809J hardware for RedMagic fan, pump, LED, and trigger nodes","Vector/LSPosed only when hook lanes are intentionally enabled"],'
  printf '"integrations":['
  printf '{"id":"nebula_core","title":"Nebula Core module","owner":"Nebula","role":"fixed_root_contract","status":"ready","installed":true,"ready":true,"mutating":false,"version":%s,"source":"nebula-core-module"},' \
    "$(json_string "$(module_version)")"
	  printf '{"id":"waylandie","method_id":"phone_app_bridge","title":"WayLandIE display/runtime","owner":"WayLandIE companion APK","role":"phone_app_bridge","status":%s,"installed":%s,"ready":%s,"display_ready":%s,"runtime_ready":%s,"container_ref":"waylandie_app_imagefs","container_kind":"app_proot","container_status":%s,"display_status":%s,"runtime_status":%s,"requirement_status":"display_requirements_met","missing_requirements":["game_client_runtime_proof_not_promoted_39bit_va"],"mutating":false,"package":%s,"evidence":%s,"source":%s,"errors":[%s]},' \
	    "$(json_string "$wl_integration_status")" \
	    "$(json_bool "$wl_installed")" \
	    "$(json_bool "$wl_display_ready")" \
	    "$(json_bool "$wl_display_ready")" \
	    "$(json_bool "$wl_ready")" \
	    "$(json_string "$wl_container_status")" \
	    "$(json_string "$wl_display_status")" \
